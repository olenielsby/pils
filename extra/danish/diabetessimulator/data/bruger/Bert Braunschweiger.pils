><:[modul:. program dansk maxi-projektet diabeteshjælper data insulinpræparaterne .tidsstempel 2009-10-21T00:06:23.324+02 .sprog dansk]><;
;insulinpræparaterne
[ [ medicinering:
    .under menu
    .kategori "Insulin"
    .navn "Analog"
    .billede "diverse/insulin_pen.svg"
    .dosis 1
    .sammensætning
    [sammensætning: .1 1]
  ]
  [ medicinering:
    .under "Analog"
    .kategori "Insulin"
    .navn "Human"
    .billede "diverse/insulin_pen.svg"
    .dosis 1
    .sammensætning
    [sammensætning: .2 1]
  ]
  [ medicinering:
    .under "Analog"
    .kategori "Insulin"
    .navn "Intermediær"="human"
    .billede "diverse/insulin_pen.svg"
    .dosis 1
    .sammensætning
    [sammensætning: .3 1]
  ]
  [ medicinering:
    .under "Analog"
    .kategori "Insulin"
    .navn "Langsom analog"
    .billede "diverse/insulin_pen.svg"
    .dosis 1
    .sammensætning
    [sammensætning: .4 1]
  ]
]
