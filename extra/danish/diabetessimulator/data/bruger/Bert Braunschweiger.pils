  [ motion:
    .under cykling
    .kategori motion
    .navn boldspil
    .billede "motion/bevaegelse_boldspil.svg"
    .puls 140
    .minutterne 30
  ]
  [ motion:
    .under cykling
    .kategori motion
    .navn løb
    .billede "motion/bevaegelse_loeb.svg"
    .puls 140
    .minutterne 30
  ]
]
