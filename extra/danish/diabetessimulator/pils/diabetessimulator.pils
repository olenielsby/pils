><:[modul:. program dansk maxi-projektet diabeteshjælper data madvarerne .tidsstempel 2011-09-30T00:34:55.058+02 .sprog dansk]><;
(;madvarerne) ===
{ .madvarerne
| :ok
  ;sti dette modul sti <-#=* "/pils/" "/data/mad/";
  @@ madfilerne hver
  { $ madfil
  | madfil <+#^* "." kald [."xml" xml ."xlsx" xslx ."ods" ods] .:kræv
    kald (@@ import)
    læs (.fil datafil (sti . madfil))
    hver {ok|:prøv ok find {? <> ()|:ok}} -# 1
    først [ukendt] fold
    { ? := vare = (+$ kategori) 1
    | :ok liste := (kategori:.; vare -# 1); kategori
    }
    { kategori := vare = () 1
    | :ok liste := (kategori:.; vare -# 1); kategori
    }
  }
  .:liste benene
  { orden :=
    kategori:.;
    navn, energi, protein, fedt, kulhydrat, alkohol, glukose, sukker,
    billede, filtype, mappe,
    1, gram, hak
  | :ok
    madvare: .orden .kategori
    .navn .energi .protein .fedt .kulhydrat .alkohol .glukose .sukker
    .billede mappe . "/" . billede . "." . filtype === {: () . ?|:ok ()}
    .gram .hak
  }
  grupperne [kald: kategori]
  benene
  { kategori := varerne = (* ;navn) 1
  | :ok
    varerne benene
    {? := vare|:ok vare flet: ;under navn }
    {1 := vare|:ok vare flet: ;under [menu] }
  }
  splejs orden [kald: orden]
}
><:[modul:. program dansk maxi-projektet diabeteshjælper data madvarerne import .tidsstempel 2008-12-24T13:52:04.398+01 .sprog dansk]><;
@@><:[modul:. program dansk maxi-projektet diabeteshjælper data madvarerne import ods .tidsstempel 2011-07-22T00:48:22.767+02 .sprog offipyk]><;
{ .filtype | :ok "ods" }
{ læs: .fil
| :ok
  fil zip
  find
  { "content.xml", xml, ? | :ok @@ engelsk:parse engelsk:xml: xml }
  ?
  find
  { oo:body: (oo:spreadsheet: (* otb:table: .otb:name "Ark1"; ok) 1) 1
  | :ok
  }
  hver {* otb:table-row: ok|:ok}
  hver
  { række
  | :ok række enhver
    { * otb:table-cell: ok | :ok ', }
    { * otb:table-cell: .otb:number-columns-repeated antal; ok
    | :ok {} læs (antal) op hver: ok: ok
    }
    splejs
    enhver
    { (ot:p: ok),
    | :ok ' **=** {+? := $ tekst|:ok liste := tekst} .:liste splejs ""
    }
    { | :ok ()}
    enhver
    { ok | :ok }
    { tal +* "0123456789" | :prøv {} læs (tal) }
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper data madvarerne import xlsx .tidsstempel 2011-07-21T02:41:08.356+02 .sprog ms-offipyk]><;
{ .filtype | :ok "xlsx" }
{ læs: .fil
| :ok
  :brug
  fil zip
  eneste
  { navn kald
    [ ."xl/sharedStrings.xml" teksterne
      ."xl/worksheets/sheet1.xml" felterne
    ]
    , værdi, ?
  | :ok :navn; @@ engelsk:parse engelsk:xml: værdi
  }
  ;
  ;teksterne '? enhver
    { oxl:si: ok
    | :ok ' **=** {* oxl:t: tekst|:ok liste := tekst} .:liste  splejs splejs ""
    }
  ;
  felterne? find {oxl:sheetData: ok|:ok}
  enhver
  { * oxl:row: ok
  | :ok ' enhver
    { * oxl:c: .oxl:r;
    | :ok celle:. oxl:r;
    }
    { * oxl:c: .oxl:r; (oxl:v: tal,),
    | :ok celle:. oxl:r; {} læs (tal)
    }
    { * oxl:c:.oxl:r .oxl:t "s"; (oxl:v: index,),
    | :ok celle:. oxl:r; {} læs (index) + 1 kald (teksterne)
    }
    enhver {celle:.; ok|:ok celle:. ' bytes . 1 - 64; ok}
    eneste {celle:. navn; værdi|:ok :navn; værdi}
    prøv
    {* node|:ok node kliche benene størst [ok] op hver ([ok:] +++ node) }
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper data madvarerne import xml .tidsstempel 2011-09-30T00:11:23.391+02 .sprog ms-offipyk]><;
{ .filtype | :ok "xml" }
{ læs: .fil
| :ok
  @@ engelsk:parse engelsk:xml (fil tekst)?
  find {* ss:Worksheet: ok|:ok}
  find {* ss:Table: ok|:ok}
  **=**
  { ss:Data: .ss:Type?; ok | :hvem :ok ' **=** hvem }
  { ss:Data: .ss:Type "Number"; ok | :ok ' splejs "" .({} læs:) }
  { html:B: ok | :hvem :ok ' **=** hvem }
  hver
  { * ss:Row: ok
  | :ok ' hver
    {* ss:Cell: ok|:ok celle: ok}
    {* ss:Cell: .ss:Index nummer; ok | :ok celle: .nummer ' .({} læs:); ok}
    først 1 fold
    { n := celle: ok | :ok liste := ok; n + 1 }
    { n := =' = celle: .nummer; ?
    | :hvem :hvis nummer > n; :ok liste := (); (n + 1) kald (hvem) :=
    }
    { n := celle: .nummer n; ok | :ok liste := ok; n + 1 }
    .:liste enhver
    { ok | :ok ' igen {ok|:ok ' splejs} kald {ok|:ok ' splejs ""} {|:ok ()} }
    { # ok, | :ok }
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne .tidsstempel 2009-10-21T00:16:40.498+02 .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne blodsukkermåling .tidsstempel 2011-07-22T00:23:31.570+02 .sprog dansk]><;
 { * blodsukkermåling: .billede .værdi
| :ok
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :ok
    ;x tidslinje x (.tid)
    .glukoseskala lærred husk glukoseskala
    ;
    ( :hvis tid >= nu + 10m;
      lærred husk glukosekurve find
      ( {tid:. ' afrund 1m; :citat værdi|:citat :ok værdi:. ' * 10 afrund / 10}
        .: ---'
      )
      eller ()
    )
    kald
    { værdi:.
    | :ok
      ;y glukoseskala y (.g værdi) & 15 & (lærred stræk . 2 - 15) orden [ok] 2;
      mal blodsukkermåling: .grafik .værdi .billede .x .y
      .forklaring [estimeret blodsukker]
    }
    eller:
    ;y glukoseskala y (.flyder);
    ;y glukoseskala y (.g glukoseskala g (.y) * 10 afrund / 10);
    mal blodsukkermåling: .grafik .værdi glukoseskala g (.y) .billede .x .y
    .forklaring [blodsukker målt]
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne dosisjustering .tidsstempel 2011-09-30T14:48:29.169+02 .sprog dansk]><;
;hak 16;
{ dosisjustering: emne:. .flyder flyder [emne] .tid tid [emne]
| :ok
  { dosis: .y .glukoseskala
  | :ok
    ( (glukoseskala y (.flyder flyder [emne]) - y) / hak afrund + (emne dosis),
      1
    )
    størst [ok]
  }
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :hvem :ok
    ;glukoseskala lærred husk glukoseskala;
    ;x tidslinje x (.tid)
    .[x: emne] tidslinje x (.tid tid [emne])
    .y glukoseskala y (.flyder)
    .[y: emne] glukoseskala y (.flyder flyder [emne])
    ;
    ;dosis
    ( :hvis (x >= x [emne] - 60) og (x < x [emne] + 140);
      hvem dosis (.y .glukoseskala)
      .ellers emne dosis
    )
    ;
    mal dosisjustering:
    .grafik
    .dosis
    .x x [emne] + 32
    .y y [emne] + (emne dosis - dosis) * hak
    .[x: emne]
    .[y: emne]
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne madvare .tidsstempel 2009-08-29T21:33:09.663+02 .sprog dansk]><;
{ madindtag = * madvare: .glukose .gram .billede .navn .hak
| :ok
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :ok
    mal madindtag:.
    .grafik
    .x tidslinje x (.tid)
    .y lærred husk glukoseskala y (.flyder)
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne medicinering .tidsstempel 2011-09-30T00:33:01.540+02 .sprog dansk]><;
{ medicinering = * ': .dosis .billede .navn
| :ok
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :ok
    mal medicinering:
    .grafik
    .dosis
    .x tidslinje x (.tid)
    .y lærred husk glukoseskala y (.flyder)
    .billede
    .navn
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne motion .tidsstempel 2011-09-30T00:32:50.868+02 .sprog dansk]><;
{ [motion] * '
| :ok
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :ok
    mal motion:. .grafik .tidslinje .tid .y lærred husk glukoseskala y (.flyder)
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne varighed .tidsstempel 2011-09-30T00:32:32.484+02 .sprog dansk]><;
{ varighed: emne:. .flyder .tid
| :ok
  { mal:. .grafik .tidslinje .tid tid [slut] .flyder? .lærred
  | ;minutterne (tid [slut] - tid) / 1m afrund;
    :hvis minutterne; :ok
    mal varighedsjustering:
    .grafik
    .tidslinje
    .tid
    .[tid: slut]
    .minutterne
    .y lærred husk glukoseskala y (.flyder)
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper emnerne vægtjustering .tidsstempel 2011-09-30T14:46:53.553+02 .sprog dansk]><;
;hak 16;
{ vægtjustering: emne:. .flyder flyder [emne] .tid tid [emne]
| :ok
  { vægt: .y .glukoseskala
  | :ok
    ( (glukoseskala y (.flyder flyder [emne]) - y) / hak afrund * (emne hak)
      + emne gram,
      emne hak
    )
    størst [ok]
  }
  { mal:. .grafik .tidslinje .tid .flyder .lærred
  | :hvem :ok
    ;glukoseskala lærred husk glukoseskala;
    ;x tidslinje x (.tid)
    .[x: emne] tidslinje x (.tid tid [emne])
    .y glukoseskala y (.flyder)
    .[y: emne] glukoseskala y (.flyder flyder [emne])
    ;
    ;vægt
    ( :hvis (x >= x [emne] - 60) og (x < x [emne] + 140);
      hvem vægt (.y .glukoseskala)
      .ellers emne gram
    )
    ;
    mal vægtjustering:
    .grafik
    .x x [emne] + 30
    .y y [emne] + (emne gram - vægt) \ (emne hak) * hak
    .[x: emne]
    .[y: emne]
    .vægt
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper forløb .tidsstempel 2011-09-30T00:14:40.734+02 .sprog dansk]><;
{ forløb:
  .tidslinje
  .placering
  ;
  & emnerne
| :ok
  [fra til] hver (placering)
  hver {x|:ok tidslinje afrund (.tid tidslinje tid (.x))}
  kald
  {fra, til|:ok 0 op ((til - fra) / 1m) hver {x|:ok tid:. fra + x * 1m;}}
  & (emnerne hver (@@ hændelsesreduktion) splejs)
  grupperne {tid:.; værdi|:ok :navn tid; værdi}
  benene {tid := hændelserne = () 1|:ok tid:.; hændelserne}
  orden [kald: tid]
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning .tidsstempel 2009-08-13T20:48:38.205+02 .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning baggrundene .tidsstempel 2009-10-21T01:32:18.655+02 .sprog dansk]><;
