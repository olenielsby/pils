| :who
  @ graphics (. j:Graphics (who) .:need) try (painter) and: :ok who
}
{ .height | :who ' j:getHeight .:ok }
{ .width | :who ' j:getWidth .:ok }
{ .png
| :who
  ;stream j:MemoryOutputStream ();
  j:PNGImageFormat () j:writeImageToStream (who, stream) .:need and:
