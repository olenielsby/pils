><:[module:. platform juce parent list .timestamp 2011-09-28T16:56:39.758+02 .language juce]><;
{ parent: .; (list: .style) anyway [.style]
| :ok
  parent j:new (j:ListBox ())
  call
  { list
  | :ok
    list mind j:items := ();
    list mind j:settings :=
    ( settings:
      .justification j:Justification 1
      .[colour: 0] j:Colour [0 0 0]
      .[colour: 1] j:Colour [190 180 255]
      .icons ()
      .rectanglePlacement j:RectanglePlacement 64
    )
    ;
    list
  }
  when
  { + n
  | :who [list]; :if n <= who [list] mind j:items count; :ok
    {|:ok n}
    { .text | :try who [list] mind j:items .:need . n .:need text }
    { text: text
    | :who :possibly
       who [list] mind j:items :=
       who [list] mind j:items .:need legs
       { n' := ok | :ok ' merge: :if n = n'; ;text }
       ;
       who [list] j:repaintRow (n - 1) and:
       who
    }
    { icon:. ' count
    | :who :ok
      ;items who [list] mind j:items;
      who [list] mind j:items :=
        (items +# (n - 1)) & (items . n merge (;icon)) & (items -# n)
      ;
      who [list] j:repaintRow (n - 1) and:
      who
    }
    { .list | :ok who [list] }
    { .select | :who :ok who [list] j:selectRow (n - 1) and: who }
  }
  { (icons:. .size) anyway [.size 16]
  | :who
    who mind j:settings :=
    ( who mind j:settings merge:
      ;icons ' every {ok j:Image|:ok} .:need .size
    );
    :ok who
  }
  { (icons: .pairs .size) anyway [.size 16]
  | :who
    who mind j:settings :=
    ( who mind j:settings merge:
      ;icons pairs every {ok = (? j:Image, ? j:Image)|:ok} .:need .size
    );
    :ok who
  }
  { add: & items
  | :who ;items ' every {$ text|:ok item: .text} .:need; :ok
    who mind j:items := who mind j:items & items;
    who j:updateContent
  }
  { add: $ text
  | :who :ok
    who mind j:items := who mind j:items & (item: .text);
    who j:updateContent
  }
  { insert: $ text
  | :who :ok
    ;old who mind j:items;
    ;at (0, who j:getLastRowSelected or 0, old count) order [ok] 2;
    who mind j:items := old +# at & (item: .text) & (old -# at);
    who j:updateContent
  }
  { hot: + n | :who ' j:selectRow (n - 1) .:ok }
  { .hot | :who (' j:getLastRowSelected + 1) call (who) .:try }
  { delete: + n
  | :who
    ;items who mind j:items;
    who mind j:items := items +# n .:need <-# 1 & (items -# n);
    :ok who j:updateContent
  }
  { width: .column?; ? | :who ' .:ok }
  { .count | :who ' mind j:items count .:ok }
  { text: + n | :who ' mind j:items . n .:need text .:try }
  { .clear | :who :ok who mind j:items := (); who j:updateContent }
  { .focus | :who ' j:grabKeyboardFocus .:ok }
  { tip: tip | :who :ok who mind tip := tip; who }
  { j:getNumRows: | :who :possibly who mind j:items .:need count }
  { j:paintListBoxItem:
    row count, g j:Graphics, + width, + height, selected call [.0 .1]
  | :who
    :use who mind j:settings;
    ( :if selected = 1; g j:setColour (colour 1) j:fillAll ) and:
    :try
    (row + 1) call (who mind j:items) .:need call
    { *;text
    | g
      j:setColour (colour 0)
      j:drawText (text, 2, 0, width - 2, height, justification, 1)
    }
    { *;icon + ' .text
    | :try icon call (icons) .:need call
      { icon j:Image
      | :ok
        g
        j:drawImageWithin (icon, 2, 2, 16, 16, rectanglePlacement, 0)
        j:setColour (colour 0)
        j:drawText (text, 20, 0, width - 20, height, justification, 1)
      }
      { icon 1 j:Image, icon 2 j:Image
      | :ok
        g
        j:drawImageWithin (icon 1, 2, 2, 16, 16, rectanglePlacement, 0)
        j:drawImageWithin (icon 2, 20, 2, 16, 16, rectanglePlacement, 0)
        j:setColour (colour 0)
        j:drawText (text, 38, 0, width - 38, height, justification, 1)
      }
    }
  }
  { j:selectedRowsChanged: row count
  | :who ' selected (. row + 1) .:try
  }
  { j:keyPressed: keypress
  | :who :try keypress j:getKeyCode call
    { 13
    | who activated (. who j:getLastRowSelected .:need + 1) .:need
      and: :ok 1
    }
    { 27 | who escape .:need and: :ok 1 }
  }
  { j:listBoxItemDoubleClicked: n count, ?
  | :who ' activated (. n + 1) .:need and: :ok 1
  }
  { focusing: focusing call [.0 .1]
  | :who ' j:setWantsKeyboardFocus (focusing) .:ok
  }
}
><:[module:. platform juce parent menu .timestamp 2011-07-21T00:25:22.988+02 .language juce]><;
{ parent:. ' j:DocumentWindow j:MenuBarModel; menu:. & ' .action
| ;standard @@ [pils standard menu] menu (.window parent) or ();
  parent j:setMenuBar (parent) and:
  ;menu ' &
  ( standard call {:where? .ruleset :ruleset try|:try ' every [call: match]}
    or:
  )
  ;
  :ok
  parent mind j:action := [ok] +++ [call: action] -> standard +++ action;
  parent mind j:menu-action :=
    menu -> [ok] +++ [call: action] -> standard +++ action
  ;
  ;tree @ tree (.menu);
  parent mind j:menu-names :=
    tree every {submenu: .name; ?|:ok say (name)}
    first (j:StringArray ()) fold {list := item|:ok list j:add (item)}
  ;
  parent mind j:menus :=
    tree every {submenu: .name; ok|:ok}
    every
    { items
    | :who :ok
      j:PopupMenu () & items fold
      { menu := submenu: .name; items
      | :ok menu j:addSubMenu: saying (name), items call (who)
      }
      { menu := item:. .name .at
      | :ok
        menu j:addItem:
        at,
        saying (name)
        (item call {*;shortcut +$ '|:ok "">>"(" (shortcut) ")"} or ""),
        1,
        item call {*;check 1|:ok 1} or 0
      }
      { menu := item:. .name [-] .at | :ok menu j:addSeparator }
    }
  ;
  parent mind j:shortcuts :=
    menu firsts
    { *;shortcut $ '
    | ;shortcut ' lower split "+";
      shortcut <+# 1 singlewise call
      { $ ok | :ok ?:? // ' }
      { ok call [."del" delete ."ins" insert ."esc" escape] | :ok }
      { $ ok | :if ok utf-8 count = 1; :ok }
      { ok $ 1 | :ok ' upper }
      .([key down]: .ctrl-key 0 .alt-key 0 .shift-key 0 .key)
      & (shortcut <-# 1) fold
      { ok := modifier call [."ctrl" ctrl-key ."alt" alt-key ."shift" shift-key]
      | :if modifier call (ok) = 0; :ok ' merge (modifier, 1)
      }
      .:try
    }
  ;
  parent j:menuItemsChanged and:
  parent
}
><:[module:. platform juce parent menu tree .timestamp 2011-07-20T23:32:39.242+02 .language system]><;
{ tree: .menu
| :ok
  menu legs
  { at := item = *;menu path
  | :ok
    (item:. .at) & (path listwise reverse) fold
    { chain := name | :ok name:. .at; chain }
  }
  call
  { level
  | :who :ok
    level groups
    { name:. .at; value | :ok :name (submenu: .name); value }
    { name:. .at; value = item: .? .at | :ok :name (item: .name); value }
    legs {group := values = (*;at) 1 |:ok group:. .at; values}
    order [call: at]
    every
    { group: . (item: .name) .at; (item:. .at) 1 | :ok item:. .name .at }
    { group: . (submenu: .name) .at?; level
    | :ok submenu: .name; level call (who)
    }
  }
}
><:[module:. platform juce parent offspring .timestamp 2011-07-21T01:02:33.399+02 .language juce]><;
;offspring
{ (name = ?:? // ?) * node
| :who :try (parent:. who; node) call:
  :need @@ ([platform juce parent] & name)
}
{ name = ?:? // ?
| :who :try (parent:. who; name) call:
  :need @@ ([platform juce parent] & name)
}
