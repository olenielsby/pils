><:[module:. platform juce parent codepane .timestamp 2011-09-30T14:05:39.185+02 .language juce]><;
{ .test | :ok @ [tokeniser] [syntax] }
{ parent: .; (codepane: .syntax / ' .tabs) anyway [.syntax .tabs 0]
| :ok
  ;dummy j:CodeDocument ()
  .tokeniser @ [tokeniser] (syntax) or [j:CodeTokeniser]
  ;
  parent j:new (j:CodeEditorComponent (dummy, tokeniser))
  try {x|x j:setFont (j:Font 18 .:need)}
  when
  { zoom: zoom | :who :ok who } ! TODO
  { text: $ text | :who ' j:loadContent (text) .:ok }
  { .text := $ text | :who ' j:loadContent (text) .:ok }
  { .text | :who :ok who j:getDocument j:getAllContent <-#$* ""~ }
  { .focus | :who :ok who j:grabKeyboardFocus and: who }
  { show: show call [.0 .1] | :who :ok who j:setVisible (show) }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who :possibly
    :use {$ ok +# -1 .:|:ok};
    ;standin who text;
    ;a standin +# a .:need utf-8 count
    .b standin +# b .:need utf-8 count
    ;
    who j:setHighlightedRegion (a, b) and:
    ( :if scroll-to-center = 1;
      ;line who j:getCaretPos j:getLineNumber
      .total who j:getNumLinesOnScreen
      ;
      ;ideal line - (total \ 2);
      who j:scrollToLine:
      :if ideal > 0; ideal .else 0
    )
    and:
    who
  }
  { .selection
  | :who :ok
    ;text who j:getText;
    [j:getHighlightedRegionStart j:getCaretPos] every (who)
    every {p|:ok text utf-8 +# p utf-8 count}
  }
  { .clear | :who :ok who j:setText "" and: who }
  { tip: tip | :who :ok who mind tip := tip; who }
  { (find:. .casing_sensitive .whole_words_only .direction)
    anyway [.casing_sensitive 0 .whole_words_only 0 .direction down]
  | :who :ok
    ;casing_sensitive ' call (.1 [ok] .0 {ok|:ok ' lower}) .raw who text;
    ;find ' call (casing_sensitive)
    .text raw call (casing_sensitive) !*=* (""/,  ""/, ""=, ""/)
    ;
    direction call
    ( .down
        raw utf-8 +# (who j:getCaretPos j:getPosition) utf-8 count
        repeat
        { from
        | ;hit text -# from =* find; :if hit > 0; :ok
          ;hit ' + from;
          list := (hit - (find count), hit);
          hit
        }
      .up
        raw utf-8 +# (who j:getHighlightedRegionStart) utf-8 count
        repeat
        { from
        | ;hit text +# from <=* find; :if hit > 0; :ok
          ;hit from - hit;
          list := (hit, hit + (find count));
          hit
        }
    )
    .:list
    find
    ( whole_words_only call: .0 [ok] .1
      { hit
      | hit find
        { at
        | :if
            0 < text +# at <++# 1 -* " ,.;:?!""(){|}[]"<=>
            < text -# at ++# 1 -* " ,.;:?!""(){|}[]"<=>
          ;
          :ok ()
        }
        or: :ok hit
      }
    )
    or ()
  }
  { j:codeDocumentEditorTextChanged: ? | :who ' changed .:try }
  { j:keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    who +++
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok who j:getTopLevelComponent j:closeButtonPressed and 1
    }
    { [key down]: .key [tab] .shift-key ? .ctrl-key 0 .alt-key 0
    | tabs call [0:.] .:try
    }
  }
  { j:focusGained: ? | :who ' focused 1 .:try }
  { j:focusLost: ? | :who ' focused 0 .:try }
  { focused: 1
  | :who ' j:getTopLevelComponent mind focused := who
  }
}
