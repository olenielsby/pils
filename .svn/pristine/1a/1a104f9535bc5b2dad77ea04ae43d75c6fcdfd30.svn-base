| :possibly j:URL (url) .:need
  when
  { .get
  | :who
    ;buffer j:MemoryBlock ();
    :if who j:readEntireBinaryStream (buffer) > 0; :ok
    buffer j:getData
  }
}
><:[module:. platform juce entry window .timestamp 2011-09-28T16:59:07.075+02 .language juce]><;
{ window: title | :who :try who window: say (title) }
{ window: $ title
| :possibly
  plumcake j:DocumentWindow (title, #ffc846, 7)
  j:setBounds [100 200 300 400]
  j:setResizable (1, 0)
  j:setTitleBarTextCentred 0
  j:setWantsKeyboardFocus 0
  j:setVisible 1
  when
  { j:new: ok j:Component
  | :who :ok
    who j:setContentComponent (ok)
    or (who j:setContentOwned (ok, 0))
    and: ok
  }
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call:
    :need @@ ([platform juce parent] & name)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call:
    :need @@ ([platform juce parent] & name)
  }
  { title: $ title | :who ' j:setName (title) .:try }
  { icon: icon | :who ' j:setIcon (icon) .:try }
  { .inner
  | :who :ok
    { size: size | who j:setContentComponentSize (size) .:try }
    { .size
    | :try [j:getWidth j:getHeight] every:
      who j:getContentComponent .:need
    }
  }
  { .pinpoint | :who :ok who mind j:pinpoint call: @@ [pils run pinpoint] }
  { .up | :who ' try [call: j:toFront: 1] .:ok }
  { size: size | :who ' j:setSize (size) .:try }
  { position: position | :who ' j:setTopLeftPosition (position) .:try }
  { place: position | :who ' j:setTopLeftPosition (position) .:try }
  { .position | :who :possibly who j:getX .:need, who j:getY .:need }
  { .size | :who :possibly who j:getWidth .:need, who j:getHeight .:need }
  { .close
  | :who :ok who j:closeButtonPressed
  }
  { j:handleCommandMessage: 0x1001
  | :who ' j:closeButtonPressed ! NB: no :ok, or jucePILS mightl crash???
  }
  { j:closeButtonPressed: | :who :ok who j:removeFromDesktop }
  { j:getMenuBarNames: | :who :try who mind j:menu-names }
  { j:getMenuForIndex: at, ?
  | :who :try (at + 1) call: who mind j:menus .:need
  }
  { j:menuItemSelected: id, ?
  | :who :try id call: who mind j:menu-action .:need
  }
  { j:keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    { [key down]: .key .alt-key 1 .ctrl-key 0 .shift-key 0
    | ;key ' upper .:need .names who j:getMenuBarNames .:need;
      0 up (names j:size - 1)
      find { n | :if names j:item_ (n) $* key > 0; :ok n } .:need
      .(who j:getMenuBar .:need j:showMenu) .:try
    }
    { shortcut
    | :possibly
      shortcut call (who mind j:shortcuts .:need) .:need
      call (who mind j:action .:need) or (?)
    }
  }
  .(@ strap) .:need
}
><:[module:. platform juce graphics .timestamp 2011-07-21T00:05:14.412+02 .language juce]><;
;centred j:Justification 63;
{ graphics:. ' j:Graphics
| :ok
  graphics j:setImageResamplingQuality 1 and:
  { j:draw: drawing | :who drawing call (graphics) .:need and: :ok who }
  { graph: graph
  | :who graphics graph:graph (graph) .:need and: :ok who
  }
  { figure:. .thickness
  | :who
    graphics j:strokePath (figure, j:PathStrokeType (thickness, 1, 2)) .:need
    and:
    :ok who
  }
  { figure: .
  | :who graphics j:fillPath (figure) .:need and: :ok who
  }
  { stroke:. .curve
  | :who
    graphics
    j:strokePath (curve, j:PathStrokeType (stroke) .:need) .:need and:
    :ok who
  }
  { image:. ' j:Drawable .rectangle
  | :who
    image j:drawWithin (graphics & rectangle & j:RectanglePlacement 36 & 1)
    .:need
    and: :ok who
  }
  { image:. ' j:Image .rectangle x, y, width, height
  | :who
    graphics j:drawImageWithin
    (image, x, y, width, height, j:RectanglePlacement 36, 0) .:need
    and:
    :ok who
  }
  { fill: .image ' j:Drawable .rectangle
  | :who
    image j:drawWithin (graphics & rectangle & j:RectanglePlacement 164)
    .:need and: :ok who
  }
  { fill: .image ' j:Image .rectangle x, y, width, height
  | :who
    graphics j:drawImageWithin
    (image, x, y, width, height, j:RectanglePlacement 164, 0) .:need
    and:
    :ok who
  }
  { colour: colour
  | :who
    graphics j:setColour (j:Colour (colour) .:need) .:need and:
    :ok who
  }
  { fill: colour
  | :who
    graphics j:fillAll (j:Colour (colour) .:need) .:need and:
    :ok who
  }
  { brush: brush j:Brush
  | :who
    graphics j:setBrush (brush) .:need and:
    :ok who
  }
  { label:. .rectangle ' = (?, ?, ?, ?)
  | :who
    graphics j:drawFittedText (label & rectangle & centred & 1) .:need
    and:
    :ok who
  }
  { line: args | :who graphics j:drawLine (args) .:need and: :ok who }
}
><:[module:. platform juce keypress .timestamp 2011-09-06T00:11:05.084+02 .language juce]><;
{ keypress:.
| :ok
  ;m keypress j:getModifiers;
  [key down]: .key
  keypress j:getKeyCode call
  { ok | :ok }
  { 0x20 <= ok < 0x10000 | :ok ' listwise utf-8 }
  { ?
  | :try keypress j:getTextCharacter call
     {+ ok|:ok ' listwise utf-8}
     {+ ok < 27|:ok (' + 64) listwise utf-8}
  }
  { ok call
    [ .8 back .9 tab .13 return .27 escape .65582 delete .127 back
      .65569 page up
      .65570 page down
      .65571 end
      .65572 home
      .65573 left
      .65574 up
      .65575 right
      .65576 down
      .65581 insert
      .65648 f1 .65649 f2 .65650 f3 .65651 f4 .65652 f5 .65653 f6
      .65654 f7 .65655 f8 .65656 f9 .65657 f10 .65658 f11 .65659 f12
      .65660 f13 .65661 f14 .65662 f15 .65663 f16 .65664 f17 .65665 f18
      .65666 f19 .65667 f20 .65668 f21 .65669 f22 .65670 f23 .65671 f24
    ]
  | :ok
  }
  .shift-key m j:isShiftDown
  .ctrl-key m j:isCtrlDown
  .alt-key m j:isAltDown
}
><:[module:. platform juce parent ' .timestamp 2009-01-16T10:28:33.682+01 .language juce]><;
{ parent: .; [parent] | :ok parent j:getParentComponent }
><:[module:. platform juce parent .timestamp 2011-07-21T01:02:42.127+02 .language juce]><;
{ [self: parent] | :self :ok self }
{ parent:. ' j:Component
| :self [parent]; :ok
  parent +++
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call: :need name call (@@)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call: :need name call (@@)
  }
}
><:[module:. platform juce parent ask .timestamp 2011-09-29T21:59:58.580+02 .language juce]><;
{ parent: .; [ask]
| :ok
  { (text:. .label .header) anyway [.header enter text .text ""]
  | ;textfield j:TextEditor ()
      when
      { state call [.[j:escapePressed:] 0 .[j:returnPressed:] 1]
      | :who ' j:getParentComponent j:exitModalState (state) .:ok
      }
      try (call: j:setText: text)
    ;
    ;dialog
      j:DialogWindow (say (label), j:Colour [200 150 100], 1)
      try (call: j:setContentOwned: textfield, 0)
      try (call: j:centreAroundComponent: parent, 300, 60)
      when
      { j:closeButtonPressed: | :who ' j:exitModalState 0 .:ok }
      { j:focusGained: ? | :ok textfield j:grabKeyboardFocus }
    ;
    dialog j:runModalLoop
    call
    { ? | dialog j:removeFromDesktop j:visibilityChanged }
    { 1
    | ;text textfield j:getText call {+$ ok|:ok} .:need;
      dialog j:removeFromDesktop j:visibilityChanged and:
      :ok text
    }
    .:try
  }
  { (open: .filename .header .type .filter .path)
    anyway [.type? .filter? .filename "" .header open .path ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser j:FileChooser(say (header), j:File(path));
    :if chooser j:browseForFileToOpen = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (save: .filename .header .type .filter)
    anyway [.type? .filter? .filename ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser j:FileChooser(say (header), j:File(filename));
    :if chooser j:browseForFileToSave 1 = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (folder: .header .folder) anyway [.folder ""]
  | ;chooser j:FileChooser(say (header), j:File(folder));
    :if chooser j:browseForDirectory = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename try {ok <-* "/"|:ok ' "/"}
  }
  { (ok:. .header) anyway [.header confirm]
  | :ok j:AlertWindow j:showOkCancelBox (1, say (header), say (ok))
    or:
    j:AlertWindow j:showOkCancelBox
    ( 1,
      say (header),
      say (ok),
      "",
      "",
      [j:Component],
      [j:ModalComponentManager.Callback]
    )
  }
}
><:[module:. platform juce parent asking .timestamp 2011-09-28T16:53:46.265+02 .language juce]><;
{ parent: .; [asking]
| :ok
  { (text:. .label .header; done) anyway [.header enter text .text ""]
  | ;textfield j:TextEditor ()
      when
      { state call [.[j:escapePressed:] 0 .[j:returnPressed:] 1]
      | :who ' j:getParentComponent j:exitModalState (state) .:ok
      }
      try (call: j:setText: text)
    ;
    ;dialog
      j:DialogWindow (say (label), j:Colour [200 150 100], 1)
      try (call: j:setContentOwned: textfield, 0)
      try (call: j:centreAroundComponent: parent, 300, 60)
      when
      { j:closeButtonPressed: | :who ' j:exitModalState 0 .:ok }
      { j:focusGained: ? | :ok textfield j:grabKeyboardFocus }
    ;
    dialog j:runModalLoop
    call
    { ? | dialog j:removeFromDesktop j:visibilityChanged }
    { 1
    | ;text textfield j:getText call {+$ ok|:ok} .:need;
      dialog j:removeFromDesktop j:visibilityChanged and:
      :ok text try (done)
    }
    .:try
  }
  { (open: .filename .header .type .filter .path)
    anyway [.type? .filter? .filename "" .header open .path ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser j:FileChooser(say (header), j:File(path));
    :if chooser j:browseForFileToOpen = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (save: .filename .header .type .filter)
    anyway [.type? .filter? .filename ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser j:FileChooser(say (header), j:File(filename));
    :if chooser j:browseForFileToSave 1 = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (folder: .header .folder) anyway [.folder ""]
  | ;chooser j:FileChooser(say (header), j:File(folder));
    :if chooser j:browseForDirectory = 1;
    ;filename chooser j:getResult j:getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename try {ok <-* "/"|:ok ' "/"}
  }
  { (ok:. .header) anyway [.header confirm]
  | :ok j:AlertWindow j:showOkCancelBox (1, say (header), say (ok))
    or:
    j:AlertWindow j:showOkCancelBox
    ( 1,
      say (header),
      say (ok),
      "",
      "",
      [j:Component],
      [j:ModalComponentManager.Callback]
    )
  }
}
><:[module:. platform juce parent at .timestamp 2011-07-20T23:30:19.277+02 .language system]><;
{ at:. .pane
| :ok
  { menu = menu: .? .action?
  | :try @ menu:. .pane .at
  }
}
><:[module:. platform juce parent at menu .timestamp 2011-07-20T23:30:04.317+02 .language juce]><;
{ menu: .pane .at .menu menu:. & ' .action
| :ok
  @ [menu] tree (.menu)
  first (j:PopupMenu ()) fold
  { menu := submenu: .name; items
  | :who :ok
    menu j:addSubMenu:
    saying (name),
    items first (j:PopupMenu()) fold (who)
  }
  { menu := item:. .name .at
  | :ok
    menu j:addItem:
    at,
    saying (name),
   1,
   item call {*;check 1|:ok 1} or 0
  }
  { menu := item:. .name [-] .at | :ok menu j:addSeparator }
  j:show
  try: menu -> [ok] +++ [call: action] -> action
}
><:[module:. platform juce parent button .timestamp 2011-07-21T00:12:18.933+02 .language juce]><;
{ parent: .; button: $ label
| :ok
  parent j:new (j:TextButton (label))
  when {j:clicked:|:who ' clicked .:try}
}
><:[module:. platform juce parent canvas .timestamp 2011-07-21T00:19:29.164+02 .language juce]><;
{ parent: .; [canvas]
| :ok
  parent j:new (j:Component ())
  j:setWantsKeyboardFocus 1
