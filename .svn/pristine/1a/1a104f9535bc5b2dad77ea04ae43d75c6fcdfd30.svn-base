><:[module:. platform juce entry graph .timestamp 2011-07-21T00:24:40.399+02 .language juce]><;
;j:Convert;
{ graph: .image ' j:Drawable
| :try image call
  { drawable
  | :who
    ;drawable ' .(j:Convert j:drawableComposite) .:need;
    :ok drawable j:getNumDrawables - 1 .(0 up) every
    { n
    | :ok drawable j:getDrawable (n) call (who)
      try
      { d
      | :possibly
        graph:transform:. drawable j:getDrawableTransform (n) .:need; d
      }
    }
    splice singlewise
  }
  { drawable
  | :who
    ;drawable ' .(j:Convert j:drawablePath) .:need;
    :ok
    ( { path
      | :possibly
        graph:ink:. brush (. drawable j:getCurrentBrush .:need);
        path **=** {graph:curve: curve|:ok graph:shape: curve}
      },
      { path
      | :possibly
        graph:ink:. brush (. drawable j:getOutlineBrush .:need);
        :call stroke:. drawable j:getOutlineStroke; path
      },
    )
    each (call: :call path:. drawable j:getPath)
    splice singlewise
  }
  try {+& ok|:ok ' .(graph:at:. 0, 0;)}
  call {ok graph:graph|:ok}
}
===
{ path:.
| :ok
  path j:toString *=* ("a ", "", "z ", "z"~, " m", ""~"m") split ""~
  every
  { segment
  | :ok segment split " " first ()
    fold
    { a := b | oops }
    { =' := $ ok|:ok list :=; ok }
    { ok := n +* "-0123456789"|:ok ' &: {} read: n }
    { () := "m" | :ok [m] }
    .(list :=)
    .:list
    every
    {a|oops}
    {|:ok []}
    {""|:ok []}
    {"z"|:ok [z]}
    {[m], a, b|:ok (a, b),}
    {ok = "l" 1|:ok ' -# 1 split 2 call {ok = (? & 2) 0|:ok}}
    {ok = "c" 1|:ok ' -# 1 split 6 call {ok = (? & 6) 0|:ok}}
    splice
    call
    { ok | :ok graph:curve: ok }
    { ok = (x, y) 1 = ((x) -1 = (y) 0) 0 | :ok graph:shape: ok }
    { ok = [z] 0 | :ok graph:shape: ok <-# 1 }
  }
  each {ok = ;: +&?|:ok} singlewise
  try
  { +& segments
  | :possibly
    graph:shape:
    segments every {graph:shape: ok|:ok ' & (,)} .:need
    splice <-# 1
  }
}
{ stroke:.; path
| :ok
  ;thickness stroke j:getStrokeThickness;
  :if thickness <> 0;
  [j:getJointStyle j:getEndStyle] every (stroke)
  call:
  .[0 0] (graph:stroke:. thickness; path)
  .[0 1] (graph:stroke: .graph:sharp thickness; path)
  .[0 2] (graph:stroke: .graph:round thickness; path)
  .[1 0] (graph:round: .graph:stroke thickness; path)
  .[1 1] (graph:round: .graph:sharp thickness; path)
  .[1 2] (graph:round:. thickness; path)
  .[2 0] (graph:sharp: .graph:stroke thickness; path)
  .[2 1] (graph:sharp:. thickness; path)
  .[2 2] (graph:sharp: .graph:round thickness; path)
}
{ brush:.|oops}
{ brush:.
| :possibly :call gradient:.
   j:Convert j:gradientBrush (brush) .:need j:getGradient
}
{ brush:.
| :possibly j:Convert j:solidColourBrush (brush) .:need j:getColour
}
{ brush:.
| :possibly :call image:.
   j:Convert j:imageBrush (brush) .:need j:getImage
}
===
{ gradient:.
| :ok
  ;stops
    0 up (gradient j:getNumColours - 1) every
    { n
    | :ok
      gradient j:getColour (n),
      gradient j:getColourPosition (n) / 0x0000ffff
    }
    call
    { (c1, 0) 1 = (c2, 1) 0 = ok | :ok }
  ;
  gradient j:isRadial call:
  .0
  ( graph:linear:.
    [j:x1 j:y1 j:x2 j:y2] every (gradient) split 2
    every
    ( :use gradient j:transform;
      { x, y
      | :ok
        x * j:mat00 + (y * j:mat01) + j:mat02,
        x * j:mat10 + (y * j:mat11) + j:mat12
      }
    )
    splice;
    stops
  )
  .1
  ( graph:circular:.
    ( [j:x1 j:y1 j:x2 j:y2] every (gradient)
      &:
      [j:mat00 j:mat01 j:mat02 j:mat10 j:mat11 j:mat12]
      every (gradient j:transform)
    );
    stops
  )
}
