| :ok
  j:Viewport ()
  j:setScrollBarsShown (directions)
  j:setInterceptsMouseClicks (1, 1)
  .(parent j:new)
  when (@ common)
  when (@ offspring)
  when
  { .inner
  | :who :ok
    { .width | :ok who j:getMaximumVisibleWidth }
    { .height | :ok who j:getMaximumVisibleHeight }
    { .size
    | :ok who j:getMaximumVisibleWidth, who j:getMaximumVisibleHeight
    }
  }
  { .scroll
  | :who :ok
    { .thickness | :ok who j:getScrollBarThickness }
  }
  { j:new: ok j:Component
  | :who :ok who j:setViewedComponent (ok) and: ok
  }
  { j:paint: graphics
  | :who ' paint (@ graphics: .) .:try
  }
}
><:[module:. platform juce parent splitter .timestamp 2011-09-29T12:59:46.693+02 .language juce]><;
{ parent: .;
  splitter: orientation call [.floor 1 .horizontal 1 .wall 0 .vertical 0]
| :ok
  ;[layout: 1]
    j:StretchableLayoutManager ()
    j:setItemLayout (0, -1, -1, -1)
  .[layout: 2]
    j:StretchableLayoutManager ()
    j:setItemLayout (0, 10, -1, -1)
    j:setItemLayout (1, 8, 8, 8)
    j:setItemLayout (2, 10, -1, -1)
  ;
  ;sash
    j:StretchableLayoutResizerBar (layout 2, 1, 1 - orientation)
    when {j:paint: g|g j:fillAll (j:Colour [255 200 70])}
  ;
  parent j:new (j:Component ())
  try
  { splitter | splitter mind j:panes := (); splitter mind j:active := layout 1 }
  j:addChildComponent (sash)
  when
  { j:resized: | :who lay-out (.splitter who) }
  { j:new: ok j:Component
  | :who :ok who j:addChildComponent (ok) and: ok
  }
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call:
    :need @@ ([platform juce parent] & name)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call:
    :need @@ ([platform juce parent] & name)
  }
  { full: full j:Component | :who :ok panes (.splitter who) := full,; who }
  { split: panes & 2
  | :who
    panes (.splitter who) :=
      panes every
      { ok j:Component
      | :self ;parent ok j:getParentComponent;
        :if parent = who; (:ok) .else :try parent call (self)
      }
      .:need
    ;
    :ok who
  }
  { .unsplit
  | :who :ok
    panes (.splitter who) := who mind j:panes ++# 1;
    who
  }
  { .size | :who :ok who j:getWidth, who j:getHeight }
  { .width | :who :ok who j:getWidth }
  { .height | :who :ok who j:getHeight }
  { j:keyPressed: keypress
  | :who :try keypress j:getKeyCode call
    { 27 | :try who escape }
  }
  ==='
  { .panes (.splitter) := panes & (count call [.1 .2])
  | :ok
    ;panes ' try {p1, p2|:ok p1, sash, p2};
    splitter mind j:panes except (panes first [ok])
    every [call: j:setVisible: 0]
    and:
    splitter mind j:panes := panes every [call: j:setVisible: 1];
    splitter mind j:active := layout (count);
    lay-out (.splitter)
  }
  ===
  { .lay-out (.splitter)
  | :ok
    splitter mind j:active j:layOutComponents:
    splitter mind j:panes, 0, 0, splitter width, splitter height, orientation, 1
  }
}
><:[module:. platform juce parent tabs .timestamp 2011-09-28T16:58:24.627+02 .language juce]><;
{ parent: .; [tabs]
| :ok
  parent j:new (j:TabbedComponent 0)
  when
  { + n
  | :who :ok

! before juce 1.52:

    { icon: + i
    | :self :ok
      ;bar who j:getTabbedButtonBar;
      0 up (bar j:getNumChildComponents - 1)
      every ({n|:ok j:getChildComponent: n} -> bar)
      find (;n ' - 1; {ok j:TabBarButton|:if ok j:getIndex = n; :ok})
      j:repaint mind j:icon := i;
      self
    }

! juce 1.52 and later:

    { icon: + i
    | :self :possibly
      who j:getTabbedButtonBar j:getTabButton (n - 1) .:need
      j:repaint mind j:icon := i;
      self
    }

    { .page
    | :possibly who j:getTabContentComponent (n - 1) .:need
      try {try|:try ' mind j:wrap}
    }
    { .close | :self who j:removeTab (n - 1) .:need and: :ok self }
    { .select | :self who j:setCurrentTabIndex (n - 1) .:need and: :ok self }
  }
  { j:new: ok j:Component
  | :who :ok who j:addChildComponent (ok) and: ok
  }
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call: :need name call (@@)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call: :need name call (@@)
  }
  { .items | :who :ok who j:getNumTabs up every (who) }
  { .reverse | :who :ok who j:getNumTabs down every (who) }
  { .clear | :who :ok who j:clearTabs }
  { .hot | :who :try (who j:getCurrentTabIndex .:need + 1) call (who) }
  { .current
  | :who :possibly who j:getCurrentContentComponent .:need
    try {try|:try ' mind j:wrap}
  }
  { icons:. .size | :who :ok who mind j:icons := icons; who }
  { .count | :who :ok who j:getNumTabs }
  { (add: .page ' j:Component .label $ ' .focus) anyway [.focus?]
  | :who :ok
    ;at who j:getNumTabs;
    who j:addTab (label, j:Colour [200 200 200], page, 1) and:
    (:if focus = 1; who j:setCurrentTabIndex: at) and:
    who
  }
  { j:currentTabChanged: ? | :who ' changed .:try }
  { j:createTabButton: name, index
  | :who :ok @ flap (.tabs who .name .index)
  }
  { j:keyPressed: keypress
  | :who :try @ keypress (.) call:
    who +++
    { [key down]: .key [f6] .shift-key .ctrl-key 0 .alt-key 0
    | :ok
      who j:setCurrentTabIndex:
      (shift-key, who j:getCurrentTabIndex, who j:getNumTabs - 1) call
      { 0, at, ? | :ok at + 1 }
      { 0, at, at | :ok 0 }
      { 1, at, ? | :ok at - 1 }
      { 1, 0, at | :ok at }
    }
  }
}
><:[module:. platform juce parent tabs flap .edit source .timestamp 2010-12-31T00:26:03.498+01 .language juce]><;
{ flap: .tabs .name .index
| :ok
  j:TabBarButton (name, tabs j:getTabbedButtonBar, index)
  or ! juce 1.52
  (
    ;bar tabs j:getTabbedButtonBar;
    j:TabBarButton (name, bar)
  )
  when
  { j:getBestTabLength: depth
  | :who :ok
    who j:getLookAndFeel
    j:getTabButtonBestWidth (index, name, depth, who)
    + 20
  }
  { j:paintButton: g, isMouseOver, isDown
  | :who :ok
    ;lookAndFeel who j:getLookAndFeel;
    g j:setOrigin (4, 4) and:
    lookAndFeel j:drawTabButton
    ( g,
      who j:getWidth - 8,
      who j:getHeight - 4,
      j:Colour [210 230 210],
      index,
      "",
      who,
      0,
      isMouseOver,
      isDown,
      who j:getToggleState
    )
    and:
    lookAndFeel j:drawTabButtonText
    ( g,
      16, 0, who j:getWidth - 20, who j:getHeight - 4,
      j:Colour [200 200 200],
      index, name, who, 0, isMouseOver, isDown, who j:getToggleState
    )
    and:
    who mind j:icon or () call (tabs mind j:icons or ()) or () try
    { icon j:Image
    | g j:drawImageWithin
      (icon, 10, 4, 16, 16, j:RectanglePlacement 64, 0)
    }
  }
}
><:[module:. platform juce parent textfield .timestamp 2011-07-21T00:11:32.206+02 .language juce]><;
{ parent: .; [textfield]
| :ok
  parent j:new (j:TextEditor ()) j:setSelectAllWhenFocused 1
  when
  { font: font | :who ' j:setFont (font) .:try }
  { text: $ text | :who ' j:setText (text) .:ok }
  { .text := $ text | :who ' j:setText (text) .:ok }
  { .text | :who ' j:getText .:ok }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who ' j:setHighlightedRegion (a, b - a) .:ok
  }
  { .selection
  | :who :ok [j:getHighlightedRegionStart j:getCaretPosition] every (who)
  }
  { .focus | :who ' j:grabKeyboardFocus .:ok }
  { .clear | :who ' j:setText "" .:ok }
  { j:textEditorTextChanged: ? | :who ' changed .:try }
  { j:keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    { key | key call (who) .:need and: :ok 1 }
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok
      who j:getTopLevelComponent j:closeButtonPressed
      and: 1
    }
  }
  { j:keyPressed: keypress
  | :who :try keypress j:getKeyCode call
    { code call [.13 return .27 escape]
    | :ok code call (who) and 1 or 0
    }
  }
}
><:[module:. platform juce parent textpane .timestamp 2011-09-30T14:06:02.127+02 .language juce]><;
{ parent: .; [textpane]
| :ok
  parent j:new (j:TextEditor ())
  j:setMultiLine 1
  j:setReturnKeyStartsNewLine 1
  try {x|x j:setFont (j:Font 18 .:need)}
  when
  { zoom: zoom | :who :ok who } ! TODO
  { text: $ text | :who :ok who j:setText (text) and: who }
  { .text := $ text | :who ' j:setText (text) .:ok }
  { text: text $ (? > 500000)
  | :who :ok who bug {} j:setText (text) and: who
  }
  { .text | :who :ok who j:getText <-#$* ""~ }
  { .focus | :who :ok who j:grabKeyboardFocus and: who }
  { show: show call [.0 .1] | :who :ok who j:setVisible (show) }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who :possibly
    :use {$ ok +# -1 .:|:ok};
    ;standin who j:getText;
    ;a standin +# a .:need
      utf-8 count
    .b standin +# b .:need
      utf-8 count
    ;
    who j:setHighlightedRegion (a, b) and:
    ( :if scroll-to-center = 1;
      who j:scrollEditorToPositionCaret
      ( who j:getWidth, who j:getHeight \ 2 )
    )
    and:
    who
  }
  { .selection
  | :who :ok
    ;text who j:getText;
    [j:getHighlightedRegionStart j:getCaretPosition] every (who)
    every {p|:ok text utf-8 +# p utf-8 count}
  }
  { .clear | :who :ok who j:setText "" and: who }
  { .wrap | :who :ok who call: @@ wrapped }
  { tip: tip | :who :ok who mind tip := tip; who }
  { (find:. .casing_sensitive .whole_words_only .direction)
    anyway [.casing_sensitive 0 .whole_words_only 0 .direction [down]]
  | :who :ok
    ;casing_sensitive ' call (.1 [ok] .0 {ok|:ok ' lower}) .raw who j:getText;
    ;find ' call (casing_sensitive)
    .text raw call (casing_sensitive) !*=* (""/,  ""/, ""=, ""/)
    ;
    direction call
    ( .down
        raw utf-8 +# (who j:getCaretPosition) utf-8 count
        repeat
        { from
        | ;hit text -# from =* find; :if hit <> 0; :ok
          ;hit ' + from;
          list := (hit - (find count), hit);
          hit
        }
      .up
        raw utf-8 +# (who j:getHighlightedRegionStart) utf-8 count
        repeat
        { from
        | ;hit text +# from <=* find; :if hit <> 0; :ok
          ;hit from - hit;
          list := (hit, hit + (find count));
          hit
        }
    )
    .:list
    find
    ( whole_words_only call: .0 [ok] .1
      { hit
      | hit find
        { at
        | :if
          0 < text +# at <++# 1 -* " ,.;:?!""(){|}[]"<=>
          < text -# at ++# 1 -* " ,.;:?!""(){|}[]"<=>
          ;
          :ok ()
        }
        or: :ok hit
      }
    )
    or ()
  }
  { j:textEditorTextChanged: ? | :who ' changed .:try }
  { j:keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    who +++
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok who j:getTopLevelComponent j:closeButtonPressed and 1
    }
  }
  { j:focusGained: ? | :who ' focused 1 .:try }
  { j:focusLost: ? | :who ' focused 0 .:try }
  { focused: 1
  | :who ' j:getTopLevelComponent mind focused := who
  }
}
><:[module:. platform juce parent tree .timestamp 2011-09-29T13:18:34.149+02 .language juce]><;
{ parent: .; (tree: .root ' call [.0 .1]) anyway [.root 1]
| :ok
  parent j:new (j:TreeView ())
  j:setColour (0x1000500, j:Colour [250 250 250])
  call
  { ok
  | :ok ' mind j:settings :=
    ( settings:
      .justification j:Justification 1
      .[colour: 0] j:Colour [0 0 0]
      .[colour: 1] j:Colour [190 180 255]
      .icons ()
      .rectanglePlacement j:RectanglePlacement 64
    )
    ;
    ok j:setRootItemVisible (root)
  }
  when
  { id j:pils.TreeViewItem
  | :self [tree]; :who [tree]; :ok id +++
    { (add: $ text .icon ' count .hot ' count) anyway [.icon 0 .hot 0]
    | :ok id j:addSubItem j:setMind (item:. () .text .icon .hot)
      call (who [tree])
    }
    { (icon:. ' count .hot ' count) anyway [.hot 0]
    | :who :ok
      id j:setMind (id j:getMind merge: ;icon .hot)
      j:treeHasChanged
      and: who
    }
    { .tree | :ok who [tree] }
    { .id | :ok id }
    { .select
    | :who :ok
      id j:setSelected [1 1]
      repeat {item|list := item; :try item j:getParentItem} .:list reverse
      every [call: j:setOpen: 1]
      and: who [tree] j:scrollToKeepItemVisible (id)
      and: who
    }
    { .children
    | :ok
      0 up (id j:getNumSubItems - 1) every
      { n | :ok id j:getSubItem (n) call (who [tree]) }
    }
    { children: children call [.0 .1]
    | :who :ok
      id j:setMind (id j:getMind merge: ;children) j:treeHasChanged
      and: who
    }
    { .visible
    | :ok
      1 ! TODO
    }
    { mind: item
    | :who :ok id j:setMind (id j:getMind merge (item: .)) and: who
    }
    { .mind | :try id j:getMind .:need item }
  }
  { (add: $ text .icon ' count .hot ' count) anyway [.icon 0 .hot 0]
  | :who :ok
    who j:newRootItem j:setMind (item: . () .text .icon .hot) call (who)
  }
  { (icons:. .size) anyway [.size 16]
  | :who ' mind j:settings :=
    ( who mind j:settings merge:
      ;icons ' every {ok j:Image|:ok} .:need .size
    );
    :ok who
  }
  { (icons: .pairs .size) anyway [.size 16]
  | :who ' mind j:settings :=
    ( who mind j:settings merge:
      ;icons pairs every {ok = (? j:Image, ? j:Image)|:ok} .:need .size
    );
    :ok who
  }
  { .clear | :who :ok who j:clear and: who }
  { .root | :who :try who j:getRootItem .:need call (who) }
  { .hot
  | :who :try
    0 up (who j:getNumSelectedItems - 1)
    find ({n|:ok j:getSelectedItem: n} -> who -> who)
  }
  { .focus | :who ' j:grabKeyboardFocus .:ok }
  { show: show call [.0 .1] | :who ' j:setVisible (show) .:ok }
  { tip: tip | :who :ok who mind tip := tip; who }
  { j:keyPressed: keypress
  | :who :try keypress j:getKeyCode call
    { 13 | :try who activated:. who j:getSelectedItem 0 .:need call (who) }
    { 27 | :try who escape }
  }
  { j:paintItem: item j:TreeViewItem, g, width, height
  | :who :ok
    :use who mind j:settings;
    ( :if item j:isSelected = 1;
      g j:setColour (colour 1) j:fillAll
    )
    and:
    item j:getMind try
    { *;text
    | g
      j:setColour (colour (2 = item j:isSelected <> 0))
      j:drawText (text, 2, 0, width - 2, height, justification, 1)
    }
    { mind = *;icon + ' .text
    | :try icon call (icons) .:need call
      { icon j:Image
      | :ok
        g
        j:setColour (colour (:if 2 = item j:isSelected; 1 .else 0))
        j:drawImageWithin (icon, 2, 2, 16, 16, rectanglePlacement, 0)
        j:drawText (text, 20, 0, width - 20, height, justification, 1)
      }
      { icon 1 j:Image, icon 2 j:Image
      | :ok
        g
        j:setColour (colour (2 = item j:isSelected <> 0))
        j:drawImageWithin (icon 1, 2, 2, 16, 16, rectanglePlacement, 0)
        j:drawImageWithin (icon 2, 20, 2, 16, 16, rectanglePlacement, 0)
        j:drawText (text, 38, 0, width - 38, height, justification, 1)
      }
    }
  }
  { j:itemDoubleClicked: item j:TreeViewItem, e
  | :who ' activated (. item try: who) .:try
  }
  { j:itemSelectionChanged: item j:TreeViewItem, 1
  | :who ' selected (. item try: who) .:try
  }
  { j:mightContainSubItems: item
  | :try item j:getMind .:need children
  }
  { j:itemOpennessChanged: item, 1
  | :who ' expand (. item call (who)) .:try
  }
}
