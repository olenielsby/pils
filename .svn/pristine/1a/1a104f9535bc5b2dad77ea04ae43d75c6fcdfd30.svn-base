{ parent: .; [column]
| :ok
  ;layout j:StretchableLayoutManager ();
  parent j:new (j:Component ())
  when (@ offspring)
  when
  { j:resized:
  | :who :ok
    ;children
      0 up (who j:getNumChildComponents - 1)
      every {n|:ok who j:getChildComponent: n}
      every {ok|:ok ' mind j:wrap or: ok}
    ;
    layout j:clearAllItems() and:
    children every
    { ? | :ok 8, -1, -1 }
    { child | ;height child mind height .:need; :ok height, height, height }
    legs { n := hint | layout j:setItemLayout: (n - 1) & hint }
    and:
    layout j:layOutComponents:
    children, 0, 0, who j:getWidth, who j:getHeight, 1, 1
  }
  { j:new: ok j:Component
  | :who :ok who j:addAndMakeVisible (ok) j:resized and: ok
  }
}
><:[module:. platform juce parent common .timestamp 2011-07-22T00:54:02.759+02 .language juce]><;
;common
{ at: . | :who :ok @ at:. .pane who }
{ .refresh | :who :ok who j:repaint }
{ .focus | :who ' j:grabKeyboardFocus .:ok }
{ .focused | :who ' j:hasKeyboardFocus 0 .:ok }
{ .size | :who :ok who j:getWidth, who j:getHeight }
{ size: size | :who ' j:setSize (size) .:try }
{ place: place | :who ' j:setTopLeftPosition (place) .:try }
{ (drag: .description .image) anyway [.image j:Image]
| :who
  ;description ' .({} write:);
  j:DragAndDropContainer j:findParentDragContainerFor (who) .:need
  j:startDragging (description, who, image, 1) .:need
  and: :ok who
}
{ (drag: .description .image) anyway [.image j:Image]
| :who
  ;description ' call {ok|:ok ' .({} write)} {$ ok|:ok};
  j:DragAndDropContainer j:findParentDragContainerFor (who) .:need
  j:startDragging (description, who, image, 1) .:need
  and: :ok who
}
{ j:mouseDown: e
| :who
  ;at [j:x j:y] every (e);
  [j:isLeftButtonDown j:isRightButtonDown] every (e j:mods) call
  { 1, 0 | :ok [mouse left down]: at }
  { 0, 1 | :ok [mouse right down]: at }
  { 1, 1 | :ok [mouse both down]: at }
  call (who) .:try
}
{ j:mouseDrag: e
| :who
  ;at [j:x j:y] every (e);
  [j:isLeftButtonDown j:isRightButtonDown] every (e j:mods) call
  { 1, 0 | :ok [mouse left drag]: at }
  { 0, 1 | :ok [mouse right drag]: at }
  { 1, 1 | :ok [mouse both drag]: at }
  call (who) .:try
}
{ j:mouseUp: e | :who ' . ([mouse up]: [j:x j:y] every (e)) .:try }
{ j:mouseMove: e | :who ' . ([mouse move]: [j:x j:y] every (e)) .:try }
{ j:resized: | :who ' sized .:try }
{ j:keyPressed: keypress
| :who :try @ keypress (.) .:need call:
  { key | key call (who) .:need and: :ok 1 }
  { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
  | :ok
    who j:getTopLevelComponent j:closeButtonPressed
    and: 1
  }
}
{ j:isInterestedInDragSource: description, component
| :who ' dragging (. {} read (description) .:need .from component) .:try
}
{ j:itemDropped: description, component, x, y
| :who
  ' dropped (. {} read (description) .:need .from component .at x, y) .:try
}
{ j:focusGained: ? | :who ' focused 1 .:try }
{ j:focusLost: ? | :who ' focused 0 .:try }
{ j:keyPressed: keypress | :who ' .(@ keypress (.) call) .:try }
{ focused: 1 | :who ' j:getTopLevelComponent mind focused := who }
><:[module:. platform juce parent find .timestamp 2011-07-21T01:05:28.835+02 .language system]><;
{ parent: .; find: .host
| :ok
  ;channel (channel: search: parent repeat {::using?; ok|:ok});
  channel close anyway:
  ;dialog platform window (say [find]);
  ;contents dialog column;
  ;row contents row when {.escape|dialog close};
  row mind height := 25;
  ;[title: find] row label (say [find]);
  title [find] mind width := 40;
  ;find
    row textfield text (host find or "")
    when
    { .return | :try host command: . [find_next] .panel dialog }
    { .changed | :who host find := who text }
    { .escape | :ok dialog close }
  ;
  and:
  ;find_next
    row button (say [find next])
    when
    { .clicked
    | :try host command: . [find_next] .panel dialog
    }
  ;
  find_next mind width := 100;
  ;row contents row;
  ;column row column;
  ;whole_words_only column checkbox (say [whole words only])
    checked (host whole_words_only)
    when {.changed|:who host whole_words_only := who checked}
  ;
  ;casing_sensitive column checkbox (say [casing sensitive])
    checked (host casing_sensitive)
    when {.changed|:who host casing_sensitive := who checked}
  ;
  [whole_words_only casing_sensitive] every
  { call
  | :ok
    ;checkbox (:call);
    checkbox checked (call call (host) or 0)
  }
  and:
  ;row ' groupbox (say [direction]) row;
  ;[direction: up]
    row checkbox (say [up])
    when
    { .changed
    | :who ' mind direction [down] checked (who checked = 0) and:
      host direction := who checked call [.1 up .0 .down]
    }
  ;
  ;[direction: down]
    row checkbox (say [down])
    when
    { .changed
    | :who direction [up] checked (who checked = 0) and:
      host direction := who checked call [.1 down .0 .up]
    }
  ;
  direction [up] mind direction [down] := direction [down];
  [up down, down up] every
  { direction, other
  | :ok
    direction (direction) checked (direction = host direction or 0)
  }
  and:
  find focus and:
  dialog inner size (300, 75)
}
