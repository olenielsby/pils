><:[module:. platform juce entry image .timestamp 2011-07-20T23:53:59.457+02 .language juce]><;
;wrap @@ wrapper image;
{ image: .filename
| :possibly
  j:ImageFileFormat j:loadFrom (j:File (filename)) .:need
  when (wrap)
}
{ image: .filename ' <$* ".svg"
| j:Drawable j:createFromImageFile (j:File (filename)) .:try
}
{ image: .png
| :possibly
  j:PNGImageFormat () j:decodeImage (j:MemoryInputStream (png, 1))
  .:need
  when (wrap)
}
{ image: .jpeg
| :possibly
  j:JPEGImageFormat () j:decodeImage (j:MemoryInputStream (jpeg, 1))
  .:need
  when (wrap)
}
{ image: .svg
| :possibly
  j:Drawable j:createFromImageData (svg) .:need
  when (wrap)
}
{ image: .size width, height
| :possibly j:Image (1, width, height, 1) .:need when (wrap)
}
