{ parent: .; [row]
| :ok
  ;layout j:StretchableLayoutManager ();
  parent j:new (j:Component ())
  when (@ common)
  when (@ offspring)
  when
  { j:resized:
  | :who :ok
    ;children
      0 up (who j:getNumChildComponents - 1)
      every {n|:ok who j:getChildComponent: n}
    ;
    layout j:clearAllItems() and:
    children every
    { ? | :ok 8, -1, -1 }
    { child | ;width child mind width .:need; :ok width, width, width }
    legs { n := hint | layout j:setItemLayout: (n - 1) & hint }
    and:
    layout j:layOutComponents:
    children, 0, 0, who j:getWidth, who j:getHeight, 0, 1
  }
  { j:new: ok j:Component
  | :who :ok who j:addAndMakeVisible (ok) j:resized and: ok
  }
}
