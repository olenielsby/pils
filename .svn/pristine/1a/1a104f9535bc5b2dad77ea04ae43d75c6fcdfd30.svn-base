><:[module:. platform juce entry system .timestamp 2008-08-04T12:55:32.254+02 .language system]><;
{ .system | :try @@ [platform juce system [?:?|pils-configuration:system]] }><:[module:. platform juce entry ticking .timestamp 2011-07-21T00:20:40.458+02 .language juce]><;
{ (ticking: .milliseconds) anyway [.milliseconds 1000]
| :ok
  j:Timer ()
  when {j:timerCallback:|:who ' tick .:try}
  j:startTimer (milliseconds)
}
{ (ticking: time)
| :try
  j:Timer ()
  when {j:timerCallback:|:who ' tick .:try}
  j:startTimer (time \ 0.001s .:need)
}
><:[module:. platform juce entry url .timestamp 2011-09-28T16:59:54.408+02 .language juce]><;
