><:[module:. platform juce strap .timestamp 2009-01-15T02:44:21.050+01 .language juce]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ strap: window
| :where :what :ok
  straps every (window) and:
  window mind j:pinpoint := (pinpoint: .what .module where this module);
  window
}
><:[module:. platform juce window .timestamp 2011-07-21T01:01:26.842+02 .language juce]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ window: .
| :where :what :ok
  straps each (window) and:
  ( @ parent:. window +++
    { j:new: ok j:Component
    | :ok window j:setContentComponent (ok) and: ok
    }
  )
  +++
  { icon: ' | :who window j:setIcon (icon) .:need and: :ok who }
  { .status
  | :who :ok
    { text: $ text
    | :ok
      ;status-bar
        window mind j:status-bar or
        ( ;status-bar j:Label ("snot", "splat");
          window mind j:status-bar := status-bar;
          window j:setBottomComponentHeight
          j:setBottomComponent (status-bar) and:
          status-bar
        )
      ;
      status-bar j:setText (text, 0) and:
      who
    }
  }
  { .status-bar | :who :ok who status }
  { .inner
  | :who :ok
    { size: '
    | window j:setContentComponentSize (size) .:need and: :ok who
    }
    { .size
    | :try [j:getWidth j:getHeight] every:
      window j:getContentComponent .:need
    }
  }
  { wenn: ' | :who :ok @ wenn: .; who }
  { .pinpoint
  | :ok @@ [pils run pinpoint] pinpoint: .what .module where this module
  }
  { .up | :who :ok window j:toFront 1 anyway: who }
  { size: ' | :who window j:setSize (size) .:need and: :ok who }
  { position: '
  | :who window j:setTopLeftPosition (position) .:need and: :ok who
  }
  { .close | :who :ok window j:removeFromDesktop and: who }
}
