| ;folder ' call {? folder: ok|:ok} {$ ok|folder (ok) .:need and: :ok} .:need;
  :ok
  j:FileBrowserComponent
  (2, j:File (folder), [j:FileFilter], [j:FilePreviewComponent], 1, 1)
  .(parent j:new)
  when (@ common)
  when
  { try | :who :try ' call: who: .; who mind j:when or () }
  { when: more
  | :who :ok who mind j:when := who mind j:when or () +++ more; who
  }
  { tip: tip | :who :ok who mind tip := tip; who }
  { focusing: focusing call [.0 .1]
  | :who ' j:setWantsKeyboardFocus (focusing) .:ok
  }
  { .hot
  | :who
    :if who j:currentFileIsValid = 1; :ok
    who j:getCurrentFile j:getFullPathName *=* ("\", "/") "/" .(folder)
  }
  { j:paint: graphics | graphics j:fillAll: j:Colour [255, 255, 255] }
  { j:selectionChanged: | :who ' changed .:try }
  try
  { folder
  | ;listener
      j:FileBrowserListener ()
      when {j:selectionChanged:|:try folder changed}
    ;
    folder mind j:listener := listener;
    folder j:addListener (listener)
  }
