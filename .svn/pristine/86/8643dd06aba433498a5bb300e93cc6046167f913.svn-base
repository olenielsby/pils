[
!  identifier boolean-literal "true false",
  identifier operator
  "and and_eq bitand bitor compl not not_eq or or_eq xor xor_eq",
!  ? operator "! % & * + , - . / : < = > ? ^ | ~",
!  ? separator "( ) [ ] { } ;",
