{ preprocess: .text .settings .filename
| :ok
  @@ macro
  { macro: .
  | :ok
    @@ tokenize (.text .filename)
    first [normal] fold
    { [finish: normal] | :who :ok who }
    { finish: macro: .parameters? .replacement? .missing? .item .at?; state
    | :who :ok who finish (state) pass (item) 
    }
    { pass: item
    | :who :ok list [outer] := item; who }
    { bypass: item
    | :who :ok list [outer] := item; who }
    { pass: :;at .item [blocked-identifier], name
    | :who :ok list [outer] := (;at .item [identifier], name); who }
    { pass: :;at? .item [space], ? | :who :ok who }
    { state := item | :who :ok who pass (item) and: state }
    { state := item = :;at? .item [identifier], name
    | :who :try macro use: .item .who; state
    }
    { state := directive: . "pragma"; ++& tail
    | ;tail . each {:;at? .item ok|:ok} {:;at? .item [space], ?|?};
      tail . 1
      call {[identifier "kvernbitr"]|:ok ()} .:need
      and:
      settings pragma
      ( . tail . 2 call {?, ok|:ok} .:need;
        tail -# 2 every {[string-literal], ok|:ok} .:need
      )
      anyway:
      :ok state
    }
    { state := directive: . "include"; tail = (:;at .item?) 1
    | :who
      :if
        ( ;who . +++ {pass: item|:who :ok list := item; who};
          who finish: tail first [normal] fold (who)
        )
        .:list
        every {:;at? .item ?, ok|:ok} {:;at? .item [space], ?|:ok " "}
        splice ""
        split [fn .fn """" [*: [-: """"] ?,] """", "<" [*: [-: ">"] ?,] ">"]
        => (([fn], include-filename),)
        ,
        settings include-filename (..at) => (:;text .filename)
      ;
      :ok
      who include: .text .filename .state
    }
    { state := directive: . "include";
      (:;at .item [include-filename], include-filename),
    | :who
      :if settings include-filename (..at) => (;text .filename); :ok
      who include: .text .filename .state
    }
    { include: .text .filename .state
    | :who :ok
      ! list [outer] := (->: filename);
      @@ tokenize (.text .filename) first (state) fold (who)
    }
    { state := directive: . "undef"; (:;at? .item [identifier], name),
    | :ok macro undefine (.name) and: state
    }
    { state := directive: . "define"; items | :try macro define: .items; state }
    { state := directive: . flag call [."ifdef" 1 ."ifndef" 0];
      (:;at? .item [identifier], name),
    | :ok :if flag = macro defined (.name); (if-true: state)
      .else if-false: state
    }
    { (ok = if-false: ?) := ? | :ok }
    { (ok = if-skip: ?) := ? | :ok }
    { state := directive: . "if"; condition
    | :who :ok
      (@@ condition: ..who .macro; state)
      call
      { x | xxx }
      { % ? | :ok if-true: state }
      { 0 | :ok if-false: state }
    }
    { (if-true: ok) := directive: . "elif"; ? | :ok ..(if-skip:) }
    { (if-true: ok) := directive: . "else"; | :ok ..(if-skip:) }
    { (if-false: ok) := directive: . "else"; | :ok ..(if-true:) }
    { (if-false: ok) := directive: . "elif"; tail
    | :who :ok (who) (ok) := directive: . "if"; tail
    }
    { (ok = if-false: ?) := directive: .? $* "if"; ? | :ok ..(if-skip:) }
    { (ok = if-skip: ?) := directive: .? $* "if"; ? | :ok ..(if-skip:) }
    { (?: ok) := directive: . "endif"; | :ok }
    { ok := :;at? .item [directive-start], ? | :ok ..(directive-start:) }
    { (directive-start: ok) := :;at? .item [directive-keyword], directive
    | :ok ..(directive: ..tail ();) }
    { (directive-start: ok) := :;at? .item [include-keyword], ?
    | :ok ..(directive: . "include" .tail ();) }
    { (directive: ..tail; state) := item | :ok directive: ..tail . & (item,); state }
    { (ok = directive: . ? .tail (); ?) := :;at? .item [space], ? | :ok }
    { (directive: ..tail; state) := :;at? .item [directive-end], ?
    | :who :ok (who) (state) := directive: .;
      tail <-#: :if tail <+# 1 => ((:;at? .item [space], ?),); 1 .else 0
    }
    { (macro: .parameters .item .at .missing .replacement; state) :=
    | :who :ok who pass (item) and: who . state :=
    }
    { (ok = macro: .parameters? .item? .at? .missing? .replacement?; ?) :=
