><:[module: . parse language C++ tokenize preprocess macro .timestamp 2007-11-04T12:22:29.167+01]><;
{ macro: run
| :try
  :mind
  :need run macro: .
  { define: .items . [&]; state
  | :ok
    items first [define] fold
    { x := y | z }
    { (want: .; ok) := :;at? .item want | :ok }
    { .define := :;at? .item [space], ? | :ok [define] }
    { .define := :;at .item [identifier], name | :ok define: .name .at }
    { (define: .name .at) := item
    | :self :ok self replacement (.() .parameters (); define) := item
    }
    { (define = define: .name .at) := :;at? .item [space], ?
    | :ok replacement: . () .parameters (); define
    }
    { (define = define: .name .at) := :;at? .item [? "("]
    | :ok parameters: . () .name .at
    }
    { (replacement: ..parameters; define) := item
    | :ok replacement: .. & (item,) .parameters; define
    }
    { (replacement = replacement: .; define) :=
      space = :;at? .item [space], ?
    | :ok space: ..replacement
    }
    { (parameters: ..name .at) := :;at? .item [identifier], parameter
    | :ok
      more: parameters: .. & (parameter,) .name .at
    }
    { (parameters: ..name .at) := :;at? .item [ellipsis "..."]
    | :ok
      ;parameters . & "...";
      want: . [? ")"];
      replacement: . () .parameters; define: .name .at .parameters
    }
    { (parameters: . () .name .at) := :;at? .item [? ")"]
    | :ok
      replacement: . () .parameters (); define: .name .at .parameters ()
    }
    { (more: parameters: ..name .at) := :;at? .item [? ")"]
    | :ok
      replacement: . () .parameters; define: .name .at .parameters
    }
    { (more: ok) := :;at? .item [? ","] | :ok }
    { (ok = more: ?) := :;at? .item [space], ? | :ok }
    { (ok = parameters: .? .name? .at ?) := :;at? .item [space], ? | :ok }
    { (replacement: ..parameters . [+&]; define) :=
      :;at? .item [identifier], parameter
    | :if parameters =* (parameter,) +> number; :ok
      replacement: .. & (parameter: ..number) .parameters; define
    }
    { (replacement: ..parameters . & number <$* ["...",]; define) :=
      :;at? .item [identifier], "__VA_ARGS__"
    | :ok
      replacement: .
      . call
      { +& try
      | :self :try . <+# 1 1 item call:
        ;try . <-# 1;
        { [space], ? | :try . call (self) }
        { [?, ","]
        | :ok
          try .
          ( replacement -# (try count) every
            { item | :ok suppress-va_args: item }
          )
        }
      }
      or (replacement)
      ( (suppress-va_args: parameter:  . "__VA_ARGS__" .number), )
      .parameters;
      define
    }
    { (ok = replacement: . () .parameters?; ?) := :;at? .item [space], ? | :ok }
    { (replacement: ..parameters; define) :=
      :;at? .item [preprocessor-concat], ?
    | :ok
      preprocessor-concat: define .parameters .replacement .
      try { ok | :if ok <+# 1 => ((:;at? .item [space], ?),); :ok . <-# 1 }
      try
      { ok
      | :if ok <+# 1 => ((parameter: ..number),);
        :ok . <-# 1 & (escaped-parameter: .parameter .number)
      }
    }
    { (ok = preprocessor-concat: .replacement? .parameters?; ?) :=
      :;at? .item [space], ?
    | :ok
    }
    { (preprocessor-concat: .replacement .parameters; define) := item
    | :ok
       replacement: .. & ([preprocessor-concat], item) .parameters;
       define
    }
    { (preprocessor-concat: .replacement .parameters; define) :=
      item = :;at? .item [identifier], name
    | :if parameters =* (name,) +> number; :ok
       replacement: .. &
       ( [preprocessor-concat],
         escaped-parameter: .parameter name .number )
       .parameters;
       define
    }
    { ( preprocessor-concat:
        .replacement
        .parameters . & number <$* ["...",];
        define) :=
      item = :;at? .item [identifier], "__VA_ARGS__"
    | :ok
       replacement: .. &
       ( [preprocessor-concat],
         escaped-parameter: .parameter "__VA_ARGS__" .number )
       .parameters;
       define
    }
    { (state = replacement: .? .parameters?; ?) :=
      :;at? .item [preprocessor-stringize], ?
    | :ok preprocessor-stringize: state
    }
    { (ok = preprocessor-stringize: ?) := :;at? .item [space], ? | :ok }
    { (preprocessor-stringize: replacement: ..parameters; define) :=
      :;at? .item [identifier], parameter
    | :if parameters =* (parameter,) +> number;
      :ok
      replacement: .. & (preprocessor-stringize: .parameter .number)
      .parameters;
      define
    }
    { (preprocessor-stringize:
      replacement: ..parameters ? & number <$* ["...",]; define) :=
      :;at? .item [identifier], "__VA_ARGS__"
    | :ok
      replacement: .. & ((preprocessor-stringize: .parameter .number),)
      .parameters;
      define
    }
    call
    { x | y }
    { replacement: ..parameters; define: .name .parameters .at
    | :ok
      mind . name := function: .replacement .name .at .parameters
    }
    { replacement: ..parameters (); define: .name .at
    | :ok
      mind . name := object: .replacement .name .at
    }
    { define: .name .parameters .at
    | :ok
      mind . name := function: .replacement () .name .at .parameters
    }
    { define: .name .at
    | :ok
      mind . name := object: .replacement () .name .at
    }
    and: state
  }
  { use: .item . = (:;at? .item [identifier], name) .who; state
  | :try mind . name .:need
    call {ok|:ok}{|?} .:need
    call
    { function: .at .name .parameters . & missing .replacement
    | :ok macro: .item .at .missing .replacement .parameters; state
    }
    { object: .at? .name? .replacement
    | :ok
      replacement first (state) fold: who +++
      { state := :;at .item [identifier], name'
      | :who :if name' = name; :ok
        who . state := ;at .item [blocked-identifier], name'
      }
    }
    call [ok]
  }
  { defined: .name | :ok mind . name or [] <> [] }
  { undefine: .name
  | :ok
    :if mind . name => ?; mind . name := []
  }
}
><:[module: . parse language C++ tokenize preprocess tokenize .timestamp 2008-01-06T21:03:38.100+01]><;
{ [test lexer]
| :self :ok self tokenize (.filename [testing] .text file "C:/test/tokens.tmp" text)
  count
}
{ [test split]
| :self :ok @@ split . (file "C:/test/tokens.tmp" text)
  count
}
{ tokenize: .text . $ total-length .filename
| :if text call (@@ line-splicing+trigraphs) => (:;text trimmed .adjustments);
  :ok
  trimmed call (@@ split)
  every (@@ keywords)
  first (;from 0 .adjustments .state [normal]) fold
  { (;from .adjustments .state) := kind, string $ count
  | :ok
    (;to from + count .slack 0 .adjustments)
    repeat
    { :;to .slack .adjustments splice: .count .at; adjustments
    | :if at <= to; :ok
      ;to . + count .adjustments .slack . + :if at = to; count .else 0
    }
    { :;to .slack .adjustments trigraph: .at; adjustments
    | :if at < to; :ok ;to . + 2 .adjustments .slack
    }
    call
    { ;to .slack .adjustments
    | :ok ;from to .adjustments .state . call
      { state := ? | :ok list := (;item kind, string .from .to . - slack); state }
      { [normal] := [directive-start]
      | :ok list := (;item [directive-start], string .from .to . - slack); [directive]
      }
      { [directive] := [linefeed]
      | :ok list := (;item [directive-end], string .from .to . - slack);
        [normal]
      }
      := kind
    }
  }
  .:list
  first 0 fold
  { a := b | pulimut }
  { 0 := :;item .from .to | :ok ;front 0, from .item .to }
  { 0 := :;item ? call [.linefeed .space], space .from .to | :ok space: . }
  { (space: .) := :;item .from .to
  | :ok
    list := (;item [space], space .at [0 0], (from, from));
    ;front 0, from .item .to
  }
  { (space: .) := :;item ? call [.linefeed .space], space 1 .from .to
  | :ok space: .. (space 1)
  }
  { (:;front .item .to) := next
  | :ok
    ;back to, next from;
    list := (;item .at filename, front, back);
    ;front back .item next item .to next to
  }
  { (pending = :;front? .item? .to?) :=
    :;item ? call [.linefeed .space], space .from? .to?
  | :ok
    space: ..pending
  }
  { (space: ..pending) := next = :;item .from .to
  | :ok
    ;back pending to, from;
    list := (;item .at filename, front, back) === pending;
    list := (;item [space], space .at (to, to) === pending, (from, from));
    ;front back .item .to
  }
  { (space: ..pending) := :;item ? call [.linefeed .space], space 1 .from? .to?
  | :ok space: .. (space 1) .pending
  }
  call
  { x | zzz }
  { 0 | :ok 0 }
  { space: .
  | :ok list := ;item [space], space .at [0 0], (total-length total-length)
  }
  { (:;front .item .to)
  | :ok list := ;item .at filename, front, (to, text count)
  }
  { space: ..pending :;item .front .to
  | :ok
    list := (;item .at filename, front, (to, total-length));
    list := ;item [space], space .at (to, to), (total-length, total-length)
  }
  .:list
}
><:[module: . parse language C++ tokenize preprocess tokenize line-splicing+trigraphs .timestamp 2008-05-03T00:06:12.560+02]><;
{ $ ok
| :ok .
  [ split: splice trigraph text
    .splice ["\", "??/"] [""/, ""=],
    .trigraph "??" ["=", "(", "/", ")", "'", "<", "!", ">", "-"],
    .text [+: [-: splice] 1, ] ]
  first 0 fold
  { at := [text], text $ count | :ok list := text; at + count }
  { at := [splice], ? $ count | :ok list := (splice: .count .at); at + count }
  { at := [trigraph], trigraph
  | :ok list := (trigraph: .at);
    list := trigraph call
    [ trigraph-translations:
      ."??=". "#"
      ."??(". "["
      ."??/". "\"
      ."??)". "]"
      ."??'". "^"
      ."??<". "{"
      ."??!". "|"
      ."??>". "}"
      ."-". "~"
    ]
    ;
    at + 3
  }
  .:list
  call
  { list
  | :ok
    ;text list each {$ ok|:ok} splice ""
    .adjustments list reverse each {* ok|:ok} first [?] fold
    { gaps := splice: .count .at | :ok splice: .count .at; gaps }
    { gaps := trigraph: .at | :ok trigraph: .at; gaps }
  }
}
><:[module: . parse language C++ tokenize preprocess tokenize split .timestamp 2008-05-03T00:08:51.903+02]><;
{ $ ok
| :ok .
  [ split:
    directive-start
    space
    linefeed
    include-head
    include-filename
    string-literal
    character-literal
    ellipsis
    floating-literal
    integer-literal
    include-keyword
    directive-keyword
    identifier
    separator
    operator
    preprocessor-concat
    preprocessor-stringize
    .linefeed ""=, ""/, ""<
    .space [+: " ", "">, "/*" [*: [-: "*/"] 1,] "*/", "//" [*: [-: linefeed] 1,]]
    .identifier ["A-Z", "a-z", "_", "$"] [*: "A-Z", "a-z", "_", "$", "0-9"],
    .directive-start [/: $ linefeed] [*: " ", "">] "#" [-: "#"] [*: " ", "">],
    .directive-keyword [/: directive-start] identifier,
    .include-keyword
      [/: directive-start] "include" [-: "A-Z", "a-z", "_", "$", "0-9"] [*: " ", "">],
    .include-filename
      [/: include-keyword]
      [ """" [+: [-: """" linefeed] 1,] """", "<" [+: [-: ">" linefeed] 1,] ">" ]
      [ -: -: [space, []] linefeed, ]
      ,
    .string-literal ["L" []] """" [*: [-: """"] string-character,] """",
    .character-literal ["L" []] "'" [-: "'"] string-character "'",
    .string-character
      [-: "\"] 1,
      "\"
      [ "'", """", "?", "\", "a", "b", "f", "n", "r", "t", "v",
        octal-digit [octal-digit [octal-digit [],], []],
        "x" [+: hexadecimal-digit],
        "u" hex-quad,
        "U" hex-quad hex-quad
      ],
    .integer-literal
      [ "1-9" [*: "0-9"],
        "0" [["X", "x"] [+: hexadecimal-digit], [*: octal-digit]]
      ]
      [ ["U", "u"] ["ll", "l", "LL", "L", []],
        ["ll", "l", "LL", "L", []] ["U", "u", []]
      ]
      ,
    .floating-literal
      [ [ +: "0-9" ] [ "." [*: "0-9"] [exponent-part, []], exponent-part ],
        "." [+: "0-9"] [exponent-part, []]
      ]
      [ "f", "l", "F", "L", [] ]
      ,
    .exponent-part ["e", "E"] ["+", "-", []] [+* "0-9"]
    .hexadecimal-digit "0-9", "a-f", "A-F"
    .hex-quad
      hexadecimal-digit hexadecimal-digit hexadecimal-digit hexadecimal-digit,
    .octal-digit "0-7"
    .ellipsis "..."
    .operator
      ["!", "%", "*", "/", "=", "^"] ["=", []],
      "&" ["&", "=", []],
      "|" ["|", "=", []],
      "+" ["+", "=", []],
      "-" ["-", "=", ">*", ">", []],
      "." ["*", []],
      ":" [":", []],
      "<" ["<", []] ["=", []],
      ">" [">", []] ["=", []],
      "?" [-: "?" ["'", "!", "/", "<", ">", "(", ")"],],
      "~"
    .preprocessor-concat "##", "%:%:"
    .preprocessor-stringize "#", "%:"
    .separator "<%", "%>", "<:", ":>"
  ]
}
><:[module: . parse language C++ tokenize settings .timestamp 2008-12-06T22:57:55.088+01 .language system]><;
{ settings: .mind
| :ok
   mind exclude := ();
  { x | y }
  { include-filename: .? .at?|?}
  { include-filename: ..at
  | :try
    ( :if include-filename $* """";
      at call {ok =* "/", ?, ?|:ok . <-#=* "/"} or ()
      &:
      mind pragma "include_path" or: )
    &
    ( mind pragma "system_include_path" or: )
    find
    { $ path
    | (path *=* ["\", "/"] <-#$* "/", include-filename -# 1 <-# 1)
      repeat
      { path =* "/", filename $* "../"
      | :ok path <-#=* "/", filename -#$* "../"
      }
      call {path, filename|:ok (path) "/" (filename)} {?, ? $* "../"|?} .(:need)
      call
      { filename
      | ;exclude-list mind exclude;
        exclude-list find {exclude|:try exclude (..filename)} or:
        :try ;filename .text file (filename) text .(:need)
      }
      .(:try)
    }
  }
  { include-filename: .. =* ":\" .at?
  | :if include-filename -# 1 <-# 1 => filename, file (filename) text => text;
    :ok ;text .filename
  }
  { pragma: . ; path | agurk }
  { pragma: path .pragma . = ? call [."system_include_path" ."include_path"]
  | path every {$ string|:if {} read (string) => +$ ok; :ok} .(:need)
    .(mind pragma (pragma) :=) and: :ok ()
  }
  { pragma: exclude-list .pragma "exclude"
  | :ok mind exclude := mind exclude & exclude-list
    every {ok|:ok . -#$* """" <-#$* """"}
    ;
  }
}
===
{ exclude: ..filename
| :try
  exclude split
  [ skip-match-end skip-match skip-end skip match
    .skip "*"
    .match [+: [-: "*"] ?,]
    .skip-match [/: skip] match,
    .skip-match-end skip-match [-: ?],
    .skip-end skip [-: ?],
  ]
  first (filename) fold
  { ok := [skip "*"] | :ok }
  { ok := [match], match $ count | :if ok $* match; :ok . -# count }
  { ok := [skip-match], match | :if ok =* match +> count; :ok . -# count }
  { ok := [skip-match-end], match | :if ok <$* match; :ok "" }
  { ok := [skip-end], match | :ok "" }
  .(:need)
  call {""|:ok()}
}
