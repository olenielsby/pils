><:[module: . parse language C++ parse rules .timestamp 2007-11-26T00:39:06.094+01 .language system]><;
{ ok := directive: .?; ? | :ok }
{ (state = declaration-sequence: .names?; ?) := . = :;at? .item ?, ?
| :who :try (specifier: state) call (who) :=
}
{ (state = specifier: ?) := . = :;at? .item ?, ?
| :who :try (type-specifier: state) call (who) :=
}
{ (type-specifier: tail) := :;at .item [keyword "void"]
| :who :try tail call (who) := ;at .item [type-specifier: void]
}
{ (specifier: tail) := :;at? .item specifier = type-specifier: ?
| :ok declaration: .specifier; tail
}

{ (state = declaration: .specifier; ?) := . = :;at? .item ?, ?
| :who :try (declarator: state) call (who) :=
}

{ (state = declarator: tail) := :;at? .item [identifier], name
| :ok declarator: .name; tail
}

{ (declarator: .name; declaration: .specifier; tail) := :;at .item [? "("]
| :ok
  parameter-declaration-list: function-declarator: .name .specifier; tail
}

{ (state = parameter-declaration-list: ?) := . = :;at .item ?, ?
| :who :try (specifier: parameter-declaration: state) call (who) :=
}
