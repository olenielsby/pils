{ reduction: p
| :ok
  { value: .; try
  | :try . call
    { priority: .; stack | :if p <= priority; :ok value: .; stack }
    { operator: .prefix [?:"!"]; stack | :ok value: .. = 0; stack }
    { operator: .prefix [+]; stack | :ok value: .; stack }
    { operator: .prefix [-]; stack | :ok value: .. [-]; stack }
    { operator: .pending .infix; stack
    | :ok value: . infix(..pending .value); stack
    }
  }
}

