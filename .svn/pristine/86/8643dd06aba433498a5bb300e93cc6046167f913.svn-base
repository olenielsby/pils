      {:;at? .item?, ok|:ok}
      {:;at? .item[space], ?|:ok " "}
      {:;at? .item ? call [.character-literal .string-literal], ok
      |:ok . *=* ["""", "\""", "\", "\\"]
      }
      -#$* [" ",] <-#$* [" ",]
      splice ""
    )
    """"
  }
  first (state) fold: who +++
  { state := :;at .item blocking = ([identifier], name)
  | :who :if blocking = item; :ok
    who . state := ;at .item [blocked-identifier], name
  }
}
