:;[identifier "false"] 0
.[identifier "true"] 1
.[? "("] [left-parenthesis]
.[? ")"] [right-parenthesis]
.[operator "!"] [operator: .prefix ?:"!"]
.[operator "*"] [operator: .infix * .priority 10]
.[operator "/"] [operator: .infix / .priority 10]
.[operator "%"] [operator: .infix % .priority 10]
.[operator "+"] [operator: .infix + .priority 9 .prefix +]
.[operator "-"] [operator: .infix - .priority 9 .prefix -]
.[operator "<<"] [operator: .infix << .priority 8]
.[operator ">>"] [operator: .infix >> .priority 8]
.[operator "<"] [operator: .infix < .priority 7]
.[operator ">"] [operator: .infix > .priority 7]
.[operator "<="] [operator: .infix <= .priority 7]
.[operator ">="] [operator: .infix >= .priority 7]
.[operator "=="] [operator: .infix == .priority 6]
.[operator "!="] [operator: .infix ?:"!=" .priority 6]
.[operator "&"] [operator: .infix & .priority 5]
.[operator "^"] [operator: .infix ^ .priority 4]
.[operator "|"] [operator: .infix ?:"|" .priority 3]
.[operator "&&"] [operator: .infix && .priority 2]
.[operator "||"] [operator: .infix ?:"||" .priority 1]
