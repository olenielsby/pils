[pils: .use? .language system]
><:[module:. parse, .timestamp 2008-03-31T14:46:15.709+02]><;
><:[module:. parse testbench .timestamp 2011-07-22T10:56:29.393+02 .language system]><;
{ testbench: .text .language
| :ok
  (channel: this module name, language) text (.) or:
  ;window platform window (say (language, [parser test]));
  ;channel (channel: window);
  ;[splitter: 1] window splitter [vertical];
  ;input-list
    splitter 1 list [.style broad]
    when {selected: .|@ selected (. ' call (window mind run) .channel)}
  ;
  ;[splitter: 2] splitter 1 splitter [vertical];
  ;state-display splitter 2 codepane;
  ;source splitter 2 textpane text (text);
  window mind test := (channel: this module name, language) listen
  { text: . | :self source text (text) and: :try self test }
  { .test
  | :ok
    ;run @ run (.text source text .limit @@ limit .language);
    window mind run := run;
    input-list clear
    add (@ input-list (.run))
    hot (run count) focus
  }
  ;
  splitter 1 split (input-list, splitter 2) and:
  ;listen channel listen (;source .state-display .input-list .language);
  splitter 2 split (state-display, source) and:
  window menu
  ( .
    [ [ menu: . test test .shortcut "Ctrl+T" .action test ]
      [ menu: . locate rule .shortcut "Ctrl+L" .action locate rule ]
    ]
    .action (channel: this module name, language) +++
    { [locate rule] | :try @ locate (.channel) }
  )
  and:
  (channel: this module name, language) test
}
><:[module:. parse testbench input-list .timestamp 2009-01-31T22:32:48.758+01 .language system]><;
{ input-list: .run
| :ok
  run every
  { at: ..state .input
  | :ok {} write: input **=** {token: . ok .tag?|:ok}
  }
}
><:[module:. parse testbench limit .timestamp 2008-01-02T16:36:48.072+01 .language system]><;
1000000><:[module:. parse testbench locate .timestamp 2011-09-10T00:59:02.824+02 .language system]><;
{ locate: .channel ' = channel: window
| channel input-list hot? -' 1 call (window mind run) .:need
  call
  { at: .? .input .state
  | @@ ([parse language] & (channel language) & [rules])
    call
    { ::ruleset .where
    | :try
      @ [pils editor] pinpoint: .where .what
      ruleset **=**
      {[action] := ok|:ok ' **=** {quote = ::ok ?|:ok ::ok ::quote}}
      ---' (where)
      .(state call:) := input
    }
  }
  .:try
}
><:[module:. parse testbench run .timestamp 2009-01-31T22:28:39.867+01 .language system]><;
{ run: .text .limit .language
| :who :ok who run (.text .language) ++# limit
}
{ run: .text .language
| :ok
  @ ([language] & language) tokenize (.text .tag [-test-])
  every {ok = token: ..tag|:ok list := ok}
  first [-test-]
  fold
  ( {? := ?|exit := ()}
    +++
    @@ ([parse language] & language & [rules])
    +++
    { state := input | list := state: ..input }
  )
  call {state|:ok list := state: ..input [done]}
  .:exit .:list
  first 1 fold
  { x := y | oops }
  { at := state: ..input | :ok list := (at: ..state .input); at }
  { ? := token: .? .tag * ;at | :ok at }
  .:list
}
><:[module:. parse testbench selected .timestamp 2011-07-22T11:10:28.417+02 .language system]><;
{ selected: ..channel
| :ok
  ;source channel source .language channel language;
  selected state
  **=** { ? := token: . ok .tag? | :ok }
  .(channel state-display text: {} indent)
  and:
  channel source selection:
  selected at call:
  @ ([language] & language & [tokenize]) positions (.text source text)
  try {ok = (extra) 0|:ok ' & (extra,)}
}
><:[module:. test, .timestamp 2008-03-31T14:42:26.418+02 .language system]><;
