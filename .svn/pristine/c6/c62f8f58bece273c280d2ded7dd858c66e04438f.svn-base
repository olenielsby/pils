{ insulin:. dosis
| :ok
  medicinering:
  .under [menu]
  .kategori "Insulin"
  .navn "Analog"
  .billede "diverse/insulin_pen.svg"
  .dosis
  .sammensætning
  [sammensætning: .1 1]
}
><:[modul:. program dansk maxi-projektet diabeteshjælper spil vare mad .tidsstempel 2010-01-22T22:38:27.299+01 .sprog dansk]><;
;madvarerne @ [data] madvarerne eneste [kald: navn];
{ mad:..gram | :ok mad kald (madvarerne) flet (;gram) }
><:[modul:. program dansk maxi-projektet diabeteshjælper spil vare motion .tidsstempel 2010-01-22T22:37:23.567+01 .sprog dansk]><;
;motionsformerne @ [data] motionsformerne eneste [kald: navn];
{ motion:..varighed 
| :ok motion kald (motionsformerne) flet (;minutterne varighed \ 1m)
}
