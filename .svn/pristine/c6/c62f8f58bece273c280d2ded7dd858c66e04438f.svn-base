><:[modul:. program dansk maxi-projektet diabeteshjælper spil tik .tidsstempel 2011-10-01T15:00:34.597+02 .sprog dansk]><;
{ tik: .lærred
| :ok
  ;minut lærred husk minut;
  ;placering @ [fremvisning] placering (.stræk lærred stræk);
  ;tidslinje @ tidslinje (.lærred .placering);
  ;starttid minut;
  lærred husk hændelserne :=
  ( ;hændelserne
      lærred husk hændelserne eller () & (tid: . starttid) orden [kald: tid]
    ;
    hændelserne +#^* ((tid: . starttid),) hver
    { emne: .flyder .tid .emne ' = * motion: .minutterne
    | ;minutterne ' - (starttid - tid) \ 1m;
      :hvis minutterne; :ok
      emne: .flyder .tid starttid .emne ' flet: ;minutterne 
    }
    &:
    hændelserne -#=* ((tid: . starttid),)
  )
  ;
  ;tilstand lærred husk tilstand [spil];
  lærred husk tilstand [spil] := tilstand gentag
  { tilstand: .tid .flyvende .aktuel
  | :hvis tid <= minut; :ok
    aktuel kald
    { vent: .; aktuel
    | :ok tilstand: .tid ' + vent .flyvende .aktuel
    }
    { fast: ..om .flyder; aktuel
    | :ok
      @ fast (..lærred .flyder .tid ' + om) pyt:
      tilstand: .tid .flyvende .aktuel
    }
    { flyv: ..fra .til .varighed; aktuel
    | :ok
      tilstand: .tid .aktuel .flyvende ' & flyv:. ' kald (@ [vare])
      .fra .til .varighed .sluttid tid + varighed
    }
    { | :ok tilstand: .tid .flyvende .aktuel @ tidsplan }
  }
  kald
  { tilstand: .tid .flyvende .aktuel
  | :ok
    tilstand: .tid .aktuel .flyvende ' hver
    { ok = flyv:.? .fra? .til? .varighed? .sluttid | :hvis sluttid >= minut; :ok }
  }
  ;
}
><:[modul:. program dansk maxi-projektet diabeteshjælper spil tilstand .tidsstempel 2010-01-22T19:53:53.939+01 .sprog dansk]><;
{ tilstand: .lærred
| :ok
  ;tidsplan @ tidsplan;
  tilstand: .aktuel tidsplan .flyvende [] .tid lærred husk minut
}
