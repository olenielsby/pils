><:[modul:. program dansk maxi-projektet diabeteshjælper forløb .tidsstempel 2011-10-01T15:02:15.650+02 .sprog dansk]><;
{ forløb:
  .tidslinje
  .placering
  ;
  & emnerne
| :ok
  [fra til] hver (placering)
  hver {x|:ok tidslinje tid (.x) afrund 1m}
  kald
  {fra, til|:ok 0 op ((til - fra) / 1m) hver {x|:ok tid:. fra + x * 1m;}}
  & (emnerne hver (@@ hændelsesreduktion) splejs)
  grupperne {tid:.; værdi|:ok :navn tid; værdi}
  benene {tid := hændelserne = () 1|:ok tid:.; hændelserne}
  orden [kald: tid]
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal .sprog dansk]><;

><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal baggrund .tidsstempel 2010-01-19T23:54:59.057+01 .sprog dansk]><;
{ baggrund: .lærred .grafik
| :ok
  ;graf (graf:baggrund:. #eeeeee;);
  lærred husk baggrund [graf] := graf;
  grafik graf (graf)
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal glukosekurve .tidsstempel 2010-01-21T01:00:21.482+01 .sprog dansk]><;
{ glukosekurve:. .grafik .placering .glukoseskala .tidslinje
| :ok
  :kald (pyt: grafik) .hvem
  ;figur
    glukosekurve hver
    {*;tid .glukose g|:ok tidslinje x (.tid), glukoseskala y (.g)}
    .(graf:kurve:)
  .gradient
    @ gradient
    ( ;margin placering bund - (placering top) \ 4;
      placering top - margin, placering bund + margin
    )
  ;
  grafik graf:
  ([9 #000000], (8, gradient))
  hver {graf:rund, graf:blæk|:ok graf:blæk:.; graf:rund:.; figur}
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal madindtag .tidsstempel 2011-10-01T15:04:49.526+02 .sprog dansk]><;
{ madindtag:. ' = (* madvare: .glukose .gram .billede .navn .hak)
  .grafik .x .y
| :ok
  grafik graf:
  graf:blæk:.;
  graf:ved:. x, y;
  ( graf:skyd:. 50%;
    graf:stræk:. 32; graf:billede: billede kald (billederne)
  )
  &:
  ( graf:ved:. 0, 25; graf:skyd:. 50%;
    graf:skrift:.; :hvis hak; sig (gram, " g") .ellers "uspec."
  )
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal medicinering .tidsstempel 2010-01-22T17:08:22.139+01 .sprog dansk]><;
{ medicinering: .grafik .dosis .x .y .billede .navn
| :ok
  grafik graf:
  graf:blæk:.; graf:ved:. x, y;
  ( graf:skyd:. 50%;
    graf:stræk:. 32; graf:billede: billede kald: billederne
  ),
  ( graf:ved:. 0, 0;
    graf:skyd:. 50%, 1; graf:skrift:.; sig (dosis, " enh.")
  ),
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal motion .tidsstempel 2010-01-22T19:16:54.723+01 .sprog dansk]><;
{ motion:. (*;navn .minutterne .puls .billede) .grafik .tidslinje .tid .y
| :ok
  ;x tidslinje x (.tid)
  .[x: slut] tidslinje x (.tid . + (minutterne * 1m))
  ;
  grafik graf:
  graf:ved:. x, y;
  ;x' x [slut] - x;
  ( graf:blæk:. #649600;
    graf:ved:. 0, 24;
    graf:figur:
    (0, -6),
    (x' - 4, -6),
    (x', -12),
    (x' + 4, -6),
    (x' + 4, 6),
    (x', 12),
    (x' - 4, 6),
    (0, 6)
  ),
  ( graf:ved:. x' / 2, 0;
    graf:skyd:. 50%; graf:stræk:. 32;
    graf:billede: billede kald: billederne
  ),
  ( graf:blæk:. #ffffff;
    graf:ved:. x' / 2, 24;
    graf:skyd:. 50%;
    graf:skrift:.; @ minutangivelse (.minutterne)
  ),
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning mal tidspil .tidsstempel 2010-01-20T00:31:04.723+01 .sprog dansk]><;
{ tidspil: .grafik .placering * placering: .top .bund .fra .til .spids .udhæng
| :ok
  grafik graf:
  graf:blæk:.;
  graf:streg:. 3;
  graf:figur:
  (fra, top),
  (til, top),
  (til, top - udhæng),
  (til + spids, top + bund / 2),
  (til, bund + udhæng), 
  (til, bund),
  (fra, bund)
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning placering .tidsstempel 2010-01-22T16:07:38.213+01 .sprog dansk]><;
{ placering: .stræk bredde, højde
| :ok
  placering:
  .top (højde * 10 \ 50) + (højde * højde \ 4000)
  .bund højde - 10 - (højde \ 8)
  .fra 30
  .til bredde - 40
  .spids 30
  .udhæng 15
  .[x: nu] 30
  .bredde
  .højde
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning vindue .tidsstempel 2011-10-01T14:58:05.912+02 .sprog dansk]><;
{ .vindue
| :ok
  kanal luk pyt:
  ;vindue
    platform vindue
    (sig [diabetrix - træn din insulin "" dosering])
    indre stræk [480 320] plads [0 0]
  ;
  vindue ikon (@ logo) og:
  ;lærred
    vindue lærred
    når
    { mal: grafik
    | :hvem @ lærred:. hvem .grafik .visning hvem husk visning
    }
    { prøv = ? $* [mus,] *?
    | :hvem :prøv ' kald:
      @ mus:
      .lærred hvem
      .placering @ placering (.stræk hvem stræk)
      .visning hvem husk visning
    }
    { .strakt | :hvem ' opfrisk .:ok }
  ;
  lærred husk ryk := 1m;
  lærred husk model := [hakkebakke];
  lærred husk baggrund [valgt] := @ baggrundene . 1;
  :brug
  { .visning | :ok lærred husk visning }
  { .placering | :ok @ placering (.stræk lærred stræk) }
  { .brugerprofil | :ok @ [data] brugerprofil }
  ;
  lærred husk visning := [personlig];
  lærred husk minut := 2000-01-01T00:00Z;
  lærred husk tilstand [spil] := @ [spil] tilstand (.lærred);
  ;husk [kanal: diabeteshjælper] lyt
    { .hændelserne | :prøv @ hændelserne }
    { .tidslinje | :prøv @ tidslinje (.lærred .placering) }
  ;
  lærred husk bredde [time] := @@ tidshorisonterne find {[mellem], ok|:ok};
  @ menu (.vindue .lærred .brugerprofil .visning) og:
  vindue husk lukker := kanal lyt
    { .luk | :prøv vindue luk }
    { .opfrisk | :prøv lærred opfrisk }
  ;
  lærred husk tidslinje := @ tidslinje (.lærred .placering);
  lærred husk butikshylde := 0;
  lærred husk trækker := ();
  lærred husk tikker := platform tikker [.engelsk:milliseconds 100] når
  { .tik
  | datafiltjek og:
    lærred husk minut := lærred husk minut + (lærred husk ryk);
    @ [spil] tik (.lærred) og:
    lærred opfrisk
  };
  og:
  vindue indre stræk [480 320]
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning vindue lærred .tidsstempel 2011-10-01T15:05:58.838+02 .sprog dansk]><;
;billederne @@ billederne
.emnerne @ [emnerne]
.mal @ [mal]
;
{ lærred:. .grafik .visning [personlig]
| :ok
  ;placering @ placering (.stræk lærred stræk);
  ;tidslinje @ tidslinje (.lærred .placering)
  .brugerprofil @ [data] brugerprofil
  .hændelserne @ hændelserne (.lærred .placering)
  .minut lærred husk minut
  ;
  ;glukoseskala
    @ glukoseskala
    (.glukosegrænserne brugerprofil glukosegrænserne .placering)
  ;
  mal baggrund (.grafik .lærred) og:
  mal tidspil (.grafik .placering) og:
!  @ varefelterne (.lærred) hver
!  { vare:.. <> [] .rektangel .hylde
!  | mal hyldevare:. vare .grafik .rektangel .hylde
!  }
!  og:
  @ [model] (lærred husk model) mal
  ( ..tidslinje
    .placering
    .hændelserne
    .brugerprofil
    .lærred
    .grafik
    .glukoseskala
  )
  og:
  lærred husk glukoseskala := glukoseskala;
  glukoseskala mal (..grafik)
  og:
  lærred husk hændelserne eller () hver
  { emne:. .tid .flyder
  | :prøv
    emne kald (emnerne) mal:. .grafik .tidslinje .tid .flyder .lærred
  }
  og:
  tidslinje mal (..grafik)
  og:
  lærred husk tilstand [spil] flyvende hver
  { flyv:. .fra .til .varighed .sluttid
  | ;sted
      (fra, til) tværs hver
      {fra, til|:ok ((fra - til) * (sluttid - minut) / varighed + til) afrund}  
    ;
    flyv
    kald (emnerne) mal
    ( ..grafik .tidslinje
      .tid tidslinje tid (.x sted . 1)
      .flyder glukoseskala flyder (.y sted . 2)
      .lærred
    )
    .:kræv
  }
  og:

  lærred husk trækker eller () prøv
  { emne:. .sted x, y
  | emne prøv [kald: emne]
    kald (emnerne) mal
    ( ..grafik .tidslinje
      .tid tidslinje tid (.x)
      .flyder glukoseskala flyder (.y)
      .lærred
    )
    .:kræv
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning vindue lærred model .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning vindue lærred model hakkebakke .tidsstempel 2010-01-21T02:04:42.129+01 .sprog dansk]><;
;hakkebakke
{ mal:
  ..tidslinje
  .placering
  .hændelserne
  .brugerprofil
  .lærred
  .grafik
  .glukoseskala
| :ok
  ;starttid tidslinje tid (.x placering fra) afrund 1m;
  ;starttilstand
    lærred husk glukosekurve eller ()
    find {ok = *;tid|:hvis tid = starttid; :ok}
    eller
    (@ [glukosemodel hakkebakke] starttilstand: .brugerprofil .tid starttid)
  ;
  ;forløb @ forløb (.tidslinje .placering; hændelserne);
  :hvis forløb antal;
  ;glukosekurve
    @ [glukosemodel hakkebakke] forløb (..brugerprofil .starttilstand)
  ;
  lærred husk glukosekurve := glukosekurve;
  mal glukosekurve (..grafik .placering .glukoseskala .tidslinje)
}
><:[modul:. program dansk maxi-projektet diabeteshjælper fremvisning vindue mus .tidsstempel 2011-10-01T15:10:43.624+02 .sprog dansk]><;
{ mus: .lærred .placering .visning [oversigt] | :ok [ok] }
{ mus: .lærred .placering .visning [personlig]
| :ok
  { [mus venstre ned]: sted = (x, y)
  | ;glukoseskala
      @ glukoseskala
      ( .glukosegrænserne @ [data] brugerprofil glukosegrænserne
        .placering
      )
    ;
    ;tidslinje @ tidslinje (.lærred .placering);
    lærred husk tidslinje := tidslinje;
    lærred husk tilstand [spil] flyvende enhver
    { flyv = flyv:.? .fra .til .varighed .sluttid
    | :ok flyv:. .sted
      (fra, til) tværs hver
      { fra, til
      |:ok ((fra - til) * (sluttid - lærred husk minut) / varighed + til) afrund
      }  
    }
    find
    { flyv:. .sted x', y'
    | :hvis (x - x' >= -20 <= 20) og (y - y' >= -20 <= 20);
      ;flyder placering flyder (.y y') eller 500;
      :ok
      lærred husk tilstand [spil] := lærred husk tilstand [spil] flet
      ( ;flyvende
        lærred husk tilstand [spil] flyvende
        undtagen ((flyv,) eneste [ok])
      )
      ;
      ;hændelserne lærred husk hændelserne;
      lærred husk hændelserne := hændelserne &:
      emne:. flyv flyv .flyder .tid tidslinje tid (.x x') afrund 1m
    }
!    { emne = emne:. aktivitet = (*;minutterne) .tid .flyder
!    | ;x' tidslinje x (.tid . + (minutterne * 1m)) .y' glukoseskala y (.flyder);
!      :hvis x' - 8 <= x, y' - 12 <= y, x' + 8 >= x, y' + 12 >= y; :ok
!      emne:. ..(varighed:) .sted
!    }
    eller:
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper glukosemodel .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper glukosemodel hakkebakke .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper glukosemodel hakkebakke forløb .tidsstempel 2011-10-01T15:02:51.867+02 .sprog dansk]><;
{ forløb:. ' = (tid:.; ?) 1 .brugerprofil .starttilstand
| :ok
  ;@@hændelse @@ hændelse .@@skridt @@ skridt;
  forløb --# 1 først (starttilstand)
  fold
  { tilstand := tid:.; hændelserne
  | :ok liste :=
    @@skridt skridt (.tid .tilstand)
    & (hændelserne -#+* (,)) fold (@@hændelse)
  }
  .(liste := starttilstand;)
  .:liste
  hver {ok = *;tid .glukose|:ok}
}
><:[modul:. program dansk maxi-projektet diabeteshjælper hændelserne .tidsstempel 2011-10-01T14:59:13.823+02 .sprog dansk]><;
;emnerne @ [emnerne];
{ hændelserne: .lærred .placering
| :ok
  ;tidslinje lærred husk tidslinje
  .glukoseskala
  ( @ glukoseskala:
    .placering
    .glukosegrænserne @ [data] brugerprofil glukosegrænserne
  )
  ;
  ;hændelserne lærred husk hændelserne eller () prøv [fejl:.?];
  lærred husk trækker eller () kald
  { | :ok hændelserne }
  { emne:. .sted ' = (?, y)
  | :ok
    hændelserne undtagen ((emne,) eneste [ok])
    &:
    () prøv
    {
    | ;tid tidslinje tid (.sted) .:kræv; :ok
      emne:. ' prøv {*;emne ok|:ok}
      .tid 
      .flyder
      @ glukoseskala
      ( .glukosegrænserne @ [data] brugerprofil glukosegrænserne
        .placering
        @@ . [fremvisning placering] placering: .stræk lærred stræk
      )
      flyder (.y)
    }
  }
  { emne:. (varighed: ?) .sted? | :ok hændelserne }
  { emne:. (varighed: aktivitet = emne:. .flyder? .tid) .sted
  | ;minutterne tidslinje tid (.sted) .:kræv - tid \ 1m;
    :hvis minutterne; :ok
    hændelserne undtagen ((aktivitet,) eneste [ok])
    &: aktivitet flet: ;emne ' flet: ;minutterne
  }
  { emne:. (vægtjustering: ?) .sted? | :ok hændelserne }
  { emne:. vægtjustering = (vægtjustering: mad = emne:. .flyder? .tid)
    .sted x, y
  | ;[x: emne] tidslinje x (.tid);
    :hvis x >= x [emne] - 100, x < x [emne] + 100;
    ;gram vægtjustering kald (emnerne) vægt (.y .glukoseskala);
    :ok
    hændelserne undtagen ((mad,) eneste [ok])
    &: mad flet: ;emne ' flet: ;gram
  }
  { emne:. (dosisjustering: ?) .sted? | :ok hændelserne }
  { emne:.
      dosisjustering = (dosisjustering: medicinering = emne:. .flyder? .tid)
    .sted x, y
  | ;[x: emne] tidslinje x (.tid);
    :hvis x >= x [emne] - 60, x < x [emne] + 140;
    :ok
    hændelserne undtagen ((medicinering,) eneste [ok])
    &: medicinering flet: ;emne ' flet:
    ;dosis dosisjustering kald (emnerne) dosis (.y .glukoseskala)
  }
  { emne:. måling =
    (* blodsukkermåling: .værdi?)
    .sted x, y
  | ;tid tidslinje afrund (.tid tidslinje tid (.x));
    :hvis y > 80, tid <= nu + 10m .ellers hændelserne .:ok;
    :ok
    hændelserne undtagen ((måling,) eneste [ok]) &:
    ;glukoseskala;
    ;værdi glukoseskala g (.y) * 10 afrund / 10;
    emne:. (måling flet (;værdi))
    .flyder (glukoseværdi:. værdi)
    .tid
  }
  { emne:. ' =
    (emne:. (måling = * blodsukkermåling: .værdi?) .flyder? .tid?)
    .sted x, y
  | ;hændelserne ' undtagen ((emne,) eneste [ok])
    .tid tidslinje afrund (.tid tidslinje tid (.x))
    ;
    :hvis y > 80,  tid <= nu + 10m .ellers hændelserne .:ok;
    :ok
    hændelserne &:
    ;glukoseskala;
    ;værdi glukoseskala g (.y) * 10 afrund / 10;
    emne:. (måling flet (;værdi))
    .flyder (glukoseværdi:. værdi)
    .tid
  }
  ===
  { .glukoseskala
  | :ok @ glukoseskala
    ( .placering @@ . [fremvisning placering] placering (.stræk lærred stræk)
      .glukosegrænserne @ [data] brugerprofil glukosegrænserne
    )
  }
}
><:[modul:. program dansk maxi-projektet diabeteshjælper hændelserne gem .tidsstempel 2010-01-20T00:54:02.164+01 .sprog dansk]><;
;kanal (kanal: engelsk:pils-library: dette program filnavn)
.modulnavn
  [program dansk maxi-projektet diabeteshjælper data hændelserne]
;
{ gem: .hændelserne
|
}
><:[modul:. program dansk maxi-projektet diabeteshjælper spil .tidsstempel 2010-01-21T12:56:48.829+01 .sprog dansk]><;
><:[modul:. program dansk maxi-projektet diabeteshjælper spil fast .tidsstempel 2010-01-22T22:41:01.120+01 .sprog dansk]><;
{ fast:. .lærred .flyder .tid
| :ok
  lærred husk hændelserne :=
  lærred husk hændelserne eller () & emne: .flyder .tid .emne
  fast kald: @ [vare]
}
