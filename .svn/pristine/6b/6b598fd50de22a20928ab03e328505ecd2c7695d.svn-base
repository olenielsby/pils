><:[module:. parse language delphi tokenize .timestamp 2011-06-12T15:53:10.560+02 .language system]><;
{ tokenize: .text .tag
| :ok @ split (.text)
  & [symbol "",]
  legs
  { at := token = (?, original) | :ok token: ..tag tag: ..at .original }
  { at := [symbol], original
  | :ok token: . original .tag tag: ..at .original
  }
  { at := [identifier], original
  | :ok
    token: . ([identifier], original lower) try (@ keywords)
    .tag tag: ..at .original
  }
  { ? := [blank], ? | ? }
}
><:[module:. parse language delphi tokenize keywords .timestamp 2011-07-07T16:08:54.646+02 .language system]><;
{ .keywords
| :ok
  @@ list
  firsts {value|:ok :name [identifier], value; value}
}
