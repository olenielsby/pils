{ (var: .names .":"; state) := type = type:.?
| :ok var: .names .":" .type; state
}
{ (var: .names .":" .type; vars:. ."var"; state)
  := ";" .:call = token:. ";" .tag?
| :ok vars:. ' & (var: .names .":" .type .";") ."var"; state
}

{ (arguments:. .item; state) := ":" .:call = token:. ":" .tag?
| :ok term: .level 1; arguments:. .item .":"; state
}
{ (arguments:. .item argument .":"; state) := term:. option
| :ok arguments:. .item (argument:. .":" .option); state
}

{ (term: .level 1; state = arguments:.?; ?) := "[" .:call = token:. "[" .tag?
| :ok arguments: argument: ."["; state
}
{ (argument: ."["; state) := arguments:. elements
| :ok argument: ."[" .elements; state
}
{ (argument: ."[" .elements; arguments:.; state)
  := "]" .:call = token:. "]" .tag?
| :ok arguments:. .item (argument: ."[" .elements ."]"); state
}

{ state := name = token:. ' .([identifier],) .tag
| :who :ok state call (who) := name:. token:. .tag
}
{ state := name = token:. ' .([integer],) .tag
| :who :ok state call (who) := integer:. token:. .tag
}
{ state := name = token:. ' .([float],) .tag
| :who :ok state call (who) := float:. token:. .tag
}
{ state := name = token:. ' .([string],) .tag
| :who :ok state call (who) := string:. token:. .tag
}
{ state := self = token:. "self" .tag?
| :who :ok state call (who) := self:.
}
