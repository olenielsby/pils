><:[module:. parse language delphi tokenize positions .timestamp 2011-06-12T16:33:06.016+02 .language system]><;
{ positions: .text
| :ok @@ . [tokenize split]
  split (.text) first 0 fold
  {p := ?, ? $ c|:ok list := p, p + c; p + c}
  .:list
}
><:[module:. parse language delphi tokenize split .timestamp 2011-07-14T23:27:18.001+02 .language system]><;
{ split: .text
| :ok
  text split
  [ identifier blank string float integer symbol
    .identifier ["A-Z", "a-z", "_"] [*: "A-Z", "a-z", "_", "$", "0-9"],
    .blank
      [ +:
        " ", "">, ""/, ""=,
        "(*" [=*: "*)"],
        "{" [=*: "}"],
        "//" [=*: ""=, ""/]]
    .string [+: "'" [=*: "'"],], [+: "#" integer,],
    .symbol
      ",", ";", ":=", "=", ":", "(", ")", "[", "]", "..", ".", "@", "<>",
      "^", "**", "*", "/", ">=", ">", "<=", "<", "+", "-"
    .integer
      [+: "0-9"], "$" [+: hexadecimal-digit]
    .float
      [ [ +: "0-9" ] [ "." [*: "0-9"] [exponent-part, []], exponent-part ],
        "." [+: "0-9"] [exponent-part, []]
      ]
      [-: "."]
      ,
    .exponent-part ["e", "E"] ["+", "-", []] [+: "0-9"],
    .hexadecimal-digit "0-9", "a-f", "A-F"
  ]
}
