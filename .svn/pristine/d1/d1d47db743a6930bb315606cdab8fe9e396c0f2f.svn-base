><:[module:. pils kernel-generator specs parse tokenize split test modules .timestamp 2009-08-23T20:51:03.619+02 .language system]><;
{ .modules
| :ok
  this program libraries every [call: filename]
  every
  { filename
  |:ok (channel: pils-library: filename) node legs
    {+& module := * ;module +$ text|:ok module: ..text}
  }
  splice
  distinct [call: module] order {module:..text?|:ok {} write: module}
  every {module:..text?|:ok module (module)}
  each
  { * module: .name .language . language .text
  | :ok module: .name .text .language
  }
}
