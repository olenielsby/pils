[pils: .use? .language system]
><:[module:. plug, .timestamp 2009-01-05T11:31:03.808+01 .language danish]><;
><:[module:. plug mysql .timestamp 2009-08-11T17:07:59.118+02 .language system]><;
;mysql @ plug><:[module:. plug mysql filename .timestamp 2009-07-30T11:33:58.480+02 .language system]><;
{ .filename
| :ok
  ( [pils-configuration:compile-mode]
    call:
    ."debug"
      this module path <-#~* "////"
      ( [pils-configuration:system] call:
        ."linux" "/src/glucplug/bin/Debug/libmysql-plug."
        ."win32" "/build/win32/vc9/Debug/mysql-plug/mysql-plug."
        ."macos" "/build/macosx/jpils/build/Debug/libmysql-plug."
      )
    ."release"
    this module path <-#~* "////"
    "/bin/"
    ( [pils-configuration:system] call:
      ."linux" "linux/plug/libmysql-plug."
      ."win32" "win32/plug/mysql-plug."
    )
  )
  [pils-configuration:plugtype]
}
><:[module:. plug mysql interface .timestamp 2009-08-31T16:11:03.851+02 .language plug]><;
p:plug:
Root:
.Root
  [host: Host: p:string p:int],
  [host: Host: p:string],
.Host
  [connect: Connection: p:string p:string p:string],
.Connection
  [server-version: p:int:],
  [query: p:void: p:blob],
  [read: ResultSet:],
  [statement: Statement: p:blob],
.Statement
  [parameters: p:int:],
  [run: p:void:],
  [bind: p:void: p:int],
  [bind: p:void: p:double],
  [bind: p:void: p:blob],
.ResultSet
  [end: p:void:],
  [row: Row:],
.Row
  [count: p:int:],
  [#: p:blob: p:int],
.error
  [text: p:string:],
><:[module:. plug mysql plug .timestamp 2009-06-10T18:06:25.747+02 .language plug]><;
(;plug) ===
{ .plug | :ok :call p:plug: . @ filename; @@ interface }
