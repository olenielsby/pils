;over "C:/Programmer/Open Clip Art Library/clipart/"
.under [pils-configuration:documents-directory]><:[modul: . job foodprofessor billedbog test .tidsstempel 2009-01-21T11:30:05.075+01 .sprog dansk]><;
{ .test
| :ok @ billedbog
}
