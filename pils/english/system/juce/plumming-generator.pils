    ;ifdef (') (class . "__" . name) or ();
    (ifdef begin)
    "        static void " (class) "__" (nickname) "("
    ( kind call
      { ? call [.0 ."virtual" ."inline" .get;]
      | :ok
        "juce::"
        ( class *=*
          ( "pils__", "pils__",
            "pilsgraft__", "pilsgraft__",
            "molested__", "molested__",
            "__", "::"
          )
        )
        " &object, "
      }
      { ? call [.ctor ."static" .["static" "inline"]] | :ok "no object, " }
      { .ctor
      | class call (extenders) .:need and: :ok
        "CallbackHelperBase *&callbackHelper, "
      }
    )
    ( types call (none: "no args, ") or: "ArgPass::" (signature) " &args, " )
    ( type
      try
      { "const", ok | :ok }
      { ok = ("const", ?, "::", ?) | :ok ' -# 1 }
      { "const", name, args = template-arguments: .? | :ok name, args }
      try
      { name, args = template-arguments: .? | :ok "juce", "::", name, args }
      call
