}><:[module:. job plumming opengl functions .timestamp 2011-07-07T16:33:51.160+02 .language system]><;
{ .functions
| :ok
  @ text
  *=* (" APIENTRY ", " ")
  *=* ("GLboolean", "bool")
  *=* (@ typedefs splice)
  split ""=
  each
  { ok $* "WINGDIAPI "
  | :ok . -# 10 split
    [ type head void a-type a-name comma tail
      .type [/: $] [+: [-: head] 1,],
      .head [+: [-: " ", "("] 1,] [" ",,] "(",
      .a-type [/: head, comma] [+: [-: ")", ",", a-name'] 1,],
      .comma ","
      .a-name' "a-z" [*: [-: " ", ",", ")"] 1,]  [-: -: ",", ")"],
      .a-name [/: a-type] a-name',
      .void [/: head] "void" [-: -: ")"],
      .tail [/: void  a-name] ");" [-: 1],
    ]
    groups
    { name, value|:ok :name; value -#+* " " <-#+* " "}
    { ? call [.void .tail .comma], ?|?}
  }
  every (generator)
  each {ok|:ok}{? $* "    void "|?}{ok $* "    void *"|:ok}
  splice ""
}
=== ;generator
{ (groups: .type ., .head ., .a-type . & argc .a-name . & argc)
  anyway [.a-type? .a-name?]
| :ok
  "    "
  (type) " " (head)
  ( (a-type, a-name) traverse every {ok|:ok . splice " "}
    splice ", "
  )
  ") {"="        "
  ( type call [."void" ""] or "return " )
  "::" (head) (a-name splice ", ")
  ");"="    }"=
}
and
{ (groups: .type ., .head ., .a-type . & argc .a-name . & argc)
  anyway [.a-type? .a-name?]
| :ok
  "    "
  (type) " " (head)
  ( (a-type, a-name) traverse every {ok|:ok . splice " "}
    splice ", "
  )
  ");"=
}
