  }
  splice &
  ( @ [extract] attributes every
    { field: .class .name .type
    | :ok method: . name .class .name .kind [get] .type
      .signature "NoArguments"
      .throw ()
    }
  )
  except 
  { method: .? .class ? $* "molested__" .name? .kind [ctor] .type?
    .signature?
    .throw?
  | :ok ()
  }
  groups [call: class]
  legs {? := ok|:ok}
  order {(*;class ok) 1|:ok}
  every
  { methods = (*;class) 1
  | :ok
    methods order [call: method]
    every
    { method: ..class .name .kind .type .signature .throw
    | :ok
      ;type @ [declarations methods] type (..class .name);
      "        " (method) "("= "            "
      "JuceClass::classes.c__"
      ( kind call
        { ? | :ok class *=* ("pilsgraft__", "") }
        { "static" | :ok (class) ".staticClass" }
        { .ctor | :ok class -#$* "pils__" }
      )
      ","="            "
      ( name
         split "__" call
         { ok | :ok ' splice "." .("""") """"}
         { "gl" 1 = (name) 2
         | :ok
           "Namespace_Juce::opengl_singleton->get(""" (name) """)"
         }
         { "OpenGL",
         | :ok "Namespace_Juce::opengl_singleton->get(""OpenGL"")"
         }
      )
      ","="            "
      "argsThunk<ArgPass::" (signature) ">,"="            "
      "(Thunk)Thunks::" (class) "__" (method)
      ( type call {?, class|:ok ","="            JuceClass::classes.c__" (class)}
        or ""
      )
      ")"
    }
    splice ","=
    .("    " (class) "__methods::" (class) "__methods() :"=)
    ""="    {}"==
  }

  { methods = (*;class ' = "PlatformUtilities") 1
  | :ok
    ifdef legs {? := ok|:ok} splice distinct order [ok] & () legs
    { position := condition
    | :ok
      :who (position, condition) call
        {?, symbol|:ok "#elif defined(" (symbol) ")"=}
        {1, symbol|:ok "#if defined(" (symbol) ")"=}
        {?,,|:ok "#else"=}
      .call
      methods order [call: method]
      each
      { method: ..class .name .kind .type .signature .throw
      | :if
          (class) "__" (method) call (ifdef) or () call
          {ok|:ok ' listwise =* (condition,)}
          {|:ok 1}
        ;
        :ok
        ;type @ [declarations methods] type (..class .name);
        "        " (method) "("= "            "
        "JuceClass::classes.c__"
        ( kind call
          { ? | :ok class }
          { "static" | :ok (class) ".staticClass" }
          { .ctor | :ok class -#$* "pils__" }
        )
        ","="            "
        ( name split "__" splice "." .("""") """" )
        ","="            "
        "argsThunk<ArgPass::" (signature) ">,"="            "
        "(Thunk)Thunks::" (class) "__" (method)
        ( type call {?, class|:ok ","="            JuceClass::classes.c__" (class)}
          or ""
        )
        ")"
      }
      splice ","=
      .("    " (class) "__methods::" (class) "__methods() :"=)
      ""="    {}"=
    }
    splice "" "#endif"==
  }
