><:[module:. job plumming juce generate definitions argtypes .timestamp 2011-07-21T02:28:08.242+02 .language system]><;
{ .argtypes
| :ok
  ;classes @ [extract] classes .pairing @ pairing;
  @ [extract] arglists
  legs
  { args := methods = (*;class .nickname) 1
  | :ok
    name: . class, nickname
    .args ' legs
    { n := field: .type .value
    | :ok arg: . "arg" ({} write: n) .type .value
    }
  }
  { () := ? | :ok name: . "NoArguments", .args () }
  order [call: name]
  every
  { name: ..args
  | :ok
    "        struct " (name splice "__") " {"=
    ( args every
      { arg: ..type .value
      | :ok
        type try
        { ref: ok
        | :ok (:if value <> (); "const") &:
          ok listwise every
          {ok|:ok ' call (classes) and ("juce::" (ok)) or (ok)}
        }
        { "const", "String", "&" | :ok "juce::String", }
        { "const", "var", "::", "identifier", "&" | :ok "juce::var::identifier", }
        { "const", "var", "&" | :ok "juce::var", }
        { array: element-type
        | :ok "ArrayArgument<" & element-type & ">"
        }
        { "const", class, type = template-arguments:. ?
        | :ok class, type
        }
        try
        { $ class, type = template-arguments:. ?
        | :ok "juce::", class, type
        }
        listwise every
        { & ok | :who :ok ' every (who) splice " " }
        { $ ok | :ok }
        { ok =* "__" | :ok ' *=* ("pils__", "pils__", "__", "::") }
        { template-arguments: .
        | :who :ok "<" (template-arguments every (who) splice ", ") ">"
        }
        { index: . ["[", "]"]; ok | :who :ok ' call (who) "*" }
        { index: . ("[", ([integer-literal], n), "]"); ok
        | :who :ok ' call (who) "*"
        }
        & arg splice " "
      }
      every {arg|:ok "            " (arg) ";"=}
      splice ""
    )
    "            bool fill(ArgumentSource &source) {"=
    ( args call (pairing)
      every
      { arg: ..type .value
      | :ok
        type call
        { ? | :ok arg: ..class () .value .ref ""}
        { class, "*"
        | class call (classes) .:need and: :ok
          arg: ..class .value .ref ""
        }
        { (outer, "::", inner), "*"
        | ;class (outer) "__" (inner);
          class call (classes) .:need and: :ok
          arg: ..class .value .ref ""
        }
        { outer, "::", inner, "*"
        | ;class (outer) "__" (inner);
          class call (classes) .:need and: :ok
          arg: ..class .value .ref ""
        }
        { "const", outer, "::", inner, "*"
        | ;class (outer) "__" (inner);
          class call (classes) .:need and: :ok
          arg: ..class .value .ref ""
        }
        { ref: class, "*"
        | class call (classes) .:need and: :ok
          arg: ..class .value .ref "&"
        }
      }
      every
      { arg: ..class .value .ref
      | :who :ok
        "                "
        ( :if value <> () .else "";
          "if (source.done()) " (arg) " = " (ref)
          ( value call
            [ .[[name: . "Colour"], "(", integer-literal "0x00000000", ")"]
              "dummy_Colour"
              .[[name: . "Justification"], "::", [name: . "horizontallyCentred"]]
              "dummy_Justification_horizontallyCentred"
              .[[name: . "Justification"], "::", [name: . "centred"]]
              "dummy_Justification_centred"
              .[[name: . "KeyPress"], "(", ")"]
              "dummy_KeyPress"
            ]
            or:
            value listwise every
            { ok | :ok }
            { ? call [.integer-literal .floating-literal .string-literal], ok | :ok }
            { name: . ok | :ok }
            splice " "
          )
          ";"=
          "                else "
        )
        "if (!source.fill("
        ( arg )
        ( class call
          { $ class
          | :ok
            ", JuceClass::classes.c__" (class) ", "
            (ref call [."" "true" ."&" "false"])
          }
          { class call [."Path" ."Colour"]
          | :ok ", JuceClass::classes.c__"  (class)
          }
          { | :ok "" }
        )
        ")) return false;"=
      }
      splice ""
    )
    "                return source.done();"=
    "            }"=
    "        };"=
  }
  splice ""=
  .(
    "    struct ArgPass {"=
    "        static const KeyPress dummy_KeyPress;"=
    "        static const Justification dummy_Justification_centred;"=
    "        static const Justification dummy_Justification_horizontallyCentred;"=
    "        static const Colour dummy_Colour;"=
  )
  "    };"==
  "    const Colour ArgPass::dummy_Colour(0x00000000);"=
  "    const Justification ArgPass::dummy_Justification_centred(Justification::centred);"=
  "    const Justification ArgPass::dummy_Justification_horizontallyCentred"
  "(Justification::horizontallyCentred);"=
  "    const KeyPress ArgPass::dummy_KeyPress;"=
  ""=
}
