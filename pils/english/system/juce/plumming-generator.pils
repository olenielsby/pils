            "mixin__", "mixin__",
            "pils__", "pils__",
            "molested__", "molested__",
            "__", "::"] )
        "&)*(juce::"
        ( class *=*
          [ "extend__", "extend__",
            "mixin__", "mixin__",
            "pils__", "pils__",
            "molested__", "molested__",
            "__", "::"] )
        "*)mixins - (char *)mixins)"
      }
