{ .functions
| :ok
  ;classes @ [extract] classes;
  @ [extract] virtuals
  each
  { virtual: ..type .parameters .const
  | :tag [ugh]; :possibly
    "        bool on__" (virtual) "("
    ( type call
      { $ type | :ok (type) " &result" }
      { $ class, "*" | :ok (class) " *&result" }
      { "const", $ class, template-arguments: . $ type,
      | :ok "const " (class) "<" (type) "> &result"
      }
      { "const", $ class, "::", $ type | :ok (class) "::" (type) " &result" }
      { $ class, "::", $ type | :ok (class) "::" (type) " &result" }
      { "const", ok | :who :ok ' call (who) }
      { "void" | :ok () }
      .:need
      &
      ( parameters legs
        { n := type
        | :ok
          ;name "arg" ({} write: n);
          :need [ugh];
          type call
          { & ? | :try type splice " " .:need " " (name) }
          { $ ? | :ok (type) " " (name) }
        }
      )
      splice ", "
    )
    ")" (const call [."const" " const"; ""]) " {"=
    "            if (!who->when) return false;"=
    ( parameters legs {n := type|:ok arg: . "arg" ({} write: n) .type}
      each
      { arg: ..type? | :ok "toPils(" (arg) ")" }
      { arg: ..type "const", class, "&"
      | class call (classes) .:need and:
        :ok "JuceClasses::c__" (class) ".reference(&" (arg) ")"
      }
      { arg: ..type class, "&"
      | class call (classes) .:need and:
        :ok "JuceClasses::c__" (class) ".reference(&" (arg) ")"
      }
      { arg: ..type "const", class, "*"
      | class call (classes) .:need and:
        :ok "JuceClasses::c__" (class) ".reference(" (arg) ")"
      }
      { arg: ..type class, "*"
      | class call (classes) .:need and:
        :ok "JuceClasses::c__" (class) ".reference(" (arg) ")"
      }
      call
      {
      | :ok
        "            Empty::singleton.addReference();"=
        "            const Constant *operand = &Empty::singleton;"=
      }
      { arg,
      | :ok
        "            const Constant *operand = " (arg) ";"=
      }
      { args &: x > 1
      | :ok
        "            const Constant *args[] = {" (args splice ", ") "};"=
        "            const Constant *operand = ListConstant::get(args, "
        ({} write: x)");"=
      }
    )
    "            const Any *call = CallbackCliche::" (virtual)
    "->node(operand);"=
    "            const Any *pilsResult = pilsCall(call);"=
    ( type call
      { ?
      | :ok
        "            return fromPils(pilsResult, result);"=
      }
      { "void"
      | :ok
        "            return fromPils(pilsResult);"=
      }
      { "const", class, "::", "Ptr"
      | class call (classes) .:need and: :ok
        "            return fromPils(pilsResult,"-
        " (ReferenceCountedObjectPtr<ReferenceCountedObject>&)"-
        "result,"-
        " JuceClasses::c__" (class)
        ");"=
      }
      { class, "*"
      | class call (classes) .:need and: :ok
        "            return fromPils(fromPilsPtr(pilsResult, (void *&)result,"-
        " JuceClasses::c__" (class)
        "));"=
      }
      { "const", class
      | class call (classes) .:need and: :ok
        "            " (class) " *ptr;"=
        "            if (const Any *hold ="
        " fromPilsPtr(pilsResult, (void *&)ptr, JuceClasses::c__" (class) "))"=
        "            {"=
