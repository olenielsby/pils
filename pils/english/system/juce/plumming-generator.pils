;pairing
{ ok
| :ok ' fold
  { old := new | :ok list := old; new }
  { (arg: ..type "const", "void", "*" .value?)
    := (arg: . size .type "int" .value?)
  | :ok arg:. (') ", " (size) .type () .value ()
  }
  { (arg: ..type (array: class, "*") .value?)
    := (arg:. size .type "int" .value?)
  | :ok arg:. (') ", " (size) ", JuceClass::classes.c__" (class ) .type () .value ()
  }
  { (arg:. .type "const", "void", "*" .value?)
    := (arg:. size .type "size_t" .value?)
  | :ok arg:. (') ", " (size) .type () .value ()
  }
  { (arg:. .type (array: class, "*") .value?)
    := (arg:. size .type "size_t" .value?)
  | :ok arg:. (') ", " (size) ", JuceClass::classes.c__" (class ) .type () .value ()
  }
  .(:list ' :=)
}
{ | :ok () }
{ ok = (?,) | :ok }
{ .test | :try argtypes }
