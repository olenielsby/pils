><:[module:. job plumming juce extract methods .timestamp 2011-07-21T01:48:57.169+02 .language system]><;
(;methods) ===
{ .methods
| :ok
  ;classes @ classes
  .abstract @ abstract singles [ok]
  .replaced @ replaced
  .typeexpander @ typeexpander
  .exclude @ exclude methods
    groups
    { ok
    | :ok ' split "::" call
      { name = (value) 0 = ? 2 | :ok :name ' <-# 1 splice "::"; value }
      { name, value | :ok :name; value }
      { name, name | :ok :name; [ctor] }
    }
    **=** {class := ok|:ok ' singles [ok]}
  ;
  classes legs
  { class := =' = * class: .keyword? .members .bases
  | :ok
    ;typeexpander ' . class +++
      {ok =* ["::",]|:ok}
      {"const", ok|:who :ok "const" &: ok **=** who}
      {ok = "const" 0|:who :ok ' <-# 1 **=** who}
    .exclude ' . class or ()
    ;
    members
    except ([call: name] -> exclude)
    groups
    { name:. $ ' try [.["[", "]"] "item_" .ctor "ctor" .dtor "dtor"] .access;
      member
    | :try member call
      { constructor: .throw .parameters
      | class call (abstract) or:
        :ok
        :name "ctor";
        method: .name class
        .access .kind [ctor] .type (constructor: .class) .const ()
        .parameters ' **=** typeexpander
        .throw
      }
      { destructor: .throw .parameters () .kind
      | :ok
       :name "dtor";
        method:
        .name "~" (class)
        .access .kind [dtor] .type (destructor: .class) .const ()
        .parameters ()
        .throw
      }
      { constructor: .throw? .parameters (*;type "const", class', "&"),
      | :if class' = class; ?
      }
      { function: .throw .const .type .parameters .kind
      | :ok
        :name ' *=*
        ( "<", "_lt",
          ">", "_gt",
          "=", "_eq",
          "+", "_plus",
          "-", "_minus",
          "!", "_not",
          "%", "_percent",
          "&", "_ampersand",
          "*", "_asterisk",
          "/", "_slash",
          "^", "_upwards",
          "|", "_bar",
        )
        ;
        method:
        .name
        .access
        .kind
        .type ' **=** typeexpander
        .const
        .parameters ' **=** typeexpander
        .throw
      }
      { * ;parameters "..." 0 | ? }
    }
    { name: . "=" .access?; ? | ? }
    legs
    { nickname := method, | :ok (class: ..nickname) merge: method }
    { nickname := ++& methods
    | :ok methods reverse legs
      { n := method
      | :ok (class: ..nickname (') "__" ({} write: n)) merge: method
      }
    }
    splice
  }
  splice
  each
  { ok | :ok }
  { method:
    .nickname?
    .name?
    .access?
    .class "StringArray"
    .type?
    .const?
    .kind [ctor]
    .parameters ' <> []
    .throw?
  | ?
  }
  { method:
    .nickname?
    .name?
    .access?
    .class
    .type?
    .const?
    .kind [ctor]
    .parameters?
    .throw?
  | class call (replaced) .:need and: ?
  }
  { method:
    .nickname?
    .name?
    .access?
    .class "Font"
    .type?
    .const?
    .kind [ctor]
    .parameters
      [field: .type "const", "Typeface", "::", "Ptr", "&" .name "typeface"],
    .throw?
  | ?
  }
  { method:
    .nickname
    .name
    .access
    .class ' $* "pils__"
    .type
    .const
    .kind [ctor]
    .parameters
    .throw
  | :ok method:
    .nickname
    .name ' -#$* "pils__"
    .access
    .class
    .type
    .const
    .kind [ctor]
    .parameters
    .throw
  }
  { x = * method: .nickname "insertDrawable__2" | ? }
  order {*;class .nickname|:ok class, nickname}
}
