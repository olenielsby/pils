    "        CopyMethod__" (class) "(const JuceClassBase &class_, const char *name, ArgumentsThunk argumentsThunk, Thunk thunk, const JuceClass &resultClass)"=
    "            : ReferenceMethod(class_, name, argumentsThunk, thunk, resultClass)"=
