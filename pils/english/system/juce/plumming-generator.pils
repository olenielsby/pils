  [ typedef garbage
    .typedef "typedef " [*: [-: ";", "("] 1,] ";",
    .garbage [+: [-: typedef] 1,]
  ]
  each {[typedef], ok|:ok . -# 8 <-# 1 split " "}
  every
  { ok = (name) 0 | :ok name, ok <-# 1 splice " " }
  order {? $ ok, ?|:ok} reverse
}
