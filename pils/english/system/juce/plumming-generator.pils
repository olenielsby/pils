{ .lineage
| :ok
  @ [extract] baselines+mixed-extenders
  legs {? := ok|:ok} order {? & ok|:ok} reverse
  every {line|:ok line every {class|:ok :name class; line}}
  splice distinct [ok]
  distinct
  order {line & count|:ok count, line}
  first 0 fold {at := line & n|:ok list := (at: .; line); at + n} .:list
  call
  { lineage
  | :ok lineage:. ' every [call:] splice
    .index
    lineage every
    { at: .; line | :ok line every {class|:ok :name class; at} }
    splice
    firsts [ok]
  }
}
