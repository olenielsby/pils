{ .extenders
| :ok
  ;extend-mixins @ [extract] extend-mixins;
  ;methods @ [extract] methods;
  ;extenders @ [extract] extenders
  .constructors methods groups
    { * ;class .kind [ctor] .parameters .throw
    | :ok :name class; ctor: .parameters .throw
    }
  .throwing-destructors
    methods each {* ;class .kind [dtor] .throw [throw]|:ok class}
    singles [ok]
  .private @ [extract] classes
    **=**
    { ? := *;members ok
    | :ok ' each {name: . ok .access "private"; ?|:ok} firsts [ok]
    }
  .unbased @ exclude basecall singles [ok]
  ;
  @ [extract] classes cliche legs order [ok]
  each
  { class
  | ;extenders ' .(:need class call:)
      except ([call: virtual] -> class call (private))
      every {ok|:ok ' .(base: . class;)}
      &
      ( class call:
        [ok:] +++:
        extend-mixins ->
        { base
        | :ok base call (extenders) or () every {ok|:ok ' .(base: .;)}
        }
      )
!      distinct [call:]
    .constructors ' .(:need class call:)
    ;
    :ok
    ;base class *=* ["mixin__" "mixin__" "pils__" "pils__" "__" "::"];
    "    class extend__" (class) " : public " (base)
    (class call (extend-mixins -> {ok|:ok ' .(", public ")}) or "")
    ", public CallbackHelper {"=
    "    public:"=
    ( constructors every
      { ctor: .parameters .throw
      | :ok
        "        extend__" (class) "("
        ( parameters every
          { field: .type .name
          | :ok type listwise call
            { & try | :try ' splice & name splice " " .:need }
          }
          { field: .type .name .value
          | :who :ok (field: .type .name) call (who) " = "
             (value every {ok|:ok} {?, $ ok|:ok} {name: . ok|:ok} splice " ")
          }
          splice ", "
        )
        ") "
        ( throw call [.throw "throw () "; ""] )
        ": " (base) "("
        ( parameters every [call: name] splice ", " )
        ") {}"=
      }
      &
      ( class call (throwing-destructors)
        and ("        ~extend__" (class) "() throw () {}"=)
        or:
      )
      splice "" 
    )
    ( extenders
      order
      { base: .?; virtual: . ok .type? .const? .parameters .throw?
      | :ok ', parameters count, {} write (parameters)
      }
      every
      { base: .; virtual: ..type .const .parameters .throw
      | :ok
        ;parameters ' legs {n := type|:ok name: . "arg" ({} write: n) .type}
        .type ' call
        { $ ok | :ok }
        { & ok | :who :ok ' every (who) splice " " }
        { template-arguments: .
        | :who :ok "< " (template-arguments every (who) splice ", ") " >"
        }
        ;
        ;names parameters every [call: name];
        "        " (type) " " (virtual) "("
        ( parameters every
          { name: ..type
          | :ok
            type call
            { & ok
            | :ok ' every
              { $ ok | :ok }
              { & ok | :who :ok ' every (who) splice " " }
              { template-arguments:. ok | :who :ok ' call (who) .("<") ">" }
              splice " "
              " " (name)
            }
            { $ ok | :ok (') " " (name) }
          }
          splice ", "
        )
        ") "
        ( const call [."const" "const "; ""] )
        ( throw call [.throw "throw () "; ""] )
        "{"=
        ( type call
          { ?
          | :ok
            "            " (type -#$* "const ") " result;"=
            "            if (on__" (virtual) "(" ("result" & names splice ", ") "))"=
            "                return result;"=
            "            else return "
            (base *=* ["mixin__" "mixin__" "pils__" "pils__" "__" "::"])
            "::" (virtual)
            "(" (names splice ", ") ");"=
          }
          { "void"
          | :ok
            ;base (') "::" (virtual) .call "on__" (virtual) "(" (names splice ", ") ")"
            ;
            base call (unbased) and ("            " (call) ";"=) or:
            "            if (!" (call) ")"=
            "            " (base) "(" (names splice ", ") ");"=
          }
        )
        ( :if virtual = "visibilityChanged" .else "";
          "            helper__visibilityChanged();"=
        )
        "        }"=
      }
      splice ""
    )
    "        juce_UseDebuggingNewOperator"=-
    "    };"==
  }
  { ? $* "molested__" | ? }
  splice ""
}
