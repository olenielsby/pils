| :ok
  :if platform ask ok [. generate binding files];
  ;start now;
  platform say:
  @ [job plumming juce] generate
  groups {(name) (;: value)|:ok :name; value}
  legs
  { name := files
  | :ok say (name) ":"="  " (files splice ""="  ") ""=
  }
  splice ""=
  call {ok|:ok (') ""="(" ({} write: now - start) ")"}
}
