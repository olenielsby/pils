      " const String &", " String &",
      " String &", " String &",
      "&", "*&",
      " void", " no ",
      "", " &"
    )
    "result) {"=
    "            "
    ( type call
      { ? | :ok "result = " }
      { "&" 0 | :ok "result = &" }
