><:[module:. job plumming juce extract abstract .timestamp 2011-07-21T01:50:22.279+02 .language system]><;
(;abstract) === 
{ .abstract
| :ok
  @ classes **=**
  { class := class: .members .keyword? .bases
  | :ok
    class: .bases ' each
    {base: .access? .name ok|ok call (@ classes) .:need and: :ok}
    ;
    members singles
    { name:. '  <> [operator] .access?;
      function:
      .kind ' call [."inline"? ."virtual" .0;]
      .const .type? .throw? .parameters
    | :ok
      :name
      ( signature: .name .const
        .parameters ' every: [ok] +++ [call: type]
      )
       ;
       kind
    }
  }
  again
  { classes
  | :ok
    classes **=**
    { class := class: .bases; signatures
    | :ok
      class: .bases;
      bases each (classes) every {class: .bases?; ok|:ok} & signatures
      every {ok|:ok ' legs {name := value|:ok :name; value}} splice lasts [ok]
    }
  }
  legs
  {class := class: .bases?; try|:try ' legs {? := 0|:ok class} find [ok]}
  order [ok]
}
><:[module:. job plumming juce extract arglists .timestamp 2011-07-21T01:42:28.543+02 .language system]><;
(;arglists) ===
{ .arglists
| :ok
  ;classes @ classes .enums [ok:] +++ (@ enums);
  @ prune-overrides
  groups
  { * ;parameters .class .access "public"
  | :ok
    parameters every
    { (field: .type .name? .value) anyway [.value?]
    | :ok
      field: .type
      ' listwise splice try
      { inner, "*"
      | ;outer class -#$* "pils__" +#^* "__";
        (outer) "__" (inner) call (classes) .:need and:
        :ok outer, "::", inner, "*"
      }
      { inner, "*"
      | ;outer class -#$* "pils__" <-#=* "__";
        (outer) "__" (inner) call (classes) .:need and:
        :ok outer, "::", inner, "*"
      }
      { ok = (class, "*") | class call (classes) .:need and: :ok }
      { ok $* ["JUCE_NAMESPACE", "::"] | :who :ok ' -# 2 try (who) }
      { "const", class, "*" | class call (classes) .:need and: :ok class, "*" }
      { "const", inner, "&"
      | ;class ' +#^* "__" "__" (inner);
        class call (classes) .:need and: :ok ref: class, "*"
      }
      { "const", class, "&"
      | class call (classes) .:need and: :ok ref: class, "*"
      }
      { class, "&" | class call (classes) .:need and: :ok ref: class, "*" }
      { class, "*", "*" | class call (classes) .:need and: :ok array: class, "*" }
      { class, "::", enum | enum call (class call: enums) and: :ok "int", }
      { "const", class, "::", enum
      | enum call (class call: enums) .:need and: :ok "int",
      }
      { "const", class, "::", inner-class, "&"
      | ;class (') "__" (inner-class); class call (classes) .:need and: :ok ref: class, "*"
      }
      { "const", class, "::", enum, "&"
      | enum call (class call (enums) .:need) .:need and: :ok "int",
      }
      { "const", "unsigned", type call [."int"] | :ok "unsigned", type }
      { "const", n, (t = template-arguments: .?), "&" | :ok n, t }
      try
      {ok,|:ok}
      {"const", ok|:ok}
      .value ' listwise try
      { (ok = name: .),
      | :try
         class call (classes) members
         each {name: .? .access "public"; enum: .|:ok enum every [call: name]}
         splice
         find {name'|:if name = name'; :ok class, "::", ok}
      }
    }
  }
}
><:[module:. job plumming juce extract attributes .timestamp 2011-07-21T02:11:39.598+02 .language system]><;
(;attributes) ===
{ .attributes
| :ok
  ;classes @ classes
  .replaced @ replaced
  .typeexpander @ typeexpander
  .exclude @ exclude attributes
    groups
    { ok
    | :ok ' split "::" call
      { name, value | :ok :name; value }
      { name, name | :ok :name; [ctor] }
    }
    **=** {class := ok|:ok ' singles [ok]}
  ;
  classes legs
  { class := =' = * class: .keyword? .members .bases
  | :ok
    ;typeexpander ' . class +++
      {ok =* ["::",]|:ok}
      {"const", ok|:who :ok "const" &: ok **=** who}
      {ok = "const" 0|:who :ok ' <-# 1 **=** who}
    .exclude ' . class or ()
    ;
    members
    except ([call: name] -> exclude)
    singles
    { name: ..access ' call [."public"]; field: .type
    | :ok :name; type **=** typeexpander
    }
    legs
    { name := type
    | :ok field: .class .name .type ' try
