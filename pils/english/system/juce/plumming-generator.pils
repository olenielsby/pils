      )
      ", "
      ( {} write: class call (baselines) count - 1 )
      ", JuceClass::lineages+" ({} write: class call: lineage index)
      ", delete_::d__"
      ( class -#$* "extend__" call (deleters) try [.none "none"] )
      ( mixins find
        { mixin: ..at; ? & count
        | :if mixin = class;
          :ok ", " ({} write: count) ", JuceClass::mixins+" ({} write: at)
        }
        or ", 0, NULL"
      )
      ");"=
    }
    splice ""
  )
""=
  "    const JuceClass *const JuceClass::lineages[] = {"=
  ( lineage lineage
    legs
    { n := class
    | :ok "        &JuceClasses::c__"
      ( class *=* ["::" "__"]
        try [."ElementBase" "RelativePointPath__ElementBase"]
      )
      ({} write (n - 1) call {?|:ok ""} {ok <$* "0"|:ok " /*" (ok) "*/"})
    }
    splice ","=
