class BigInteger
{
	BigInteger& operator&= (const BigInteger& other);
	BigInteger& operator^= (const BigInteger& other);
	BigInteger& operator%= (const BigInteger& other);
	BigInteger& operator<<= (int numBitsToShift);
	BigInteger& operator>>= (int numBitsToShift);
	BigInteger& operator++();
	BigInteger& operator--();
	const BigInteger operator++ (int);
	const BigInteger operator-- (int);
};
><:[module:. job plumming juce parse split .timestamp 2011-07-21T01:37:57.798+02 .language system]><;
{ $ ok
| :ok ' split
  [ directive-start
    space
    linefeed
    include-head
    include-filename
    string-literal
    character-literal
    ellipsis
    floating-literal
    integer-literal
    include-keyword
    directive-keyword
    identifier
    separator
    operator
    preprocessor-concat
    preprocessor-stringize
    .linefeed ""=, ""/, ""<
    .space [+: " ", "">, "/*" [*: [-: "*/"] 1,] "*/", "//" [*: [-: linefeed] 1,]]
    .identifier ["A-Z", "a-z", "_", "$"] [*: "A-Z", "a-z", "_", "$", "0-9"],
    .directive-start [/: $ linefeed] [*: " ", "">] "#" [-: "#"] [*: " ", "">],
    .directive-keyword [/: directive-start] identifier,
    .include-keyword
      [/: directive-start] "include"
      [-: "A-Z", "a-z", "_", "$", "0-9"] [*: " ", "">],
    .include-filename
      [/: include-keyword]
      [ """" [+: [-: """" linefeed] 1,] """", "<" [+: [-: ">" linefeed] 1,] ">" ]
      [ -: -: [space, []] linefeed, ]
      ,
    .string-literal ["L" []] """" [*: [-: """"] string-character,] """",
    .character-literal ["L" []] "'" [-: "'"] string-character "'",
    .string-character
      [-: "\"] 1,
      "\"
      [ "'", """", "?", "\", "a", "b", "f", "n", "r", "t", "v",
        octal-digit [octal-digit [octal-digit [],], []],
        "x" [+: hexadecimal-digit],
        "u" hex-quad,
        "U" hex-quad hex-quad
      ],
    .integer-literal
      [ "1-9" [*: "0-9"],
        "0" [["X", "x"] [+: hexadecimal-digit], [*: octal-digit]]
      ]
      [ ["U", "u"] ["ll", "l", "LL", "L", []],
        ["ll", "l", "LL", "L", []] ["U", "u", []]
      ]
      ,
    .floating-literal
      [ [ +: "0-9" ] [ "." [*: "0-9"] [exponent-part, []], exponent-part ],
        "." [+: "0-9"] [exponent-part, []]
      ]
      [ "f", "l", "F", "L", [] ]
      ,
    .exponent-part ["e", "E"] ["+", "-", []] [+* "0-9"]
    .hexadecimal-digit "0-9", "a-f", "A-F"
    .hex-quad
      hexadecimal-digit hexadecimal-digit
      hexadecimal-digit hexadecimal-digit,
    .octal-digit "0-7"
    .ellipsis "..."
    .operator
      ["!", "%", "*", "/", "=", "^"] ["=", []],
      "&" ["&", "=", []],
      "|" ["|", "=", []],
      "+" ["+", "=", []],
      "-" ["-", "=", ">*", ">", []],
      "." ["*", []],
      ":" [":", []],
      "<" ["<", []] ["=", []],
      ">" [">", []] ["=", []],
      "?" [-: "?" ["'", "!", "/", "<", ">", "(", ")"],],
      "~"
    .preprocessor-concat "##", "%:%:"
    .preprocessor-stringize "#", "%:"
    .separator "<%", "%>", "<:", ":>"
  ]
}
