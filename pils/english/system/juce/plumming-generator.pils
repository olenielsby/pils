><:[module:. job plumming juce generate declarations methods .timestamp 2011-07-21T02:18:08.181+02 .language system]><;
{ .methods
| :ok
  ;classes @ [extract] classes
  .enums @ [extract] enums
  .arglists @ [extract] arglists
  .ifdef @ ifdef
  ;
  arglists legs
  { ? := methods = (*;nickname .class) 1
  | :ok
    ;signature (class) "__" (nickname);
    methods each
    { method:
      .access "public"
      .class
      .name
      .nickname
      .kind ' <> [dtor]
      .type
      .const?
      .parameters?
      .throw
    | :ok
      method: . nickname .class .name .kind .type .signature
      .throw
    }
  }
  { () := methods
  | :ok
    ;signature "NoArguments";
    methods each
    { method:
      .access "public"
      .class
      .name
      .nickname
      .kind ' <> [dtor]
      .type
      .const?
      .parameters?
      .throw
    | :ok
      method: . nickname .class .name .kind .type .signature
      .throw
    }
  }
  splice &
  ( @ [extract] attributes every
    { field: .class .name .type
    | :ok method: . name .class .name .kind [get] .type
      .signature "NoArguments"
      .throw ()
    }
  )
  groups [call: class]
  legs {? := ok|:ok}
  order {(*;class ok) 1|:ok}
  every
  { methods = (*;class) 1
  | :ok
    methods
    except 
    { method: .? .class ? $* "molested__" .name? .kind [ctor]
      .type? .signature? .throw?
    | :ok ()
    }
    order [call: method]
    every
    { method: ..class .name .kind .type .signature .throw
    | :ok
      ;ifdef ' ((class) "__" (method)) or ();
      (ifdef begin)
      "        " (@ type (..class .name) try {ok, ?|:ok}) " " (method) ";"=
      (ifdef end)
    }
    splice ""
    .(
      "    class " (class) "__methods {"=
      "        static " (class) "__methods singleton;"=
      "        " (class) "__methods();"=
    )
    "    };"==
  }
  splice ""
}
===
{ : $ symbol begin | :ok "#ifdef " (symbol) ""= }
{ : $ symbol end | :ok "#endif /*" (symbol) "*/"= }
{ : & symbols begin
| :ok
  "#if " (symbols every {symbol|:ok "defined(" (symbol) ")"} splice " || ")
  ""=
}
{ : & symbols end | :ok "#endif /*" (symbols splice "||") "*/"= }
{ : () (? call [.begin .end]) | :ok "" }
