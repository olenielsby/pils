      { & ok | :who :ok ' every (who) splice " " }
      { [integer-literal], ok | :ok }
      { template-arguments: .
      | :who :ok
        "<"
        (template-arguments every (who) splice ", " <$*=*: ">", "> ")
        ">"
      }
      { constructor: .class
      | :ok "juce :: " (class *=* ("pils__", "pils__", "__", "::")) " *"
      }
      { constructor: .class
