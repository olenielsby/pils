  { language-library: .language-name
  | :ok
    bootfilename <-#^* "/pils/"
    (language-name) "/system/" (language-name) "."
    [pils-configuration:pils-filetype]
  }
  { .editor-filename
  | :ok bootfilename <-#^* "/" . "editor." [pils-configuration:pils-filetype]
  }
  { .icons-filename
  | :ok bootfilename <-#^* "/" . "icons." [pils-configuration:pils-filetype]
  }
  { .bugpinner-filename
  | :ok bootfilename <-#^* "/" . "bugpinner." [pils-configuration:pils-filetype]
  }
  { encode: $ ok
  | :ok ' *=* ["\", "/"]
    try
    { (ok)
    | ;ok ' <-#$* ("." [pils-configuration:pils-filetype]);
      :if ok <+#-* "/" =* "." = 0; :ok
    }
    $*=*: encodings
  }
  { decode: $ ok
  | :ok ' $*=* decodings try
    { (ok)
    | :if ok <+#-* "/" =* "." = 0; :ok (') "." [pils-configuration:pils-filetype]
    }
  }
  { .encodings | :try encodings }
  { .decodings | :try decodings }
  ===
  { .decodings
  | :self :ok self encodings split 2 every {(a, b)|:ok b, a} splice
  }
  { .encodings
  | :ok
    bootfilename <-#^* "/pils/", "<pils>/",
    [pils-configuration:configuration-directory], "<config>/",
    [pils-configuration:documents-directory], "<doc>/",
    path <-#^* "/", "<.>/",
    path <-#=* "/" <-#^* "/", "<..>/",
    bootfilename <-#=* "/pils/" "/app/", "<app>/",
  }
}
><:[module:. pils system program .timestamp 2026-07-17T16:09:42.497+02 .language system]><;
!!
