:quote
{ delete: .module-name
| :self :who
  :if self = who;
  ;ruleset self call {::ruleset ok .where?|:ok} .:need;
  ;library-node ' without (module-name);
  ( channel: pils-library-changed: library-filename )
  ( changed: .library-filename .module-name .listen
    (channel: pils-library: library-filename) listen:
    ruleset --- :
    ;library-filename
    .library-node
    .timestamp
    .library-language
    .bootfilename
  )
  or:
  :ok library-node
}
{ changed:. .module-name
| :self :who
  :if self = who;
  ;ruleset self call {::ruleset ok .where?|:ok} .:need;
  ;library-node ' merge (module-name, changed);
  ( channel: pils-library-changed: library-filename )
  ( changed: .library-filename .module-name .listen
    (channel: pils-library: library-filename) listen:
    ruleset --- :
    ;library-filename
    .library-node
    .timestamp
    .bootfilename
    .library-language
    :if module-name = [] .else library-language;
    changed call
    { * ;language ' = ?:? // $ language-name
    | ;language-library
        bootfilename <-#^* "/pils/"
        (language-name) "/system/" (language-name) "."
        [pils-configuration:pils-filetype]
      ;
      (channel: pils-library: language-library) node .:need
      .(([pils], [language], language) call) .:need
      call
      { * module:. | :try {} read (module) or () call {(ok) language|:ok} }
      .:try
    }
    or {}
  )
  or:
  :ok library-node
}
{ .header | :ok library-node? }
{ .modules | :ok library-node legs {(a) := b|:ok a, b} {() := ?|?} }
{ .node | :ok library-node }
{ .header := = changed | :self :ok self changed:. .module-name [] }
{ = +& module-name := changed = * module:. $?
| :self :ok
  self changed:. .module-name
}
{ = +& module-name := [] | :self :ok self delete: .module-name }
{ .library | :who :ok who }
{ = +& module-name
| :possibly
  module:. module-name call (library-node) .:need
  .library library-filename
  .module-name
}
{ .library-language |:ok library-language }
{ language: .module-name +& '
| :try @@ (module-name call (library-node) .:need language or :ok {})
}
><:[module:. pils system library-list .timestamp 2026-07-17T15:55:51.749+02 .language system]><;
!!
