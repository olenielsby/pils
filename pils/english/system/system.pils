;depend (channel: pils-dependency: .thread ' or [dummy-thread]);
knot:
{ $ program-filename | :ok strap (program: program-filename) }
->
;[@@: pils system base] .[@@: pils system library-list];
{ (program-strap) = strap: program: $ program-filename
| :self
  :try self program:
  .program-filename
  .libraries @@ [pils system library-list] . program-filename .:need every
  { library:. .filename .why
  | :ok
    library:. .filename .why .changing
    (channel: pils-library-changed: filename) listen (program-strap)
  }
}
{ program: .program-filename .libraries
| :self :ok
  ;program-strap strap (program: program-filename);
  ;program-language
    (channel: pils-library: program-filename) library-language
  .command-line-processor
    [channel: pils: command-line] listen
    { (command-line)
    | :ok [pils system start] call (program-strap) instance command-line: .
    }
  .draw [ok] +++ depend -> program-strap -> {* ;instance ok|:ok}
  ;
  program-strap? :=
  ( knot:
    { .existing-program | :ok :call program-strap }
    { .library-list | program-strap call (self) anyway: }
    { .libraries
    | :ok
      libraries every {* library: .filename .why|:ok library: .filename .why}
    }
    { changed: .module-name .library-filename .listen
    | ;bound program-strap?;
      ;program-strap ' try (self);
      ;dependencies
        bound legs
        { (depend) := *;dependencies
        | :ok dependencies legs {(name) := ?|:ok :name; depend}
        }
        splice groups [ok]
      ;
      ;invalid
        ( (firsts:),
          module-name try {(ok)|:ok (ok,) firsts [ok]} {|?} {[firsts] *?|?}
        )
        repeat
        { (done, * more)
        | :ok
          done merge (more),
          more cliche legs each (dependencies) splice except (done)
          firsts [ok]
        }
        call {(ok,,)|:ok}
      ;
      bound legs {(name) := value | name call (invalid) or: :ok :name; value }
      singles [ok]
      try {* b|:ok program-strap? := b head () merge: , program-strap?}
      and:
      (channel: pils-program: program-filename)
      changed (.module-name .library-filename)
      anyway:
    }
    { (internal-name) = basemodule: . = +& module-name .library
    | :try
      libraries every [call: filename] -#^* (library,) --# 1
      every {(filename)|:ok channel: pils-library: filename}
      each (call: module-name)
      find: module-maker (.internal-name)
    }
    { = +& module-name
    | :try
      libraries every {(library)|:ok channel: pils-library: library filename}
      each (call: module-name)
      find: module-maker (.internal-name module-name)
    }
    ===
    { module-maker: .internal-name
    | :ok
      { module: . ' = * (module:. +$ module-text) .library .module-name
      | ;entry
