><:[module:. ===, .timestamp 2026-07-17T15:31:40.656+02 .language system]><;
!!
The rules of this module are available to all modules except the
[pils system ...] ones.

Edit with care - the bug pinning depends on this module, so bugs
here may not be pinned.
!!

{ : object list
| :possibly
  object count .:need call {(ok) count|:ok} .:need up every (object)
}
{ : object list: step
| :ok object repeat {(ok)|list := step call (ok) or (?); :ok} .:list
}
{ .user | :ok @@ [pils user] }
{ say: say | :ok {} write: say }
{ saying: say | :ok {} write: say }
{ say: $ ok | :ok }
{ saying: $ ok | :ok }
{ saying: say | :who ' user .:need talk .:need saying (say) .:try }
{ say: say | :who ' user .:need talk .:need say (say) .:try }
{ saying: say | :who ' user .:need talk .:need saying (say) .:try }
{ (text) ([upper] // replace) | :try text *=* replace .:need upper }
{ (text) ([lower] // replace) | :try text *=* replace .:need lower }
{ (text) ([title] // replace) | :try text $*=* replace .:need title }
{ : filename @@@: = +& module-name
| :try module-name call:
  filename call (@@ [pils system program]) .:need -> [call: instance]
}
{ :error .who .module
| :where :what
  :try @@ [pils run error] error:. .who .what .where .module
}
{ : object find (filter) | :try [items] call (object) .:need find (filter) }
{ : object each (filter) | :try [items] call (object) .:need each (filter) }
{ : object every (filter) | :try [items] call (object) .:need every (filter) }
{ language: .module-name +&? .library $? | :ok {} }
{ language: .module-name = +& ' .library $ '
| :try
  module-name call ((channel: pils-library: library) node) .:need
  language .:need
  call
  { (language)
  | :ok 
    module-name count down 0 every
    {(n)| :ok module-name +# n & [pils language] & language}
  }
  { [system] | :ok {} }
  find {(module-name)|:try @@ (module-name)}
}
{ language: .? .module-name +&? .library $? | :ok {} }
{ language:. .module-name = +& ' .library $ '
| :try
  module-name count down 0
  find {(n)|module-name +# n & [pils language] & language .(@@) .:try}
}
{ language: . [system] .module-name +&? .library $? | :ok {} }
{ .platform
| :ok @ ([platform [?:?|pils-configuration:platform] entry])
}
{ datafile: $ filename
| :possibly file (filename) try (channel: pils-dependency: .thread ' or [dummy-thread])
}
{ .datafile-check
| :ok
  (strap: program: this program filename)?
  legs
  { +& name := * ;dependencies * '
  | dependencies legs
    { (file file: ?) := timestamp
    | (file timestamp .:need, timestamp) call {(ok, ok)|:ok} or:
      :ok name
    }
    find [ok] .:try
  }
  singles [ok]
  try {* module|:ok @@ [pils system changed] changed: .module}
}
===
{ .user | :ok @@ [pils user] }
