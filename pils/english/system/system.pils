><:[module:. pils system base .timestamp 2026-07-17T15:37:40.767+02 .language system]><;
!!
Edit with care - everything depends on this module.
PILS should be restarted and tested after each edit.
!!

{ base:
  .expression
  .language
  .library
  .module-name
  .program-strap ' = (strap: program: program-filename)
  .module-header
  .module-text
  .bootfilename
  .program-language
| :ok
  ;draw
    { (module-name)
    | module-name try (channel: pils-dependency: .thread ' or [dummy-thread])
      call (program-strap) .:need
      call {* ;instance ok|:ok} .:try
    }
  .same (module-name,) singles [ok]
  .module
  ( module:
    .name module-name
    .language
    .expression
    .header module-header
    .text module-text
    .filename library
    .path library <-#^* "/"
    .channel channel: module:. module-name .program program-filename
  )
  ;
  ;module-paths
    module-name count down 0 each
    {(n)|:ok module-name +# n}
  .names ()
  ;
  :;@@
  ( { / name
    | :try module-paths every {(ok)|:ok ' & name} except (same) find (draw)
    }
    { = & names
    | :try module-paths every {(ok)|:ok ' & names} except (same) find (draw)
    }
  )
  .@
  ( { / name * node
    | :try node call: :need
      module-paths every {(ok)|:ok ' & name} except (same) find (draw)
    }
    { / name * node :=
    | :try node call
      ( :need
        module-paths every {(ok)|:ok ' & name} except (same) find (draw)
      )
      :=
    }
    { / name
    | :try name call: :need
      module-paths every {(ok)|:ok ' & name} except (same) find (draw)
    }
    { / name :=
    | :try name call
      ( :need
        module-paths every {(ok)|:ok ' & name} except (same) find (draw)
      )
      :=
    }
  )
  .this
  ( this:
    .module
    .program
    ( program:
      .path program-filename <-#-* "/"
      .filename program-filename
      .libraries program-strap libraries
      .language program-language
      .channel (channel: pils-program: program-filename)
      .mind
      { = name | :try name call: strap? }
      { = name := ok
      | :ok ' try: knot:
        { (?) | strap? := strap? merge: name, ok }
      }
      { | :ok strap? }
      .:quote --- ;strap strap: mind: program: program-filename
      
    )
  )
  ;
  { | :try draw basemodule:. module-name .library }
  { .bootfilename | :ok bootfilename }
  { .plumcake | :ok plumcake }
  { @@: = +& module-name | :try module-name call (draw) }
  { @: = names
  | :ok
    { / name * node
    | ;names ' & name;
      :try node call: :need
      module-paths every {(ok)|:ok ' & names} except (same) find (draw)
    }
    { / name * node :=
    | ;names ' & name;
      :try node call
      ( :need
        module-paths every {(ok)|:ok ' & names} except (same) find (draw)
      )
      :=
    }
    { / name
    | ;names ' & name;
      :try name call: :need
      module-paths every {(ok)|:ok ' & names} except (same) find (draw)
    }
    { / name :=
    | ;names ' & name;
      :try name call
      ( :need
        module-paths every {(ok)|:ok ' & names} except (same) find (draw)
      )
      :=
    }
  }
  { module: +& = module-name
  | :try
    module-name call (program-strap) .:need basement .:need
    this .:need
    module
  }
  { :error? | :ok [error] }
  { :error
  | :who :where
    :try (::error .who .module) call (where)
  }
  { write: x | :try language write: x }
  { read: x | :try language read: x }
  { indent: x | :try language indent: x }
  { traceread: x | :try language traceread: x }
  +++ plumcake
}
><:[module:. pils system boot .timestamp 2026-07-17T16:48:28.870+02 .language system]><;
!!
Edit with care - everything depends on this module.
PILS should be restarted and tested after each edit.
!!

!!
The boot module sets up a simple instantiation mechanism
that allows the system modules to reference each other
!!
{ boot: .filename .text
| :where :ok
  text -#$* ""efbbbf split "><.:"
  every
  { (ok)
  | :ok ' split "><.;"
    every {(ok)|:ok ' -#$* ""= *=* ["><..", "><."]}
    legs:
    { (?) := ok | :ok }
    { 1 := ok | :ok ' .({} read) }
    ===
    { :error error: . .start .end
    | (text +# start)
      "<start>" (text +# end -# start) "<end>"=
      ({} name: error)
      bug {}
    }
  }
  firsts
  { (program-header,) | :ok :name (); program-header }
  { (module) = (* module: . name), text
  | :ok :name; module merge: module:. text
  }
  { (module) = (* module: . name $* [pils system]), text
  | :ok :name; module merge: module:. text; {} read (text)
    ===
    { :error error:. .start .end
    | text +# end . "<SYNTAX ERROR>" bug {}
    }
  }
  call
  { (library-node)
  | :ok
    { @@: & module-name
    | :who
      :try module-name call (library-node) or () call
      { * module: .; body
      | :ok body ---: where +++ :
        ;@@
          module-name call
          { (module-path)
          | :who [module-path];
            :ok
            { = relative-name | :try who @@: module-path & relative-name }
            { | :try module-path <-# 1 call (who [module-path]) }
          }
          { | ? }
        .program (;filename .path filename <-#^* "/" .language {})
        .bootfilename filename
        .this (;program ;filename .path filename <-#^* "/" .language {})
        ;
        who
      }
    }
    try
    { (system)
    | strap [system: boot]? := (channel: pils-library: filename) listen:
      system @@ [pils system library] ---:
      ;library-filename filename
      .library-node
      .timestamp now
      .bootfilename filename
      .library-language {}
    }
  }
  @@ [pils system program]
  (filename)
  [pils system start]
  try [call: instance]
  start
}

===
{ :error
| :what
  "********************************ERROR*******************************" bug {} and:
  (what: .; error) bug {}
}
><:[module:. pils system changed .timestamp 2026-07-17T15:47:28.290+02 .language system]><;
!!
Edit with care - everything depends on this module.
PILS should be restarted and tested after each edit.
!!

;program-strap (strap: program: this program filename);
knot:
{ changed: .module
| :ok
  ;dependencies
    program-strap?
    call {() * ok|:ok} or ()
    legs
    { (value) := *;dependencies ok
    | :ok ' legs {(name) := ?|:ok :name; value}
    }
    splice groups [ok] **=** {(?) := ok|:ok ' firsts [ok]}
  ;
  (,module try {(ok)|:ok (ok,) firsts [ok]} {|?} {(?) call [.firsts .singles] *?|?})
  repeat
  { (done, * more)
  | :ok
    done merge (more),
    more
    cliche legs
    each (dependencies)
    each {* ok|:ok ' cliche legs}
    splice except (done) firsts [ok]
  }
  call
  { (changed,,)
  | :ok :exit
    program-strap? :=
    program-strap? try {knot: ?|exit := ()}
    legs {(name) := value|name call (changed) or: :ok :name; value}
    singles [ok] head () try {;: ok|:ok}
    ;
  }
}
><:[module:. pils system librarian .timestamp 2026-07-17T15:51:36.531+02 .language system]><;
!!
Edit with care - everything depends on this module.
PILS should be restarted and tested after each edit.
!!

;[@@: pils system library];
!!
This structure is shared by all systems using a library.
A file-specific channel (channel: pils-library: filename)
is used for registering the latest version of the library
node. A parallel channel (channel: pils-library-changed: filename)
is used to notify programs of changes.
!!
{ $ library-filename
| :self
  :if library-filename =* "\" = 0;
  (channel: pils-library: library-filename) library .:try anyway:
  ;library-file-text file (library-filename) text .:need;
  ;segments
    library-file-text
    -#$* ""efbbbf ! notepad-compatibility - bogus endian marker
    split "><.:"
    every
    { (segment)
    | :ok
      segment split "><.;"
      every {(part)|:ok part -#$* ""= *=* ["><..", "><."]}
    }
  ;
  ;header segments call {(text,) 1|;ok {} read (text) or (?); :ok};
  ;library-language
    header call
    { * ;language ' = ?:? // language-name
    | ;language-library
        @@ [pils system path] language-library (.language-name)
      ;
      ;keep language-library call (self) .:need;
      (channel: pils-library: language-library) node .:need
      .([pils language] & language call) .:need
      call
      { * module: . | :try {} read (module) or () call {(ok) language|:ok} }
      { * ;language | language singlewise call [system:.] or: ? }
      .:try
    }
    { * ;language ok language | :ok }
    or {}
  ;
  ;modules
    segments -# 1
    every
    { (module-header, module-text)
    | :try
      library-language read (module-header) or (?)
      call
      { (module-head) = = * module:. +& module-name
      | :ok
        module-name,
        module-head merge: module:. module-text
      }
    }
    .:need
  ;
  :ok
  ;library-node
    modules first (, header) firsts {(name, value)|:ok :name; value}
  ;
  (channel: pils-library: library-filename) listen:
  @@ [pils system library] ---:
  ;library-node
  .library-filename
  .timestamp now
  .library-language
  .bootfilename
}
><:[module:. pils system library .timestamp 2026-07-17T15:57:55.004+02 .language system]><;
!!
Edit with care - everything depends on this module.
