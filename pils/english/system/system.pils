@@ [pils talk system]
><:[module:. pils talk system .timestamp 2026-07-17T16:12:53.811+02 .language system]><;
{ say: say
| :who ' saying (say) .:need title .:try }
{ saying: try
| :who
  ;language user .:need language .:need;
  :try ' call
  { (try) | language write (try) .:need ++# 100 .:try }
  { = try | :try language write (try) .:need -#$* "[" <-#$* "]" ++# 100 }
  { / name | :try language name (name) }
  { $ text | :ok text }
  { +& q | :self :try q every {(say)|:try who saying: say} .:need splice " " }
  { ++& list
  | :self
    (list . 1 call (self) .:need)
    (list +# 2 find {$ ?|:ok ""} or " ") .:need
    (list -# 1 call (self) .:need)
    .:try
  }
}
