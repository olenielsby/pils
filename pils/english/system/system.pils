;[@@: pils system librarian] .[@@: pils system path];
{ $ program-filename
| ;program-library @@ [pils system librarian] . program-filename .:need;
  :ok
  ( ( system: @@ [pils system path] editor-filename &: bootfilename or: ),
    ( system: @@ [pils system path] bugpinner-filename &: bootfilename or: ),
    ( system: @@ [pils system path] icons-filename &: bootfilename or: ),
    ( platform:
      [platform-filename platform-program-filename]
      every: @@ [pils system path]
    ),
    ( use:
      (channel: pils-library: program-filename) header use or ()
      reverse every {(ok)|:ok ' -#$* "*"}
    ),
    configuration:
    [ default-configuration-filename
      language-configuration-filename
      user-configuration-filename
    ]
    every (@@ [pils system path])
    &:
    program-filename <-#-* "/" call
    { (?) | :ok () }
    { (ok) <$* "/"
    | :who :ok ' <-# 1 <-#-* "/" call (who) &
       (ok . "config." [pils-configuration:pils-filetype])
    }
  )
  every
  { (why) ;: ok
  | :ok ' every {(library)|:ok library:. .why .path program-filename}
  }
  splice
  every
  { library:. .path .why
  | :self :ok
    list := library:. ' .(@@ [pils system path] path (.) decode) .self .why
  }
  .(:list ' := program-filename;)
  distinct {library:. .why? .self?|:ok library} {$ ok|:ok}
  each
  { library: . filename .why .self
  | ;library filename call (@@ [pils system librarian]) .:need; :ok
    (channel: pils-library: filename) header use or () reverse
    each
    { (library) | :ok library:. .path filename .why ' try [.use used] }
     { (?) $* "*" | ? }
    each (self) and:
    library:. .filename .why
  }
  & (library: . program-library .filename program-filename .why [main])
  reverse
}
{ .test|:self :try this program filename call (self) }
