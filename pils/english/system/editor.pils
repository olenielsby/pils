><:[module:. pils editor menu rename .timestamp 2011-09-29T23:54:03.026+02 .language system]><;
{ rename: .page .library-channel .home
| :ok
  ( menu: . [module rename] .shortcut "Ctrl+R" .action rename: .page )
  &
  ( :if
      (home count > 1)
      and (home . (home count) <> home . (home count - 1))
    ;
    ;rename home <-# 2 & (home <+# 1);
    menu: . [module move down] .action rename:. .page
  )
  &
  ( library-channel modules each
    { name, ?
    | :try name +# (home count) .:need -##* home call {ok,|:ok}
    }
    distinct every
    { name
    | :ok
      menu: . [module move up] & (this program language name (name))
      .action rename: . home <-# 1 & name & (home <+# 1) .page
    }
    order [call: menu]
  )
  &
  ( this program libraries each
    { library: .filename .why [use]
    | :ok
      menu:
      . [module], [move], [library], filename .(@@ [pils system path] encode)
      .action move: .page .library filename
    }
  )
}
><:[module:. pils editor navigate .timestamp 2011-07-21T00:16:57.767+02 .language system]><;
;library-channel (channel: pils-library: this program filename)
.language this program language
;
{ navigate: .home .window .tabs
| :who :ok
  editor-channel escape anyway:
  window mind escape := editor-channel listen
  { .escape
  | window mind escape := ();
    window mind splitter unsplit and:
    tabs current focus
  }
  { * [key down]: .key [escape] | :self :try self escape }
  { .restructure
  | :ok who navigate: .home tabs current mind module-name .window .tabs
  }
  ;
  ;icon-selector
    tabs count up each (tabs) each
    { tab | :ok :name tab page mind module-name; 1 }
    &
    ( library-channel node legs
      { +& name := * module: . "" | :ok :name; 4 }
    )
    firsts [ok]
  ;
  ;tree window mind tree;
  ;root tree clear add (this program filename <+#^* "/" .icon 4);
  library-channel node legs {+& ok := ?|:ok}
  order {ok|:ok ' .(language write)}
  .(level: . 1 .branch root .items)
  call
  { level:. .branch .items
  | :self :ok
    items groups { item | :ok item +# level } legs
    { group := items
    | :ok ;group .items .name language name: group <+# 1 1
    }
    order [call: name]
    each
    { :;group .items .name
    | ;branch ' add (name .icon 3);
      items each
      { item
      | :if item = group .else (:ok item);
         list := (:name branch id; item);
         branch icon: .
         :if item = home; (tree mind home := branch; 2)
         .else item call (icon-selector) .:need
      }
      try { +& items | self level:. ' + 1 .branch .items }
    }
  }
  .:list firsts [ok]
  .(tree mind nodes :=) and:
  window mind splitter split (tabs, tree) and:
  tree mind home select and:
  tree focus
}
{ tree: .splitter .tabs
| :ok 
  splitter tree show 0
  icons
  ( .size 16 .icons
    [opener horizontal cold, opener vertical cold, bottle, bottle empty]
    each {name|:ok @@ ([pils icon] & name & [small])}
  )
  when
  { activated: .
  | :who
    ;module-name activated id call (who mind nodes) .:need;
     @ operations (.window .tabs) module (.module-name) and:
     who mind home icon (. 1) and:
     who mind home := activated icon (. 2);
     who focus
  }
  { .escape | :try editor-channel escape }
}
><:[module:. pils editor new .timestamp 2011-07-21T00:34:25.617+02 .language system]><;
{ new: .filename
| :if file (filename) count or 0 = 0; :ok
  ;choices;
  ;window platform window (say [choose language]);
  ;list window list add (choices every [call: choice]) focus
    when
    { * [key down]: .key [escape] | window close }
    { activated: .
    | ( :if file (filename) count or 0 = 0;
        file (filename) text := activated call (choices) .:need new;
        filename @@@ [pils editor] window
      )
      and: :ok window close
    }
  ;
  list hot (choices count up largest (choices -> [call: relevance]))
}
{ .test
| :ok
  [pils-configuration:language]
}
===
{ .choices
| :ok
  folder (this module filename <-#^* "/pils/") folders each
  { ? folder: path
  | ;name path <-#$* "/" <+#-* "/";
    :try choice:. say (?:? // name) .name
    .new
      file (path . "system/new." [pils-configuration:pils-filetype])
      text .:need
    .relevance :if name = [pils-configuration:language] lower; 2
    .else name bug {} call {"english"|:ok 1} {?|:ok 0} bug {}    !! = "english" !!
  }
  order [call: choice]
}
><:[module:. pils editor operations .timestamp 2011-07-20T23:43:25.557+02 .language system]><;
;library-channel;
{ operations: .window .tabs
| :ok
  @ +++:
  @ file (.window .tabs)
  +++
  { close: .page |:if tabs count > 1; tabs hot close }
  { function:. .module .home
  | ;error-hint @ [pils run error] hint;
    [result escape] find (editor-channel) anyway:
    @ result: . function call (module) .:need .window .tabs
  }
  { [library import] | :ok @@ libraries import }
  { open: .library | library @@@ [pils editor] window }
  { navigate: .page
  | @ navigate: .window .tabs .home page mind module-name
  }
  { .detective | :ok @ detective: .window .tabs }
  { [test open] | :try @@ [pils run command open] open }
}
><:[module:. pils editor operations file .timestamp 2011-09-28T17:11:36.982+02 .language system]><;
;library-channel;

{ file: .window .tabs
| :ok
  { new: .page
  | ;text window ask text [.header create, .label new module] .:need;
    :if text count > 0;
    ;newname read (.text) .:need call {ok = ? // ?|:ok}
      or (:ok window say [bad module name])
    ;
    ;new page mind module-name & newname;
    new call (library-channel node)
    and (:ok window say [trying to create already existing module])
    or:
    (library-channel) (new) :=
    this program libraries
    every
    { library: .why? .filename
    | :ok [node] call: channel: pils-library: filename
    }
    find ((call: new) -> {ok|:ok ' without [timestamp]})
    or
    ( module: .
      ( this program language write (: { newname | :quote :ok })
        <-#$* " " . ""=
        try
        { text
        | ;ok text *=* ["{[", "{ .", "]|", ""="| ", "}", ""="}"];
          this program language read (ok) or ()
          call {{n|?}|:if n = newname; :ok} .:try
        }
      )
      .language library-channel header language or [system]
    )
    ;
    save and:
    tabs open (.module-name new) and:
    editor-channel restructure anyway:
  }
  { rename: .page
  | ;old page mind module-name .:need;
    ;last old call {(ok) 0|:ok} .:need;
    ;suggestion
      this program language write (last)
      -#$* "[" <-#$* "]" <$*=* ["""", "'""", "", "'"]
    ;
    ;text
      window ask text
      (. suggestion .header [rename module] .label [new name])
      .:need
      call {+$ ok|:ok} .:need
    ;
    ;new
      this program language read ("[" (text) "]") or ()
      call {ok = ? // ?|:ok} or (:ok window say [bad module name])
    ;
    ;new old <-# 1 & new;
    new call (library-channel node)
    and (:ok window say [rename to already existing module])
    or:
    rename (.old .new)
    and:
    tabs open (.module-name new) and:
    editor-channel restructure anyway:
  }
  { rename:. .page
  | ;old page mind module-name;
    rename (.old page mind module-name .new rename)
    and:
    tabs open (.module-name rename) and:
    editor-channel restructure anyway:
  }
  { copy: .page
  | ;old page mind module-name .:need;
    ;last old call {(ok) 0|:ok} .:need;
    ;suggestion
      this program language write (last)
      -#$* "[" <-#$* "]" <$*=* ["""", "'""", "", "'"]
    ;
    ;text
      window ask text
      (. suggestion .header [copy module] .label [copy as name])
      .:need
      call {+$ ok|:ok} .:need
    ;
    ;new
      this program language read ("[" (text) "]") or ()
      call {ok = ? // ?|:ok} or (:ok window say [bad module name])
    ;
    ;new old <-# 1 & new;
    new call (library-channel node)
    and (:ok window say [copy to already existing module])
    or:
    copy (.old .new) and:
    tabs open (.module-name new) and:
    editor-channel restructure anyway:
  }
  { delete: .page
  | ;module-name page mind module-name;
    (library-channel) (module-name) := [];
    tabs hot close and:
    save and:
    :if tabs count = 0;
    window close
    .else
    editor-channel restructure anyway:
  }
  { save: .page
  | ;module-name page mind module-name;
    ;module
      module-name call (library-channel) .:need
      call {* module: . ok|:ok} .:need
    ;
    ;text page mind extra valid (.page) .:need;
    :ok
    (library-channel) (module-name)
    := module merge
      (;module text .timestamp now .language page mind language)
    ;
    paged anyway:
    save
  }
  { [save and test]: .page
  | ;module-name page mind module-name;
    ;module
      module-name call (library-channel) .:need
      call {* module: . ok|:ok} .:need
    ;
    ;text page mind extra valid (.page) .:need;
    (library-channel) (module-name)
    := module merge
      (;module text .timestamp now .language page mind language)
    ;
    paged anyway:
    save and:
    pane [result] and:
    ;error-hint @ [pils run error] hint;
    @ test-methods (.home module-name)
    find {menu: .? .shortcut ? <> [] .action ok| :ok}
    try
    { function:. .module .home
    | :exit
      ;_ (channel: error: this program filename) listen
        {* error: .?|exit := ()}
      ;
      @ result:. function call (module) .:need .window .tabs
    }
  }
  { move: .page .library
  | ;to (channel: pils-library: library);
    ;module-name page mind module-name;
    ;modules
      library-channel node legs
      {module :=|:if module $* module-name > 0; :ok module: .; ='}
    ;
    modules find ([call: module] -> to node)
    and (window say [module already exists])
    or:
    module-name <-# 1 repeat
    { +& module-name
    | module-name call (to node) or:
      to . module-name := (module: . "" .timestamp);
      :ok module-name <-# 1
    }
    and:
    modules each { module: .; =' | to . module := }
    and:
    library @@@ [pils system program-file] save
    and:
    modules each { module: .; ? | library-channel . module := () }
    and:
    save
    and:
    tabs count down each (tabs) each
    { tab
    | :if tab page .:need mind module-name $* module-name > 0; tab close
    }
    and:
    editor-channel restructure anyway:
  }
  { module: .module-name
  | tabs select (.module-name) .:try anyway:
    tabs open (.module-name) .:try
  }
  { language:. .page
  | page mind language := language;
    paged
  }
  { language: .
  | library-channel header
    := library-channel header try [-: pils: .language?] merge (;language);
    paged anyway:
    @ menu (.window .tabs .page tabs current) anyway:
    save and:
    @ reconstruct (.window .tabs)
  }
  { edit:. .page
  | ;module-name page mind module-name;
    ;module
      module-name call (library-channel) .:need
      call {* module: . ok|:ok} .:need
    ;
    tabs close (.module-name) and:
    (library-channel) (module-name) := module merge (;edit);
    paged anyway:
    save and:
    :try tabs open (.module-name)
  }
  { .open
  | window ask open
    ( .path this program filename <-#-* "/"
      .type [pils-configuration:pils-filetype]
      .filter "*." [pils-configuration:pils-filetype])
    .:need
    call { ok | :if  ok <$* ("." [pils-configuration:pils-filetype]) > 0; :ok } .:need
    @@@ [pils run start] .:need
    start .:try
  }
  { .explorer | :try platform system explorer }
  ==='
  { read: .text
  | :try this program language read ("[?:" ({} write (text)) "]")
  }
  { read: .text ' =* ":"
  | this program language read (text) or ()
    call {ok = +$? // +$?|:ok} .:try anyway:
    this program language read
    ("[" (text +#=* ":") ({} write (text -#=* ":")) "]") .:try
  }
  { rename: .old .new
  | :ok
    tabs count down each (tabs) each
    { tab | :if tab page .:need mind module-name $* old > 0; tab close }
    and:
    (library-channel) modules each
    { name, module
    | :if name $* old > 0;
      ;new ' & (name -#$* old);
      (library-channel) (new) or:
      (library-channel) (new) := module;
      (library-channel) (name) := [];
    }
    and:
    save
  }
  { copy: .old .new
  | :ok
    (library-channel) modules each
    { name, module
    | :if name $* old > 0;
      ;new ' & (name -#$* old);
      (library-channel) (new) or:
      (library-channel) (new) := module;
    }
    and:
    save
  }
  ===
  { .save | :try @@ [pils system program-file] save }
  { .paged | :try @ refresh: .window .tabs }
  { [pane: result] | :ok [result escape] find (editor-channel) anyway: }
}
><:[module:. pils editor operations file reconstruct .timestamp 2011-07-21T00:13:52.291+02 .language pils language system]><;
{ reconstruct: .window .tabs
| :ok
  ;tabs ' count up every (tabs) every
  { tab
  | :ok
    ;page tab page;
    tab:
    .hot page = tabs hot page
    .data
    ( page:
      .language page mind language
      .text page text
    )
    .module-name page mind module-name
  }
  .position window position
  .size window size
  ;
  window close and:
  reconstruct (.tabs .position .size)
}
===
{ reconstruct: .tabs .position .size
| :ok
  ;window
    @@ editor window (.module-name ()) position (position) size (size)
  ;
  ;operations window mind operations operations;
  tabs every
  { tab: .hot? .module-name .data
  | :ok
    operations module (.module-name) and:
    ;page window mind tabs hot page;
    page text := data text;
    page mind language := data language;
    @ refresh (.window .tabs window mind tabs)
  }
  and:
  ;tab tabs every [call: hot] legs {ok := 1|:ok} find (window mind tabs);
  tab select and: tab page focus
}
><:[module:. pils editor pinpoint .timestamp 2009-04-27T18:28:36.752+02 .language system]><;
{ pinpoint: .what .where
| ;module where this .:need module .:need;
  :try
  module filename @@@ [pils editor] window mind operations operations
  module (.module-name module name) .:need
  selection
  ( :need @@ . [run pinpoint] pinpoint:
    .what
    .expression module expression
    .source module text
    .language module language
  )
  .:need
  focus
}
><:[module:. pils editor refresh .timestamp 2011-09-29T22:09:18.880+02 .language system]><;
;library-channel (channel: pils-library: this program filename);
{ refresh: .tabs .window
| ;page tabs current .:need; :ok
  page focus and:
  window mind status-bar text
  ( this program language write (page mind module-name)
    -#$* "[" <-#$* "]"
  )
  anyway:
  ;module-name page mind module-name;
  ;module module-name call (library-channel) module;
  ( window mind state,
    state:
    .page ' repeat {::using?; ok|:ok}
    .changed
    :if
      (page mind language = module language or [system])
      and
      (page text = module-name call (library-channel) module module)
    ; 0
    .else 1
  )
  try:
  { (state: .page .changed), ?
  | tabs mind images . page := (state: .selected 0 .changed) }
  { (state: .page .changed?), (state: .page .changed?)
  | ? }
  { ?, state = state: .page? .changed
  | window mind state := state;
    tabs mind images . page := (state: .selected 1 .changed);
    @ menu (.page .window .tabs)
  }
  { x, x | ? }
}
><:[module:. pils editor result .timestamp 2011-07-21T00:32:13.771+02 .language system]><;
{ result:. .window .tabs
| :who
  (:try @ graph:. result .window .tabs) anyway:
  :ok
  ;textpane window mind result;
  [result escape] find (editor-channel) anyway:
  window mind splitter split (tabs, textpane)
  and:
  window mind escape := editor-channel listen
  { .escape
  | window mind escape := ();
    window mind splitter unsplit and:
    tabs current focus
  }
  { .result | :ok () }
  ;
  textpane text:
  ;language this program language;
  result call
  { result | :ok language indent: result }
  { $ ok | :ok }
}
{ result: .splitter | :ok splitter codepane show 0 }
><:[module:. pils editor result find .timestamp 2009-03-05T12:21:31.949+01 .language system]><;
{ find: .textpane
| :ok
}
><:[module:. pils editor result graph .timestamp 2011-07-20T23:40:16.545+02 .language system]><;
{ graph:. ' graph:graph .window .tabs
| :ok
  ;canvas window mind graph or
  ( window mind splitter canvas when
    { paint: paint | :who :try @ paint: .paint .canvas who }
  );
  [graph escape] find (editor-channel) anyway:
  window mind splitter split (tabs, canvas)
  and:
  window mind escape := editor-channel listen
  { .escape
  | window mind escape := ();
    window mind splitter unsplit and:
    tabs current focus
  }
  { .graph | :ok () }
  ;
  window mind graph := canvas;
  canvas mind graph := graph;
  canvas refresh
}
><:[module:. pils editor result graph paint .timestamp 2011-07-21T00:13:39.187+02 .language system]><;
{ paint:. .canvas
| :try
  paint graph:
  graph:background:. #dddddd;
  graph:at:. canvas size each {ok|:ok ' \ 2};
  graph:align: . 50%;
  graph:size:. canvas size every {ok > 20|:ok ' - 10} .:need;
  canvas mind graph
}
><:[module:. pils editor size .timestamp 2008-07-27T22:18:21.438+02 .language system]><;

600, 700
><:[module:. pils editor tabs .timestamp 2011-07-20T23:42:07.263+02 .language system]><;
;library-channel;
{ tabs: .parent .window
| :ok
  ;tabs parent tabs
  when
  { select: .module-name
  | :who :try
    who count up each (who)
    find
    { tab
    | ;page tab page .:need;
      :if page mind module-name = module-name; :ok
      tab select and:
      who refresh anyway:
      page
    }
  }
  { open: .module-name | :who :try @ page: .tabs who .module-name }
  { close: .module-name
  | :who :try
    who count up each (who) find
    { tab
    | :if tab page .:need mind module-name = module-name; :ok tab close
    }
  }
  { .refresh | :who ' .(@ refresh: .window .tabs) .:try }
  { .changed | :who ' .(@ refresh: .window .tabs) .:try }
  ;
  tabs mind images := @ imagelist (.tabs);
  tabs
}
><:[module:. pils editor tabs imagelist .timestamp 2011-09-28T17:08:48.575+02 .language system]><;
{ imagelist: .tabs
| :ok
  [ horizontal cold,
    horizontal hot,
    vertical cold,
    vertical hot
  ]
  each {name|:ok @@ ([pils icon opener] & name & [small])}
  .(tabs icons: .size 16 .icons)
  and:
  { page := state: .changed .selected
  | :ok
    tabs count up find
    { n
    | :if
        tabs . n page mind module-name = page mind module-name .:need
      ;
      :ok tabs . n icon: changed + (selected * 2) + 1
    }
    or ()
    === {:error|:ok 0}
  }
}
><:[module:. pils editor tabs page .timestamp 2009-08-29T11:08:08.828+02 .language system]><;
{ page: .tabs .module-name
| ;edit
    module-name call (library-channel node) .:need
    call {* (module: .? .edit ok = ? // ?) anyway [.edit pils-source]|:ok}
    .:need
  ;
  ;edit-module
    module-name count down 0
    every {n|:ok module-name +# n & [pils edit] & edit}
    & [pils edit source,]
    find {module-name|:try @@ (module-name)} .:need
  ;
  ;page edit-module edit (.parent tabs .module-name .library-channel) .:need;
  :ok
  page mind module-name := module-name;
  page mind language :=
    library-channel node . module-name language or [system]
  ;
  tabs add
  ( .page
    .focus 1
    .label this program language name: module-name <+# 1 1
  )
  and:
  tabs refresh anyway:
  page
}
><:[module:. pils editor test-methods .timestamp 2011-09-06T00:05:11.995+02 .language system]><;
{ test-methods: .home = & '
| :ok
  (home & [test], home)
  & (home count up each {count|:ok home <-# count & [test]})
  & ((home count - 1) down each {count|:ok home +# count})
  each
  { module-name
  | :ok
    ;module @@ (module-name) or ();
    module call
    { ? | :ok () }
    { ::where .ruleset ::ruleset
    | :try ruleset every {:;match .action?|:ok match}
    }
    { [] * module | :ok module cliche legs +#^* (,) }
    each
    { function = ? // ?
    | :ok
      (select: . function; function:. .module-name)
      try
      { ok =
        select: . function <> [test];
        spec = function:. .module-name ' = (function) 0
      | :ok (select: . [test]; spec) & ok
      }
    }
    splice
  }
  splice
  distinct [call: select]
  distinct [call:]
  every
  { select:.; function:. .module-name
  | :ok select:.; function:. .module @@ (module-name) .home
  }
  try
  { actions
  | actions find {select: . [test]; ?|:ok ()} or:
    :ok actions &:
    select: . [test];
    function: . [test] .module {.test|:ok say [no test]} .home
  }
  each
  { select: .; action = function:. .module? .home?
  | :ok
    ;function ' try {ok * ?|:ok};
    menu: . [test], this program language name (function) or (function)
    .action .shortcut :if select = [test]; "Ctrl+T"
  }
  & [menu:. test go .action test open .shortcut "Ctrl+G"]
}
><:[module:. pils editor title .timestamp 2008-05-25T01:33:39.509+02 .language system]><;

