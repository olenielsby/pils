><:[module:. compute text .timestamp 2009-04-26T18:39:11.397+02 .language system]><;

><:[module:. compute text differences .timestamp 2011-09-06T00:03:50.572+02 .language system]><;
!!
The differences function takes two strings and tries to match their content,
as used in file comparers of versioning tools.
The result is an alternating list of strings for identical passages and string pairs
for differing passages.
The differences function is not utf-8-aware.
!!
{ differences: ok = ($ ?, $ ?) | :ok ', }
{ differences: $ a, $ b
| :who :try
  longest-identical-passage (.a .b) .:need
  call
  { :;ca .cb .count ' > 4
  | :ok
    (who differences: a +# ca, b +# cb)
    &
    (a -# ca +# count)
    &
    (who differences: a -# ca -# count, b -# cb -# count)
  }
}
{ differences: ["", ""] | :ok () }
===
{ longest-identical-passage: .a ' $ (? > 4) .b ' $ (? > 4)
| :ok
  (;pagesize a count .best ;count 0 .ca 0 .cb 0)
  repeat
  { :;pagesize .best
  | :if pagesize > best count; :ok
    ;pagesize ' \ 2;
    ;pagesize .best
    a split (pagesize) legs
    { n := page $ count
    | 0 repeat
      { cb
      | ;found b -# cb =* page; :if found; :ok
        ;cb ' + found - count;
        list := (;count .ca (n - 1) * pagesize .cb);
        cb + 1
      }
    }
    .:list
    every
    { :;ca .cb .count
    | :ok
      ;before a +# ca <#* (b +# cb)
      .after a -# ca -# count #* (b -# cb -# count)
      ;
      ;ca ' - before
      .cb ' - before
      .count ' + before + after
    }
    largest [call: count] or ()
  }
  best or ()
}
===
{ $ s split: + c
| :ok (s count + c - 1) \ c up every {n|:ok s -# ((n - 1) * c) ++# c}
}
><:[module:. compute text searching .timestamp 2011-09-30T14:02:47.183+02 .language system]><;
{ (searching: .wanted $ ' .whole 0 .case-sensitive 1)
  anyway [.whole 0 .case-sensitive 1]
| :ok
  { $ text
  | :ok :list
    text split (wanted) fold
    { $ before :=
    | :who :ok (before count, before split ""= count) call (who) :=
    }
    { (count, line) := $ gap
    | :ok
      list := (hit:. count, count + (wanted count) .line);
      count + (wanted count) + (gap count), line + (gap split ""= count - 1)
    }
  }
}
{ (searching: .wanted $ ' .whole 1 .case-sensitive 1)
  anyway [.case-sensitive 1]
| :ok
  { $ text
  | :ok :list
    text split (wanted) fold
    { $ before :=
    | :who :ok
      ( before count, before split ""= count, wordstarter (before))
        call (who) :=
    }
    { "" :=
    | :who :ok
      (0, 1, 1) call (who) :=
    }
    { (count, line, ?) := +$ gap
    | :ok
      count + (wanted count) + (gap count),
      line + (gap split ""= count - 1),
      wordstarter (gap)
    }
    { (count, line, 1) := +$ gap
    | :if wordstopper (gap);
       list := hit:. count, count + (wanted count) .line
    }
    { (count, line, [last]) := +$ gap
    | :if 0 < wordstarter (wanted) < wordstopper (gap);
       list := hit:. count, count + (wanted count) .line
    }
    { (count, line, ?) := ""
    | :ok
      count + (wanted count), line, wordstarter (wanted)
    }
    { (count, line, 1) := ""
    | :ok
      count + (wanted count),
      line,
      :if wordstopper (wanted) > 0 .else [last];
      list := (hit:. count, count + (wanted count) .line);
      wordstarter (wanted)
    }
    try
    { count, line, [last] | list := hit:. count - (wanted count), count .line }
  }
}
{ (searching: .wanted $ ' .whole .case-sensitive 0) anyway [.whole 0]
| :self :try
  { $ ok | :ok ' lower } -> :need
  (searching: .wanted ' lower .whole .case-sensitive 1) call (self)
}
{ * searching: .wanted "" | :ok { $? | :ok () } }
===
{ wordstarter: +$ x | :ok x <+# 1 <+* " .,()[]{|}""!?:;"~<=>7f }
{ wordstopper: +$ x | :ok x +# 1 +* " .,()[]{|}""!?:;"~<=>7f }
