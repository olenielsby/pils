small (.png)><:[module:. pils editor detective match .timestamp 2011-07-21T00:36:51.469+02 .language system]><;
{ match: .wanted
| ;match this program language read (wanted) or (:ok [ok:]);
  :ok
  { ? | :ok ( ) }
  { text
  | :where
    :try
    module (where module) .:need
    call
    { * module: .expression .language ' language
    | expression **=** ({: =' .:quote = match|:quote list :=} .: ---') .:list
      find [ok] .:need and:
      :ok
      language traceread (text)
      repeat
      ( { :quote ::traceread? .start? .end?; ok | :quote :ok }
        { ::traceread match .start ' 1 .:quote .end ' 1 .:quote;
          ? .:quote
        | :quote list := start 1, end 1
        }
        .: ---'
      )
      .:list
      order {ok, ?|:ok}
      first [0 1] fold
      { (last, line) := hit = (start, end)
      | :ok :if start < last; last, start
        .else
        ;line ' + (text +# start -# last count ""=);
        list := (hit:. .line);
        end, line + (text +# end -# start count ""=)
      }
      .:list
    }
  }
}
><:[module:. pils editor detective modules .timestamp 2011-07-21T00:30:07.013+02 .language system]><;

{ .modules
| :ok
  this program libraries every
  { library: .filename .why?
  | :ok
    (channel: pils-library: filename) node legs
    { module := * module:. +$ text | :ok module:. .text .library filename }
  }
  splice distinct [call: module]
}
><:[module:. pils editor detective state .timestamp 2011-09-06T00:12:07.938+02 .language system]><;
{ state: .search (search: .high .low) .tree
| :ok
  { flap:. .item; branches
  | :who :ok
    item call
    {|:ok state: .high 0 .low 0}
    { module:. .text .library?
    | :ok
      state:
      .high ' . text ++# 1 count
      .low ' . text ++# 1 count
    }
    & (branches each: who) fold
    { (state: .high .low) := state: .high h .low l
    | :ok state: .high (' + h) call [0:.] or 1 .low (' + l) call [0:.] or 1
    }
    try
    { state
    | tree . flap icon: .
      state call
      [ .[state: .high 0 .low 0] 1
        .[state: .high 1 .low 0] 2
        .[state: .high 0 .low 1] 3
        .[state: .high 1 .low 1] 4
      ]
    }
  }
}><:[module:. pils editor latest .timestamp 2008-05-25T01:30:44.271+02 .language system]><;

{ .latest
| library-channel node
  legs
  { +& name := ? | :ok name, () }
  { +& name := * ;timestamp | :ok ;name .timestamp }
  largest [call: timestamp] .:need name
  .:try anyway: :ok
  @ new
}
><:[module:. pils editor libraries .timestamp 2011-09-30T14:10:36.478+02 .language system]><;
;library-channel (channel: pils-library: this program filename);
{ .import
| :ok
  this module channel import or:
  ;panel platform window (say ([use], [libraries], " - ", @@ title));
  panel mind . (this module channel listen {.import|:ok panel}) := ();
  ;list
    panel list [.style broad]
    add (libraries) add ""
    hot 1 width (.column 1;)
  ;
  panel menu:.
  [menu:. edit insert .action edit insert .shortcut "Ins"],
  [menu:. edit delete .action edit delete .shortcut "Del"],
  [menu:. edit up .action edit up .shortcut "Shift+Up"],
  [menu:. edit down .action edit down .shortcut "Shift+Down"],
  [menu:. edit tester .action edit tester .shortcut "Ctrl+T"],
  .action
  { [edit up]
  | ;hot list hot .:need;
    :if (hot? > 1) and (hot text count > 0);
    ;items 
      (hot? - 2) up & (hot?) & (hot? - 1) & ((hot? + 1) up (list count))
      every (list) .:need every [call: text] .:need
    ;
    list clear add (items) hot (hot? - 1)
    and: changed
  }
  { [edit down]
  | ;hot list hot .:need;
    :if (hot? > 0 < list count - 1) and (hot text count > 0);
    ;items
      (hot? - 1) up & (hot? + 1) & (hot?) & ((hot? + 2) up (list count))
      every (list) .:need every [call: text] .:need
    ;
    list clear add (items) hot (hot? + 1)
    and: changed
  }
  { [edit delete]
  | ;hot list hot .:need;
    ;old hot text call {+$ ok|:ok} .:need;
    library-channel node? call
    { * ;language ?:? // name
    | :if old = "<pils>/" (name) "/system/" (name); :ok
      panel say [can not remove file language library]
    }
    or:
    list delete (hot?) and: changed
  }
  { [edit insert]
  | panel ask open
    ( .header [add library]
      .path this program path
    )
    .:need
    .(@@ [pils system path] encode)
    .:need
    .(list insert)
    and: changed
  }
  { [edit tester]
  | ;hot list hot .:need;
    hot text
    (:need hot text call {+$ ok|:ok ' .("*")}{ok $* "*"|:ok ' -# 1})
    and: changed
  }
  ===
  { .changed
  | :ok
    list width (.column 1;) and:
    libraries := (list count - 1) up every {n|:ok list text (n)};
    list focus
  }
}
===
{ .libraries | :ok library-channel header use or () }
{ .libraries := use
| :ok
  library-channel header
  := library-channel header try {|:ok [pils: .use?]} merge (;use);
  @@ [pils system program-file] save and:
  (channel: pils-library-changed: this program filename) library-list
  anyway:
  ;tabs window mind tabs;
  @ menu: .window .tabs .page tabs current
}
><:[module:. pils editor menu .timestamp 2011-09-30T01:03:36.568+02 .language system]><;
;library-channel;
{ menu: .page .window .tabs
| :ok
  ;home page mind module-name;
  window menu:
  .action
    @ operations (.window .tabs)
    +++ {action:. .who|:try action call (who)}
  .menu
  ( ( menu: . [file open] .shortcut "Ctrl+O" .action [open] ),
    ( menu: . [file explorer] .shortcut "Ctrl+E" .action [explorer] ),
    ( menu: . [module create] .shortcut "Ctrl+N" .action new: .page ),
    ( menu: . [module navigate] .shortcut "Ctrl+M"
      .action navigate: .page ),
    ( menu: . [edit detective] .shortcut "Ctrl+D" .action [detective] ),
  )
  &
  ( page mind extra menu (.window) or () )
  &
  ( ;text page text;
    :if
      ( text = home call (library-channel) module module )
      and
      ( page mind language
        = home call (library-channel) module language or [system]
      )
    .else
      ( menu: . [edit module save] .shortcut "Ctrl+S" .action save: .page ),
      ( menu: . [edit module [save and test]]
        .shortcut "Ctrl+T"
        .action [save and test]: .page
      ),
    ;
    @ test-methods (.home)
    &
    ( :if tabs count > 1;
      menu: . [edit close] .shortcut "Ctrl+F4" .action close: .page
    )
    &
    ( menu: . [module copy] .shortcut "Ctrl+K" .action copy: .page )
    &
    ( (text, home) call
      { ?
      |:ok
        (@ rename: .page .library-channel .home)
      }
      { "", ?
      | :ok
        (@ rename: .page .library-channel .home)
        &
        ( library-channel node legs {ok := ?|:ok}
          find {& ok|:if (ok $* home > 0) and (ok <> home); :ok ()} or:
          menu: . [module destroy] .action delete: .page
        )
      }
      { "", ? $* [pils system] | :ok ()}
      { "", [pils language system] | :ok () }
    )
    & (@ editors: .page)
    &:
    @@ . [[?:?|pils-configuration:platform] [?:?|pils-configuration:system]]
    or ()
    menu (.page .text .module-name home) or ()
  )
  & (@ languages: .page)
  & (@ libraries)
}
><:[module:. pils editor menu editors .timestamp 2011-09-29T13:03:24.879+02 .language system]><;
