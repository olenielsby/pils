><:[module:. pils editor menu languages module .timestamp 2011-07-21T00:34:36.056+02 .language system]><;
;library-channel .filename this program filename;
{ languages: .page
| :ok
  ;module-name page mind module-name;
  ;current page mind language;
  this program libraries each
  { library: .filename library .why ? <> [configuration]
  | (channel: pils-library: library) node .:need legs
    { language =* [pils language] := module = *;module +$?
    | ;stub language <-#=* [pils language];
      :if module-name +#$* stub = stub; :ok
      language <+#^* [pils language]
    }
    { ? <$* [pils language] := ? | ? }
    .:try
  }
  splice distinct order {ok|:ok this program language write (ok) <-#+* ",]"}
  every
  { language
  | :ok
    ;language ' singlewise;
    :if language = current;
    ( menu:
      . [language] & language
      .check 1
      .action language: . [system] .page
    )
    .else
    menu: . [language] & language .action language:. .page
  }
}
><:[module:. pils editor menu languages program .timestamp 2011-07-20T23:41:10.056+02 .language system]><;
;library-channel .filename this program filename
.pilssuffix "." [pils-configuration:pils-filetype]
;
{ .languages
| :ok
  ;current library-channel node? language or ();
  :if filename <> bootfilename;
  this program libraries each
  { library: .filename ok .why ? <> [configuration] | :ok }
  distinct each
  { filename
  | ;name filename <-#$* pilssuffix <+#-* "/";
    :if
      filename =
      bootfilename <-#^* "/pils/"
      (name) "/system/" (name) (pilssuffix)
    ;
    ;language ?:? // name
    .library-node (channel: pils-library: filename) node
    ;
    ([pils], [language], language) call (library-node) or ()
    call
    { * module:. .language [system]
    | :try {} read (module) .:need call {? language|:ok ()}
    }
    .:need and:
    :ok
    ;menu [file settings language] & language;
    :if language = current; (menu:. .check 1 .action language: . [system])
    .else menu:. .action language: .
  }
}
{ .test|:ok pilssuffix}><:[module:. pils editor menu libraries .timestamp 2011-07-21T00:36:41.374+02 .language system]><;
{ .libraries
| :ok
  ( :if this program filename <> bootfilename;
    menu: . [libraries use] .action [library import]
  )
  &:
  this program libraries groups
  { library: .filename .why section call
    [.use 1 .used 2 .configuration 3 .system 4 .platform 4]
