@@ source +++ ;zoom 6
><:[module:. pils edit source .timestamp 2011-09-28T17:13:49.545+02 .language system]><;
{ edit: .parent .module-name .library-channel
| :who :ok
  ;extra
  { valid: .page
  | :tag [valid];
    ;text page text .language page mind language;
    ( language (. .library this program filename .module-name) .:need
      read (text)
      ===
      { :error = error:. ' try
        [ .0 not implemented by parser
          .1 parsing stack overflow
          .2 unexpected end
          .3 unexpected character
          .4 bad string
          .5 bad date
          .6 bad duration
          .7 bad exponent
          .8 bad prefix
          .9 forbidden name
          .10 unknown name
          .11 multiple prefix
          .12 twin attribute
          .13 bad dot
          .14 missing operand
          .15 bad constant
          .16 bad rule
        ]
        .start
        .end
      | ( :if parent ask ok (. (error) .header [syntax error]) <> 0;
          page selection (start, end)
        )
        and:
        :error [valid]; error
      }
    )
    and: :ok text
  }
  { menu: .window | :who :ok @ menu: .window .edit who }
  { .data
  | :who :ok data: .text who text .selection who selection
  }
  { .data := data: .text .selection
  | :who :ok who text (text) selection (selection)
  }
  ;
  parent codepane [.syntax pils]
  zoom (who zoom)
  text (module-name call (library-channel node) module)
  when
  { .changed|:try parent refresh }
  { * [key down]: .key [escape]
  | :who parent parent unsplit and: who focus
  }
  call {ok|:ok ' mind extra := extra; ok}
}
{ .zoom | :ok @@ zoom }
><:[module:. pils edit source menu .timestamp 2008-12-21T14:25:00.121+01 .language system]><;
{ menu: .window .edit
| :ok
  ;who @ action (.window .edit);
  (menu: . [edit source find] .shortcut "Ctrl+F" .action action: . [find] .who),
}
><:[module:. pils edit source menu action .timestamp 2009-03-05T12:55:54.050+01 .language system]><;
{ action: .window .edit
| :ok
  { .find
  | :ok
    window find: .host
    @@ find host:
    .window
    .minding [find]
    .pages {.current | :try window mind focused}
  }
}
><:[module:. pils edit source menu action find .timestamp 2011-07-21T00:44:08.405+02 .language system]><;
;defaults
  [search: .find "" .direction down .casing_sensitive 0 .whole_words_only 0]
;

{ host: .minding .window .pages
| :ok
  { command: . [find] .panel | :ok find (.data .panel) }
  { command: . [find_next] .panel | :ok find (.data .panel) }
  { / option | :try data . option }
  { / option := value
  | :ok window mind . minding := data merge (option, value)
  }
  ===
  { .data | :ok window mind . minding or: defaults }
  { find: .panel .data
    * search: .find .direction .casing_sensitive .whole_words_only
  | ;page pages current .:need;
    page find (. .casing_sensitive .whole_words_only .direction) .:need
    call
    { selection | :try page selection (selection) }
    { found count | :ok page selection (found, found + (find count)) }
    { | :ok panel say [text not found] }
    .:try
  }
}
><:[module:. pils editor .timestamp 2011-06-25T21:49:14.177+02 .language system]><;
{ .window
| :who
  :try who window: .module-name @ latest
}
{ window: .module-name
| ( module-name call (-:) or:
    :try this module channel window .:need up
  )
  anyway:
  :ok
  ;window
    platform window (@@ title)
    inner size (@@ size)
    icon
    ( :call @@:
      [pils icon opener] &
      (:if this program filename = bootfilename; [horizontal] .else [vertical])
      &
      [cold large]
    )
    when (this module channel)
  ;
  window mind . (this module channel listen: ;window) := ();
  ;inner window column;
  window mind state := [new];
  ;splitter
    inner splitter [horizontal]
    when {.escape|:try this module channel escape}
  ;
  window mind status-bar := inner label "";
  window mind status-bar mind height := 30;
  ;tabs @ tabs (.parent splitter .window);
  window mind tree := @@ navigate tree (.splitter .tabs);
  window mind detective := @ detective (.splitter .tabs);
  window mind result := @ result (.splitter);
  window mind splitter := splitter;
  window mind active := tabs;
  window mind tabs := tabs;
  splitter full (tabs) and:
  window mind listen [change] :=
    this program channel listen
    { changed: .module-name? .library-filename
    | (library-filename, this program filename) call {ok, ok|:ok} or:
      @ menu: .window .tabs .page tabs current
    }
  ;
  ;operations {.operations|:ok @ operations (.window .tabs)};
  window mind operations := operations;
  ( module-name call (-:) or:
    operations operations module (.module-name)
  )
  and:
  window
}
><:[module:. pils editor === .timestamp 2008-12-21T14:25:18.339+01 .language system]><;
{ .library-channel | :ok channel: pils-library: this program filename }
{ .editor-channel | :ok this module channel }
{ .window | :try @@ [pils editor] window }
><:[module:. pils editor detective .timestamp 2011-09-29T21:57:05.394+02 .language system]><;
{ detective: .window .tabs
| :ok
  editor-channel escape anyway:
  ;detective window mind detective;
  window mind splitter split (tabs, detective) and:
  window mind escape := editor-channel listen
  { .escape
  | window mind escape := ();
    window mind splitter unsplit and:
    tabs current focus
  }
  ;
  [populate changed] each (this module channel) and:
  detective mind focusing focus
}
{ detective: .splitter .tabs
| :ok
  ;changing [call: .changed] -> this module channel;
  ;column splitter column;
  ;[row: high] column row;
  ;[seek: high] row [high] textfield when (changing);
  ;[match: high] row [high] checkbox (say [structural]) when (changing);
  ;[whole: high]
    row [high] checkbox (say [whole words only]) when (changing)
  ;
  ;[case-sensitive: high]
    row [high] checkbox (say [case-sensitive]) checked 1
    when (changing)
  ;
  column mind focusing := seek [high];
  ;belt column row;
  ;tree
    belt tree
    icons
    ( . [none high low both]
       every {n|:ok @@ . ([icon], [detectives], n, [small])}
       .size 16
     )
    when
    { selected: .
    | :who ' mind selected := selected id;
      this module channel hits
    }
    { activated: .
    | :who ' mind selected := activated id;
      this module channel open
    }
    { * [key down]: .key [escape] | :try editor-channel escape }
  ;
  ;hits belt list when
    { selected: .
    | :who ' mind hits . selected call
      { hit = hit: .? .line? .module? .library .text?
      | :try hit call: library @@@ [pils editor detective hit]
      }
      and: who focus
    }
    { * [key down]: .key [escape] | :try editor-channel escape }
  ;
  hits mind width := 60;
  ;[row: low] column row;
  ;[seek: low] row [low] textfield when (changing);
  ;[match: low] row [low] checkbox (say [structural]) when (changing);
  ;[whole: low]
    row [low] checkbox (say [whole words only]) when (changing)
  ;
  ;[case-sensitive: low]
    row [low] checkbox (say [case-sensitive]) checked 1
    when (changing)
  ;
  tree mind listen := this module channel listen
  { .hits
  | :ok
    ;selected tree mind selected or ();
    selected call (-:) or:
    tree mind contents
    **=** {flap:. .item; ?|:if flap = selected; list := item}
    .:list find
    { | :ok () }
    { module:. .text .library
    | :ok
      [high low] each (column mind search or:) every (call: text) splice
      order {hit: . ok, ? .line?|:ok}
      every {hit:. .line|:ok hit:. .line .module .text .library}
    }
    or ()
    call
    { hitlist
    | :ok
      hits mind hits := hitlist;
      hits clear add: hitlist every
      { * hit: .line | :ok {} write (line) }
    }
  }
  { .open
  | :ok
    ;selected tree mind selected or ();
    selected call (-:) or:
    tree mind contents
    **=** {flap:. .item; ?|:if flap = selected; list := item}
    .:list find
    { | :ok () }
    { module:. .text? .library
    | :ok
      library @@@ [pils editor detective hit] open (.module) anyway:
    }
  }
  { .populate
  | :ok
    tree mind contents :=
    ( flap:. tree clear add (this program filename .icon 1)
      .path ()
      .modules @ modules
    )
    call
    { flap:. .path .modules
    | :who :ok
      modules
      groups {module:. .text? .library?|:ok module -#$* path ++# 1}
      legs
      { () := ok, | :ok }
      { (name,) := modules
      | :ok flap: .name .modules
        .display this program language write (name) -#$* "[" <-#$* "]"
      }
      order {?|:ok ""} {* ;display ok|:ok}
      call
      { list | :ok item: . () .list }
      { (item = module: .? .text? .library?) 1 = list | :ok item:. .list ' -# 1 }
      call
      { item:. .list
      | :ok flap:. ' id .item;
        list every
        { flap: .name .modules .display
        | :ok flap:. ' add (display .icon 1) .path ' & name .modules
        }
        every (who)
      }
    }
  }
  { .changed
  | ;search
    [search: .high .low] **=**
    { side := side
    | :ok
      (whole (side), case-sensitive (side))
      every (call: show: 1 - match (side) checked)
      and:
      ;wanted seek (side) text;
      :if match (side) checked = 1; @ match (.wanted)
      .else
      @ [compute text] searching:
      .wanted
      .whole whole (side) checked
      .case-sensitive case-sensitive (side) checked
    }
    ;
    column mind search := search;
    tree mind contents call (@ state: .search .tree) and:
    this module channel hits
  }
  ;
  [high low] every {side|:ok row (side) mind height := 40} and:
  column ! show 0
}
><:[module:. pils editor detective hit .timestamp 2011-07-20T23:44:38.195+02 .language system]><;
{ h = * hit:. .module
| @@ [pils editor] window mind operations operations
  module (.module-name module) .:need
  selection (hit .scroll-to-center 1) anyway: :ok ()
}
{ open: .module
| @@ [pils editor] window mind operations operations
  module (.module-name module) .:try
}
