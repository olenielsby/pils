><:[module:. platform qt .timestamp 2008-06-21T23:43:08.612+02 .language system]><;
><:[module:. platform qt entry .timestamp 2008-07-19T17:38:47.465+02 .language system]><;
@><:[module:. platform qt entry ask .timestamp 2011-05-18T00:50:13.502+02 .language system]><;
{ .ask | :ok @@ . [parent ask] parent [.; ask] }
{ .asking | :ok @@ . [parent asking] parent [.; asking] }
><:[module:. platform qt entry clipboard .timestamp 2009-07-02T19:37:51.513+02 .language qt]><;
{ .clipboard
| :ok
  { .text | :try juce-SystemClipboard juce-getTextFromClipboard }
  { text: text
  | :who
    juce-SystemClipboard juce-copyTextToClipboard (text) .:need and: :ok who
  }
}
><:[module:. platform qt entry icon .timestamp 2010-02-26T18:55:28.627+01 .language qt]><;
{ icon: .size .png | :ok Q:Image: png }
><:[module:. platform qt entry keyboard .timestamp 2011-07-20T23:09:04.998+02 .language qt]><;
;keyboard
{ ok call
  [.shift-key juce-isShiftDown .ctrl-key juce-isCtrlDown .alt-key m juce-isAltDown]
| :ok ' call: juce-ModifierKeys juce-getCurrentModifiers
}
><:[module:. platform qt entry path .timestamp 2009-01-26T00:31:04.937+01 .language system]><;
;path
{ .documents | :ok [pils-configuration:documents-directory] }
><:[module:. platform qt entry say .timestamp 2011-05-06T20:18:34.589+02 .language qt]><;
{ (say: message .header) anyway [.header information]
| :ok
  juce-AlertWindow juce-showMessageBoxAsync
  ( 3,
    say (header),
    say (message),
    "",
    [juce-Component],
  )
}
><:[module:. platform qt entry system .timestamp 2008-08-04T12:55:32.254+02 .language system]><;
{ .system | :try @@ [platform qt system [?:?|pils-configuration:system]] }
><:[module:. platform qt entry window .timestamp 2011-09-28T16:59:07.075+02 .language qt]><;
{ window: handle
| :possibly
  plumcake Q:MainWindow
  q:setWindowTitle (handle title .:need)
  q:setWindowIcon (handle icon .:need)
  q:show
  q:setGeometry (handle geometry .:need)
  when
  { ask: .; options = :where? .ruleset :' rules
  | :who :ok
    ;buttons rules every [call: match];
    ;dialog plumcake Q:Dialog (who) when
    {|}
    ;
    ;hbox plumcake Q:HBoxLayout;
    dialog q:setWindowTitle (say (ask) "?")
    q:setWindowModality 1 ! WindowModal
    q:setLayout (hbox)
    and:
    rules every
    { ;match .action?
    | :ok hbox q:addWidget:
      plumcake Q:PushButton (say (match))
      when
      { qs:clicked: ?
      | :ok
        dialog q:close and: match try (options)
      }
    }
    and:
    dialog q:show
 }
  { icon: ' | :who :try who q:setWindowIcon (icon) }
  { qe:mouseButtonPress: ' | (': ') bug {}}
  { qe:mouseButtonRelease: ' | (': ') bug {}}
  { title: $ title | :who ' q:setWindowTitle (title) .:try }
  { .pinpoint | :who :ok who mind pinpointer call: @@ [pils run pinpoint] }
  { .size | :who :possibly who juce-getWidth .:need, who juce-getHeight .:need }
  { menubar: handle
  | :who :ok who q:menuBar
    when
    { action: ..name
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args
      | handle action (.) or:
      }
      and: who
    }
    { action: ..name .shortcut
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args
      | handle action (.) or:
      }
      q:setShortcut (shortcut)
      anyway: who
    }
    { menu: .name
    | :who :self :ok
      who q:addMenu (name) when (self)
    }
    or: who q:menuBar q:clear
  }
  { .statusbar
  | :who :ok
    ;statusbar who q:statusBar;
    { say: $ say | :ok statusbar q:showMessage (say, 0) }
    { .says | :ok statusbar q:currentMessage }
  }
  { .inner
  | :who :ok
    who mind inner or:
    ;inner plumcake Q:Widget when
    { .vertical
    | :who :ok
      ;layout
        plumcake Q:VBoxLayout when
        { .splitter
        | :who :ok
          ;splitter
            plumcake Q:Splitter 2 when
            { label: text
            | :who :ok
              ;label plumcake Q:Label (text) when {|};
              who q:addWidget (label) and:
              label
            }
            { edit: text
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit (text) when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b)
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { .edit
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit "" when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b)
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { .tabs
            | :who :ok
              plumcake Q:TabWidget when
              { .tabs
              | :who :ok
                who q:count up every
                { n | :ok who q:widget: n - 1 }
              }
              { edit: handle
              | :who :ok
                ! Search for existing tab with same id
                who tabs find
                (;id handle id;
                { tab
                | :if id = tab id; :ok
                  (found-tab: .id) bug {} and:
                  tab edit
                })
                or:
                ;edit
                  plumcake Q:PilsPlainTextEdit (handle text)
                  when
                  { qs:textChanged:
                  | :who handle text:. who q:toPlainText
                  }
                  { .handle | :ok handle }
                  { .text | :who :ok who q:toPlainText }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b)
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                ;
                ;layout plumcake Q:VBoxLayout;
                ;tab plumcake Q:Widget when
                { .edit | :ok edit }
                { .id | :ok handle id }
                ;
                tab q:setLayout (layout) and:
                who q:addTab (tab, handle name) and:
                layout q:addWidget(edit, 1, 0) and:
                edit
              }
              { .current
              | :who :ok who q:currentWidget edit
              }
              try {tabs|who q:addWidget (tabs)}
            }
          ;
          who q:addWidget (splitter, 1, 0) and:
          splitter
        }
      ;
      who q:setLayout (layout) and:
      layout
    }
    ;
    who q:setCentralWidget (inner) and:
    inner
  }
  .(@ strap) .:need
}

><:[module:. platform qt keypress .timestamp 2011-09-06T00:11:05.084+02 .language qt]><;
{ keypress:.
| :ok
  ;m keypress juce-getModifiers;
  [key down]: .key
  keypress juce-getKeyCode call
  { ok | :ok }
  { 0x20 <= ok < 0x10000 | :ok ' listwise utf-8 }
  { ?
  | :try keypress juce-getTextCharacter call
     {+ ok|:ok ' listwise utf-8}
     {+ ok < 27|:ok (' + 64) listwise utf-8}
  }
  { ok call
    [ .8 back .9 tab .13 return .27 escape .65582 delete .127 back
      .65569 page up
      .65570 page down
      .65571 end
      .65572 home
      .65573 left
      .65574 up
      .65575 right
      .65576 down
      .65581 insert
      .65648 f1 .65649 f2 .65650 f3 .65651 f4 .65652 f5 .65653 f6
      .65654 f7 .65655 f8 .65656 f9 .65657 f10 .65658 f11 .65659 f12
      .65660 f13 .65661 f14 .65662 f15 .65663 f16 .65664 f17 .65665 f18
      .65666 f19 .65667 f20 .65668 f21 .65669 f22 .65670 f23 .65671 f24
    ]
  | :ok
  }
  .shift-key m juce-isShiftDown
  .ctrl-key m juce-isCtrlDown
  .alt-key m juce-isAltDown
}
><:[module:. platform qt parent ' .timestamp 2009-01-16T10:28:33.682+01 .language qt]><;
{ parent: .; [parent] | :ok parent juce-getParentComponent }
><:[module:. platform qt parent .timestamp 2011-07-21T01:02:42.127+02 .language qt]><;
{ [self: parent] | :self :ok self }
{ parent:. ' juce-Component
| :self [parent]; :ok
  parent +++
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call: :need name call (@@)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call: :need name call (@@)
  }
}
><:[module:. platform qt parent ask .timestamp 2011-09-29T21:59:58.580+02 .language qt]><;
{ parent: .; [ask]
| :ok
  { (text:. .label .header) anyway [.header enter text .text ""]
  | ;textfield juce-TextEditor ()
      when
      { state call [.[juce-escapePressed:] 0 .[juce-returnPressed:] 1]
      | :who ' juce-getParentComponent juce-exitModalState (state) .:ok
      }
      try (call: juce-setText: text)
    ;
    ;dialog
      juce-DialogWindow (say (label), juce-Colour [200 150 100], 1)
      try (call: juce-setContentOwned: textfield, 0)
      try (call: juce-centreAroundComponent: parent, 300, 60)
      when
      { juce-closeButtonPressed: | :who ' juce-exitModalState 0 .:ok }
      { juce-focusGained: ? | :ok textfield juce-grabKeyboardFocus }
    ;
    dialog juce-runModalLoop
    call
    { ? | dialog juce-removeFromDesktop juce-visibilityChanged }
    { 1
    | ;text textfield juce-getText call {+$ ok|:ok} .:need;
      dialog juce-removeFromDesktop juce-visibilityChanged and:
      :ok text
    }
    .:try
  }
  { (open: .filename .header .type .filter .path)
    anyway [.type? .filter? .filename "" .header open .path ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser juce-FileChooser(say (header), juce-File(path));
    :if chooser juce-browseForFileToOpen = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (save: .filename .header .type .filter)
    anyway [.type? .filter? .filename ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser juce-FileChooser(say (header), juce-File(filename));
    :if chooser juce-browseForFileToSave 1 = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (folder: .header .folder) anyway [.folder ""]
  | ;chooser juce-FileChooser(say (header), juce-File(folder));
    :if chooser juce-browseForDirectory = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename try {ok <-* "/"|:ok ' "/"}
  }
  { (ok:. .header) anyway [.header confirm]
  | :ok juce-AlertWindow juce-showOkCancelBox (1, say (header), say (ok))
    or:
    juce-AlertWindow juce-showOkCancelBox
    ( 1,
      say (header),
      say (ok),
      "",
      "",
      [juce-Component],
      [juce-ModalComponentManager.Callback]
    )
  }
}
><:[module:. platform qt parent asking .timestamp 2011-09-28T16:53:46.265+02 .language qt]><;
{ parent: .; [asking]
| :ok
  { (text:. .label .header; done) anyway [.header enter text .text ""]
  | ;textfield juce-TextEditor ()
      when
      { state call [.[juce-escapePressed:] 0 .[juce-returnPressed:] 1]
      | :who ' juce-getParentComponent juce-exitModalState (state) .:ok
      }
      try (call: juce-setText: text)
    ;
    ;dialog
      juce-DialogWindow (say (label), juce-Colour [200 150 100], 1)
      try (call: juce-setContentOwned: textfield, 0)
      try (call: juce-centreAroundComponent: parent, 300, 60)
      when
      { juce-closeButtonPressed: | :who ' juce-exitModalState 0 .:ok }
      { juce-focusGained: ? | :ok textfield juce-grabKeyboardFocus }
    ;
    dialog juce-runModalLoop
    call
    { ? | dialog juce-removeFromDesktop juce-visibilityChanged }
    { 1
    | ;text textfield juce-getText call {+$ ok|:ok} .:need;
      dialog juce-removeFromDesktop juce-visibilityChanged and:
      :ok text try (done)
    }
    .:try
  }
  { (open: .filename .header .type .filter .path)
    anyway [.type? .filter? .filename "" .header open .path ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser juce-FileChooser(say (header), juce-File(path));
    :if chooser juce-browseForFileToOpen = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (save: .filename .header .type .filter)
    anyway [.type? .filter? .filename ""]
  | ;name filename <+#^* "/" .:need .folder filename <-#^* "/" .:need;
    ;chooser juce-FileChooser(say (header), juce-File(filename));
    :if chooser juce-browseForFileToSave 1 = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename
  }
  { (folder: .header .folder) anyway [.folder ""]
  | ;chooser juce-FileChooser(say (header), juce-File(folder));
    :if chooser juce-browseForDirectory = 1;
    ;filename chooser juce-getResult juce-getFullPathName *=* ("\", "/");
    :if filename count > 0; :ok filename try {ok <-* "/"|:ok ' "/"}
  }
  { (ok:. .header) anyway [.header confirm]
  | :ok juce-AlertWindow juce-showOkCancelBox (1, say (header), say (ok))
    or:
    juce-AlertWindow juce-showOkCancelBox
    ( 1,
      say (header),
      say (ok),
      "",
      "",
      [juce-Component],
      [juce-ModalComponentManager.Callback]
    )
  }
}
><:[module:. platform qt parent at .timestamp 2011-07-20T23:30:19.277+02 .language system]><;
{ at:. .pane
| :ok
  { menu = menu: .? .action?
  | :try @ menu:. .pane .at
  }
}
><:[module:. platform qt parent at menu .timestamp 2011-07-20T23:30:04.317+02 .language qt]><;
{ menu: .pane .at .menu menu:. & ' .action
| :ok
  @ [menu] tree (.menu)
  first (juce-PopupMenu ()) fold
  { menu := submenu: .name; items
  | :who :ok
    menu juce-addSubMenu:
    saying (name),
    items first (juce-PopupMenu()) fold (who)
  }
  { menu := item:. .name .at
  | :ok
    menu juce-addItem:
    at,
    saying (name),
   1,
   item call {*;check 1|:ok 1} or 0
  }
  { menu := item:. .name [-] .at | :ok menu juce-addSeparator }
  juce-show
  try: menu -> [ok] +++ [call: action] -> action
}
><:[module:. platform qt parent button .timestamp 2011-07-21T00:12:18.933+02 .language qt]><;
{ parent: .; button: $ label
| :ok
  parent juce-new (juce-TextButton (label))
  when {juce-clicked:|:who ' clicked .:try}
}
><:[module:. platform qt parent canvas .timestamp 2011-07-21T00:19:29.164+02 .language qt]><;
{ parent: .; [canvas]
| :ok
  parent juce-new (juce-Component ())
  juce-setWantsKeyboardFocus 1
  when (@ common)
  when (@ offspring)
  when
  { .clear | :who ' juce-deleteAllChildren .:ok }
  { juce-new: ok juce-Component
  | :who :ok who juce-addAndMakeVisible (ok) and: ok
  }
  { juce-paint: graphics | :who ' paint (@ graphics: .) .:try }
}
><:[module:. platform qt parent checkbox .timestamp 2011-07-21T00:12:42.100+02 .language qt]><;
{ parent: .; checkbox: $ label
| :ok
  parent juce-new (juce-ToggleButton (label))
  when
  { show: show call [.0 .1] | :who :ok who juce-setVisible (show) }
  { .checked | :who ' juce-getToggleState .:try }
  { checked: state call [.0 .1] | :who ' juce-setToggleState (state, 0) .:try }
  { juce-clicked: | :who ' changed .:try }
}
><:[module:. platform qt parent codepane .timestamp 2011-09-30T14:05:39.185+02 .language qt]><;
{ .test | :ok @ [tokeniser] [syntax] }
{ parent: .; (codepane: .syntax / ' .tabs) anyway [.syntax .tabs 0]
| :ok
  ;dummy juce-CodeDocument ()
  .tokeniser @ [tokeniser] (syntax) or [juce-CodeTokeniser]
  ;
  parent juce-new (juce-CodeEditorComponent (dummy, tokeniser))
  try {x|x juce-setFont (juce-Font 18 .:need)}
  when
  { zoom: zoom | :who :ok who } ! TODO
  { text: $ text | :who ' juce-loadContent (text) .:ok }
  { .text := $ text | :who ' juce-loadContent (text) .:ok }
  { .text | :who :ok who juce-getDocument juce-getAllContent <-#$* ""~ }
  { .focus | :who :ok who juce-grabKeyboardFocus and: who }
  { show: show call [.0 .1] | :who :ok who juce-setVisible (show) }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who :possibly
    :use {$ ok +# -1 .:|:ok};
    ;standin who text;
    ;a standin +# a .:need utf-8 count
    .b standin +# b .:need utf-8 count
    ;
    who juce-setHighlightedRegion (a, b) and:
    ( :if scroll-to-center = 1;
      ;line who juce-getCaretPos juce-getLineNumber
      .total who juce-getNumLinesOnScreen
      ;
      ;ideal line - (total \ 2);
      who juce-scrollToLine:
      :if ideal > 0; ideal .else 0
    )
    and:
    who
  }
  { .selection
  | :who :ok
    ;text who juce-getText;
    [juce-getHighlightedRegionStart juce-getCaretPos] every (who)
    every {p|:ok text utf-8 +# p utf-8 count}
  }
  { .clear | :who :ok who juce-setText "" and: who }
  { tip: tip | :who :ok who mind tip := tip; who }
  { (find:. .casing_sensitive .whole_words_only .direction)
    anyway [.casing_sensitive 0 .whole_words_only 0 .direction down]
  | :who :ok
    ;casing_sensitive ' call (.1 [ok] .0 {ok|:ok ' lower}) .raw who text;
    ;find ' call (casing_sensitive)
    .text raw call (casing_sensitive) !*=* (""/,  ""/, ""=, ""/)
    ;
    direction call
    ( .down
        raw utf-8 +# (who juce-getCaretPos juce-getPosition) utf-8 count
        repeat
        { from
        | ;hit text -# from =* find; :if hit > 0; :ok
          ;hit ' + from;
          list := (hit - (find count), hit);
          hit
        }
      .up
        raw utf-8 +# (who juce-getHighlightedRegionStart) utf-8 count
        repeat
        { from
        | ;hit text +# from <=* find; :if hit > 0; :ok
          ;hit from - hit;
          list := (hit, hit + (find count));
          hit
        }
    )
    .:list
    find
    ( whole_words_only call: .0 [ok] .1
      { hit
      | hit find
        { at
        | :if
            0 < text +# at <++# 1 -* " ,.;:?!""(){|}[]"<=>
            < text -# at ++# 1 -* " ,.;:?!""(){|}[]"<=>
          ;
          :ok ()
        }
        or: :ok hit
      }
    )
    or ()
  }
  { juce-codeDocumentEditorTextChanged: ? | :who ' changed .:try }
  { juce-keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    who +++
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok who juce-getTopLevelComponent juce-closeButtonPressed and 1
    }
    { [key down]: .key [tab] .shift-key ? .ctrl-key 0 .alt-key 0
    | tabs call [0:.] .:try
    }
  }
  { juce-focusGained: ? | :who ' focused 1 .:try }
  { juce-focusLost: ? | :who ' focused 0 .:try }
  { focused: 1
  | :who ' juce-getTopLevelComponent mind focused := who
  }
}
><:[module:. platform qt parent codepane tokeniser .timestamp 2011-07-06T19:36:40.525+02 .language system]><;
><:[module:. platform qt parent codepane tokeniser C++ .timestamp 2011-07-06T19:36:25.641+02 .language qt]><;
;C++ juce-CPlusPlusCodeTokeniser ()
><:[module:. platform qt parent codepane tokeniser pils .timestamp 2011-07-06T19:33:39.429+02 .language qt]><;
;pils juce-PilsCodeTokeniser ()
><:[module:. platform qt parent codepane tokeniser syntax .timestamp 2011-07-06T17:56:02.791+02 .language qt]><;
;syntax [juce-CodeTokeniser]><:[module:. platform qt parent column .timestamp 2011-09-05T23:59:36.570+02 .language qt]><;
{ parent: .; [column]
| :ok
  ;layout juce-StretchableLayoutManager ();
  parent juce-new (juce-Component ())
  when (@ offspring)
  when
  { juce-resized:
  | :who :ok
    ;children
      0 up (who juce-getNumChildComponents - 1)
      every {n|:ok who juce-getChildComponent: n}
      every {ok|:ok ' mind juce-wrap or: ok}
    ;
    layout juce-clearAllItems() and:
    children every
    { ? | :ok 8, -1, -1 }
    { child | ;height child mind height .:need; :ok height, height, height }
    legs { n := hint | layout juce-setItemLayout: (n - 1) & hint }
    and:
    layout juce-layOutComponents:
    children, 0, 0, who juce-getWidth, who juce-getHeight, 1, 1
  }
  { juce-new: ok juce-Component
  | :who :ok who juce-addAndMakeVisible (ok) juce-resized and: ok
  }
}
><:[module:. platform qt parent common .timestamp 2011-07-22T00:54:02.759+02 .language qt]><;
;common
{ at: . | :who :ok @ at:. .pane who }
{ .refresh | :who :ok who juce-repaint }
{ .focus | :who ' juce-grabKeyboardFocus .:ok }
{ .focused | :who ' juce-hasKeyboardFocus 0 .:ok }
{ .size | :who :ok who juce-getWidth, who juce-getHeight }
{ size: size | :who ' juce-setSize (size) .:try }
{ place: place | :who ' juce-setTopLeftPosition (place) .:try }
{ (drag: .description .image) anyway [.image juce-Image]
| :who
  ;description ' .({} write:);
  juce-DragAndDropContainer juce-findParentDragContainerFor (who) .:need
  juce-startDragging (description, who, image, 1) .:need
  and: :ok who
}
{ (drag: .description .image) anyway [.image juce-Image]
| :who
  ;description ' call {ok|:ok ' .({} write)} {$ ok|:ok};
  juce-DragAndDropContainer juce-findParentDragContainerFor (who) .:need
  juce-startDragging (description, who, image, 1) .:need
  and: :ok who
}
{ juce-mouseDown: e
| :who
  ;at [juce-x juce-y] every (e);
  [juce-isLeftButtonDown juce-isRightButtonDown] every (e juce-mods) call
  { 1, 0 | :ok [mouse left down]: at }
  { 0, 1 | :ok [mouse right down]: at }
  { 1, 1 | :ok [mouse both down]: at }
  call (who) .:try
}
{ juce-mouseDrag: e
| :who
  ;at [juce-x juce-y] every (e);
  [juce-isLeftButtonDown juce-isRightButtonDown] every (e juce-mods) call
  { 1, 0 | :ok [mouse left drag]: at }
  { 0, 1 | :ok [mouse right drag]: at }
  { 1, 1 | :ok [mouse both drag]: at }
  call (who) .:try
}
{ juce-mouseUp: e | :who ' . ([mouse up]: [juce-x juce-y] every (e)) .:try }
{ juce-mouseMove: e | :who ' . ([mouse move]: [juce-x juce-y] every (e)) .:try }
{ juce-resized: | :who ' sized .:try }
{ juce-keyPressed: keypress
| :who :try @ keypress (.) .:need call:
  { key | key call (who) .:need and: :ok 1 }
  { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
  | :ok
    who juce-getTopLevelComponent juce-closeButtonPressed
    and: 1
  }
}
{ juce-isInterestedInDragSource: description, component
| :who ' dragging (. {} read (description) .:need .from component) .:try
}
{ juce-itemDropped: description, component, x, y
| :who
  ' dropped (. {} read (description) .:need .from component .at x, y) .:try
}
{ juce-focusGained: ? | :who ' focused 1 .:try }
{ juce-focusLost: ? | :who ' focused 0 .:try }
{ juce-keyPressed: keypress | :who ' .(@ keypress (.) call) .:try }
{ focused: 1 | :who ' juce-getTopLevelComponent mind focused := who }
><:[module:. platform qt parent find .timestamp 2011-07-21T01:05:28.835+02 .language system]><;
{ parent: .; find: .host
| :ok
  ;channel (channel: search: parent repeat {::using?; ok|:ok});
  channel close anyway:
  ;dialog platform window (say [find]);
  ;contents dialog column;
  ;row contents row when {.escape|dialog close};
  row mind height := 25;
  ;[title: find] row label (say [find]);
  title [find] mind width := 40;
  ;find
    row textfield text (host find or "")
    when
    { .return | :try host command: . [find_next] .panel dialog }
    { .changed | :who host find := who text }
    { .escape | :ok dialog close }
  ;
  and:
  ;find_next
    row button (say [find next])
    when
    { .clicked
    | :try host command: . [find_next] .panel dialog
    }
  ;
  find_next mind width := 100;
  ;row contents row;
  ;column row column;
  ;whole_words_only column checkbox (say [whole words only])
    checked (host whole_words_only)
    when {.changed|:who host whole_words_only := who checked}
  ;
  ;casing_sensitive column checkbox (say [casing sensitive])
    checked (host casing_sensitive)
    when {.changed|:who host casing_sensitive := who checked}
  ;
  [whole_words_only casing_sensitive] every
  { call
  | :ok
    ;checkbox (:call);
    checkbox checked (call call (host) or 0)
  }
  and:
  ;row ' groupbox (say [direction]) row;
  ;[direction: up]
    row checkbox (say [up])
    when
    { .changed
    | :who ' mind direction [down] checked (who checked = 0) and:
      host direction := who checked call [.1 up .0 .down]
    }
  ;
  ;[direction: down]
    row checkbox (say [down])
    when
    { .changed
    | :who direction [up] checked (who checked = 0) and:
      host direction := who checked call [.1 down .0 .up]
    }
  ;
  direction [up] mind direction [down] := direction [down];
  [up down, down up] every
  { direction, other
  | :ok
    direction (direction) checked (direction = host direction or 0)
  }
  and:
  find focus and:
  dialog inner size (300, 75)
}
><:[module:. platform qt parent folder .timestamp 2011-09-28T16:55:53.647+02 .language qt]><;
{ parent: .; folder: .
| ;folder ' call {? folder: ok|:ok} {$ ok|folder (ok) .:need and: :ok} .:need;
  :ok
  juce-FileBrowserComponent
  (2, juce-File (folder), [juce-FileFilter], [juce-FilePreviewComponent], 1, 1)
  .(parent juce-new)
