><:[module:. platform qt parent splitter .timestamp 2011-09-29T12:59:46.693+02 .language qt]><;
{ parent: .;
  splitter: orientation call [.floor 1 .horizontal 1 .wall 0 .vertical 0]
| :ok
  ;[layout: 1]
    juce-StretchableLayoutManager ()
    juce-setItemLayout (0, -1, -1, -1)
  .[layout: 2]
    juce-StretchableLayoutManager ()
    juce-setItemLayout (0, 10, -1, -1)
    juce-setItemLayout (1, 8, 8, 8)
    juce-setItemLayout (2, 10, -1, -1)
  ;
  ;sash
    juce-StretchableLayoutResizerBar (layout 2, 1, 1 - orientation)
    when {juce-paint: g|g juce-fillAll (juce-Colour [255 200 70])}
  ;
  parent juce-new (juce-Component ())
  try
  { splitter | splitter mind juce-panes := (); splitter mind juce-active := layout 1 }
  juce-addChildComponent (sash)
  when
  { juce-resized: | :who lay-out (.splitter who) }
  { juce-new: ok juce-Component
  | :who :ok who juce-addChildComponent (ok) and: ok
  }
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call:
    :need @@ ([platform qt parent] & name)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call:
    :need @@ ([platform qt parent] & name)
  }
  { full: full juce-Component | :who :ok panes (.splitter who) := full,; who }
  { split: panes & 2
  | :who
    panes (.splitter who) :=
      panes every
      { ok juce-Component
      | :self ;parent ok juce-getParentComponent;
        :if parent = who; (:ok) .else :try parent call (self)
      }
      .:need
    ;
    :ok who
  }
  { .unsplit
  | :who :ok
    panes (.splitter who) := who mind juce-panes ++# 1;
    who
  }
  { .size | :who :ok who juce-getWidth, who juce-getHeight }
  { .width | :who :ok who juce-getWidth }
  { .height | :who :ok who juce-getHeight }
  { juce-keyPressed: keypress
  | :who :try keypress juce-getKeyCode call
    { 27 | :try who escape }
  }
  ==='
  { .panes (.splitter) := panes & (count call [.1 .2])
  | :ok
    ;panes ' try {p1, p2|:ok p1, sash, p2};
    splitter mind juce-panes except (panes first [ok])
    every [call: juce-setVisible: 0]
    and:
    splitter mind juce-panes := panes every [call: juce-setVisible: 1];
    splitter mind juce-active := layout (count);
    lay-out (.splitter)
  }
  ===
  { .lay-out (.splitter)
  | :ok
    splitter mind juce-active juce-layOutComponents:
    splitter mind juce-panes, 0, 0, splitter width, splitter height, orientation, 1
  }
}
><:[module:. platform qt parent tabs .timestamp 2011-09-28T16:58:24.627+02 .language qt]><;
{ parent: .; [tabs]
| :ok
  parent juce-new (juce-TabbedComponent 0)
  when
  { + n
  | :who :ok
    { icon: + i
    | :self :possibly
      who juce-getTabbedButtonBar juce-getTabButton (n - 1) .:need
      juce-repaint mind juce-icon := i;
      self
    }

    { .page
    | :possibly who juce-getTabContentComponent (n - 1) .:need
      try {try|:try ' mind juce-wrap}
    }
    { .close | :self who juce-removeTab (n - 1) .:need and: :ok self }
    { .select | :self who juce-setCurrentTabIndex (n - 1) .:need and: :ok self }
  }
  { juce-new: ok juce-Component
  | :who :ok who juce-addChildComponent (ok) and: ok
  }
  { (name = ?:? // ?) * node
  | :who :try (parent:. who; node) call: :need name call (@@)
  }
  { name = ?:? // ?
  | :who :try (parent:. who; name) call: :need name call (@@)
  }
  { .items | :who :ok who juce-getNumTabs up every (who) }
  { .reverse | :who :ok who juce-getNumTabs down every (who) }
  { .clear | :who :ok who juce-clearTabs }
  { .hot | :who :try (who juce-getCurrentTabIndex .:need + 1) call (who) }
  { .current
  | :who :possibly who juce-getCurrentContentComponent .:need
    try {try|:try ' mind juce-wrap}
  }
  { icons:. .size | :who :ok who mind juce-icons := icons; who }
  { .count | :who :ok who juce-getNumTabs }
  { (add: .page ' juce-Component .label $ ' .focus) anyway [.focus?]
  | :who :ok
    ;at who juce-getNumTabs;
    who juce-addTab (label, juce-Colour [200 200 200], page, 1) and:
    (:if focus = 1; who juce-setCurrentTabIndex: at) and:
    who
  }
  { juce-currentTabChanged: ? | :who ' changed .:try }
  { juce-createTabButton: name, index
  | :who :ok @ flap (.tabs who .name .index)
  }
  { juce-keyPressed: keypress
  | :who :try @ keypress (.) call:
    who +++
    { [key down]: .key [f6] .shift-key .ctrl-key 0 .alt-key 0
    | :ok
      who juce-setCurrentTabIndex:
      (shift-key, who juce-getCurrentTabIndex, who juce-getNumTabs - 1) call
      { 0, at, ? | :ok at + 1 }
      { 0, at, at | :ok 0 }
      { 1, at, ? | :ok at - 1 }
      { 1, 0, at | :ok at }
    }
  }
}
><:[module:. platform qt parent tabs flap .edit source .timestamp 2010-12-31T00:26:03.498+01 .language qt]><;
{ flap: .tabs .name .index
| :ok
  (
    ;bar tabs juce-getTabbedButtonBar;
    juce-TabBarButton (name, bar)
  )
  when
  { juce-getBestTabLength: depth
  | :who :ok
    who juce-getLookAndFeel
    juce-getTabButtonBestWidth (index, name, depth, who)
    + 20
  }
  { juce-paintButton: g, isMouseOver, isDown
  | :who :ok
    ;lookAndFeel who juce-getLookAndFeel;
    g juce-setOrigin (4, 4) and:
    lookAndFeel juce-drawTabButton
    ( g,
      who juce-getWidth - 8,
      who juce-getHeight - 4,
      juce-Colour [210 230 210],
      index,
      "",
      who,
      0,
      isMouseOver,
      isDown,
      who juce-getToggleState
    )
    and:
    lookAndFeel juce-drawTabButtonText
    ( g,
      16, 0, who juce-getWidth - 20, who juce-getHeight - 4,
      juce-Colour [200 200 200],
      index, name, who, 0, isMouseOver, isDown, who juce-getToggleState
    )
    and:
    who mind juce-icon or () call (tabs mind juce-icons or ()) or () try
    { icon juce-Image
    | g juce-drawImageWithin
      (icon, 10, 4, 16, 16, juce-RectanglePlacement 64, 0)
    }
  }
}
><:[module:. platform qt parent textfield .timestamp 2011-07-21T00:11:32.206+02 .language qt]><;
{ parent: .; [textfield]
| :ok
  parent juce-new (juce-TextEditor ()) juce-setSelectAllWhenFocused 1
  when
  { font: font | :who ' juce-setFont (font) .:try }
  { text: $ text | :who ' juce-setText (text) .:ok }
  { .text := $ text | :who ' juce-setText (text) .:ok }
  { .text | :who ' juce-getText .:ok }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who ' juce-setHighlightedRegion (a, b - a) .:ok
  }
  { .selection
  | :who :ok [juce-getHighlightedRegionStart juce-getCaretPosition] every (who)
  }
  { .focus | :who ' juce-grabKeyboardFocus .:ok }
  { .clear | :who ' juce-setText "" .:ok }
  { juce-textEditorTextChanged: ? | :who ' changed .:try }
  { juce-keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    { key | key call (who) .:need and: :ok 1 }
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok
      who juce-getTopLevelComponent juce-closeButtonPressed
      and: 1
    }
  }
  { juce-keyPressed: keypress
  | :who :try keypress juce-getKeyCode call
    { code call [.13 return .27 escape]
    | :ok code call (who) and 1 or 0
    }
  }
}
><:[module:. platform qt parent textpane .timestamp 2011-09-30T14:06:02.127+02 .language qt]><;
{ parent: .; [textpane]
| :ok
  parent juce-new (juce-TextEditor ())
  juce-setMultiLine 1
  juce-setReturnKeyStartsNewLine 1
  try {x|x juce-setFont (juce-Font 18 .:need)}
  when
  { zoom: zoom | :who :ok who } ! TODO
  { text: $ text | :who :ok who juce-setText (text) and: who }
  { .text := $ text | :who ' juce-setText (text) .:ok }
  { text: text $ (? > 500000)
  | :who :ok who bug {} juce-setText (text) and: who
  }
  { .text | :who :ok who juce-getText <-#$* ""~ }
  { .focus | :who :ok who juce-grabKeyboardFocus and: who }
  { show: show call [.0 .1] | :who :ok who juce-setVisible (show) }
  { (selection: % a, % b .scroll-to-center) anyway [.scroll-to-center 0]
  | :who :possibly
    :use {$ ok +# -1 .:|:ok};
    ;standin who juce-getText;
    ;a standin +# a .:need
      utf-8 count
    .b standin +# b .:need
      utf-8 count
    ;
    who juce-setHighlightedRegion (a, b) and:
    ( :if scroll-to-center = 1;
      who juce-scrollEditorToPositionCaret
      ( who juce-getWidth, who juce-getHeight \ 2 )
    )
    and:
    who
  }
  { .selection
  | :who :ok
    ;text who juce-getText;
    [juce-getHighlightedRegionStart juce-getCaretPosition] every (who)
    every {p|:ok text utf-8 +# p utf-8 count}
  }
  { .clear | :who :ok who juce-setText "" and: who }
  { .wrap | :who :ok who call: @@ wrapped }
  { tip: tip | :who :ok who mind tip := tip; who }
  { (find:. .casing_sensitive .whole_words_only .direction)
    anyway [.casing_sensitive 0 .whole_words_only 0 .direction [down]]
  | :who :ok
    ;casing_sensitive ' call (.1 [ok] .0 {ok|:ok ' lower}) .raw who juce-getText;
    ;find ' call (casing_sensitive)
    .text raw call (casing_sensitive) !*=* (""/,  ""/, ""=, ""/)
    ;
    direction call
    ( .down
        raw utf-8 +# (who juce-getCaretPosition) utf-8 count
        repeat
        { from
        | ;hit text -# from =* find; :if hit <> 0; :ok
          ;hit ' + from;
          list := (hit - (find count), hit);
          hit
        }
      .up
        raw utf-8 +# (who juce-getHighlightedRegionStart) utf-8 count
        repeat
        { from
        | ;hit text +# from <=* find; :if hit <> 0; :ok
          ;hit from - hit;
          list := (hit, hit + (find count));
          hit
        }
    )
    .:list
    find
    ( whole_words_only call: .0 [ok] .1
      { hit
      | hit find
        { at
        | :if
          0 < text +# at <++# 1 -* " ,.;:?!""(){|}[]"<=>
          < text -# at ++# 1 -* " ,.;:?!""(){|}[]"<=>
          ;
          :ok ()
        }
        or: :ok hit
      }
    )
    or ()
  }
  { juce-textEditorTextChanged: ? | :who ' changed .:try }
  { juce-keyPressed: keypress
  | :who :try @ keypress (.) .:need call:
    who +++
    { [key down]: .key [f4] .shift-key 0 .ctrl-key 0 .alt-key 1
    | :ok who juce-getTopLevelComponent juce-closeButtonPressed and 1
    }
  }
  { juce-focusGained: ? | :who ' focused 1 .:try }
  { juce-focusLost: ? | :who ' focused 0 .:try }
  { focused: 1
  | :who ' juce-getTopLevelComponent mind focused := who
  }
}
><:[module:. platform qt parent tree .timestamp 2011-09-29T13:18:34.149+02 .language qt]><;
{ parent: .; (tree: .root ' call [.0 .1]) anyway [.root 1]
| :ok
  parent juce-new (juce-TreeView ())
  juce-setColour (0x1000500, juce-Colour [250 250 250])
  call
  { ok
  | :ok ' mind juce-settings :=
    ( settings:
      .justification juce-Justification 1
      .[colour: 0] juce-Colour [0 0 0]
      .[colour: 1] juce-Colour [190 180 255]
      .icons ()
      .rectanglePlacement juce-RectanglePlacement 64
    )
    ;
    ok juce-setRootItemVisible (root)
  }
  when
  { id juce-pils.TreeViewItem
  | :self [tree]; :who [tree]; :ok id +++
    { (add: $ text .icon ' count .hot ' count) anyway [.icon 0 .hot 0]
    | :ok id juce-addSubItem juce-setMind (item:. () .text .icon .hot)
      call (who [tree])
    }
    { (icon:. ' count .hot ' count) anyway [.hot 0]
    | :who :ok
      id juce-setMind (id juce-getMind merge: ;icon .hot)
      juce-treeHasChanged
      and: who
    }
    { .tree | :ok who [tree] }
    { .id | :ok id }
    { .select
    | :who :ok
      id juce-setSelected [1 1]
      repeat {item|list := item; :try item juce-getParentItem} .:list reverse
      every [call: juce-setOpen: 1]
      and: who [tree] juce-scrollToKeepItemVisible (id)
      and: who
    }
    { .children
    | :ok
      0 up (id juce-getNumSubItems - 1) every
      { n | :ok id juce-getSubItem (n) call (who [tree]) }
    }
    { children: children call [.0 .1]
    | :who :ok
      id juce-setMind (id juce-getMind merge: ;children) juce-treeHasChanged
      and: who
    }
    { .visible
    | :ok
      1 ! TODO
    }
    { mind: item
    | :who :ok id juce-setMind (id juce-getMind merge (item: .)) and: who
    }
    { .mind | :try id juce-getMind .:need item }
  }
  { (add: $ text .icon ' count .hot ' count) anyway [.icon 0 .hot 0]
  | :who :ok
    who juce-newRootItem juce-setMind (item: . () .text .icon .hot) call (who)
  }
  { (icons:. .size) anyway [.size 16]
  | :who ' mind juce-settings :=
    ( who mind juce-settings merge:
      ;icons ' every {ok juce-Image|:ok} .:need .size
    );
    :ok who
  }
  { (icons: .pairs .size) anyway [.size 16]
  | :who ' mind juce-settings :=
    ( who mind juce-settings merge:
      ;icons pairs every {ok = (? juce-Image, ? juce-Image)|:ok} .:need .size
    );
    :ok who
  }
  { .clear | :who :ok who juce-clear and: who }
  { .root | :who :try who juce-getRootItem .:need call (who) }
  { .hot
  | :who :try
    0 up (who juce-getNumSelectedItems - 1)
    find ({n|:ok juce-getSelectedItem: n} -> who -> who)
  }
  { .focus | :who ' juce-grabKeyboardFocus .:ok }
  { show: show call [.0 .1] | :who ' juce-setVisible (show) .:ok }
  { tip: tip | :who :ok who mind tip := tip; who }
  { juce-keyPressed: keypress
  | :who :try keypress juce-getKeyCode call
    { 13 | :try who activated:. who juce-getSelectedItem 0 .:need call (who) }
    { 27 | :try who escape }
  }
  { juce-paintItem: item juce-TreeViewItem, g, width, height
  | :who :ok
    :use who mind juce-settings;
    ( :if item juce-isSelected = 1;
      g juce-setColour (colour 1) juce-fillAll
    )
    and:
    item juce-getMind try
    { *;text
    | g
      juce-setColour (colour (2 = item juce-isSelected <> 0))
      juce-drawText (text, 2, 0, width - 2, height, justification, 1)
    }
    { mind = *;icon + ' .text
    | :try icon call (icons) .:need call
      { icon juce-Image
      | :ok
        g
        juce-setColour (colour (:if 2 = item juce-isSelected; 1 .else 0))
        juce-drawImageWithin (icon, 2, 2, 16, 16, rectanglePlacement, 0)
        juce-drawText (text, 20, 0, width - 20, height, justification, 1)
      }
      { icon 1 juce-Image, icon 2 juce-Image
      | :ok
        g
        juce-setColour (colour (2 = item juce-isSelected <> 0))
        juce-drawImageWithin (icon 1, 2, 2, 16, 16, rectanglePlacement, 0)
        juce-drawImageWithin (icon 2, 20, 2, 16, 16, rectanglePlacement, 0)
        juce-drawText (text, 38, 0, width - 38, height, justification, 1)
      }
    }
  }
  { juce-itemDoubleClicked: item juce-TreeViewItem, e
  | :who ' activated (. item try: who) .:try
  }
  { juce-itemSelectionChanged: item juce-TreeViewItem, 1
  | :who ' selected (. item try: who) .:try
  }
  { juce-mightContainSubItems: item
  | :try item juce-getMind .:need children
  }
  { juce-itemOpennessChanged: item, 1
  | :who ' expand (. item call (who)) .:try
  }
}
