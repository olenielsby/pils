><:[module:. platform qt parent list .timestamp 2011-09-28T16:56:39.758+02 .language qt]><;
{ parent: .; (list: .style) anyway [.style]
| :ok
  parent juce-new (juce-ListBox ())
  call
  { list
  | :ok
    list mind juce-items := ();
    list mind juce-settings :=
    ( settings:
      .justification juce-Justification 1
      .[colour: 0] juce-Colour [0 0 0]
      .[colour: 1] juce-Colour [190 180 255]
      .icons ()
      .rectanglePlacement juce-RectanglePlacement 64
    )
    ;
    list
  }
  when
  { + n
  | :who [list]; :if n <= who [list] mind juce-items count; :ok
    {|:ok n}
    { .text | :try who [list] mind juce-items .:need . n .:need text }
    { text: text
    | :who :possibly
       who [list] mind juce-items :=
       who [list] mind juce-items .:need legs
       { n' := ok | :ok ' merge: :if n = n'; ;text }
       ;
       who [list] juce-repaintRow (n - 1) and:
       who
    }
    { icon:. ' count
    | :who :ok
      ;items who [list] mind juce-items;
      who [list] mind juce-items :=
        (items +# (n - 1)) & (items . n merge (;icon)) & (items -# n)
      ;
      who [list] juce-repaintRow (n - 1) and:
      who
    }
    { .list | :ok who [list] }
    { .select | :who :ok who [list] juce-selectRow (n - 1) and: who }
  }
  { (icons:. .size) anyway [.size 16]
  | :who
    who mind juce-settings :=
    ( who mind juce-settings merge:
      ;icons ' every {ok juce-Image|:ok} .:need .size
    );
    :ok who
  }
  { (icons: .pairs .size) anyway [.size 16]
  | :who
    who mind juce-settings :=
    ( who mind juce-settings merge:
      ;icons pairs every {ok = (? juce-Image, ? juce-Image)|:ok} .:need .size
    );
    :ok who
  }
  { add: & items
  | :who ;items ' every {$ text|:ok item: .text} .:need; :ok
    who mind juce-items := who mind juce-items & items;
    who juce-updateContent
  }
  { add: $ text
  | :who :ok
    who mind juce-items := who mind juce-items & (item: .text);
    who juce-updateContent
  }
  { insert: $ text
  | :who :ok
    ;old who mind juce-items;
    ;at (0, who juce-getLastRowSelected or 0, old count) order [ok] 2;
    who mind juce-items := old +# at & (item: .text) & (old -# at);
    who juce-updateContent
  }
  { hot: + n | :who ' juce-selectRow (n - 1) .:ok }
  { .hot | :who (' juce-getLastRowSelected + 1) call (who) .:try }
  { delete: + n
  | :who
    ;items who mind juce-items;
    who mind juce-items := items +# n .:need <-# 1 & (items -# n);
    :ok who juce-updateContent
  }
  { width: .column?; ? | :who ' .:ok }
  { .count | :who ' mind juce-items count .:ok }
  { text: + n | :who ' mind juce-items . n .:need text .:try }
  { .clear | :who :ok who mind juce-items := (); who juce-updateContent }
  { .focus | :who ' juce-grabKeyboardFocus .:ok }
  { tip: tip | :who :ok who mind tip := tip; who }
  { juce-getNumRows: | :who :possibly who mind juce-items .:need count }
  { juce-paintListBoxItem:
    row count, g juce-Graphics, + width, + height, selected call [.0 .1]
  | :who
    :use who mind juce-settings;
    ( :if selected = 1; g juce-setColour (colour 1) juce-fillAll ) and:
    :try
    (row + 1) call (who mind juce-items) .:need call
    { *;text
    | g
      juce-setColour (colour 0)
      juce-drawText (text, 2, 0, width - 2, height, justification, 1)
    }
    { *;icon + ' .text
    | :try icon call (icons) .:need call
      { icon juce-Image
      | :ok
        g
        juce-drawImageWithin (icon, 2, 2, 16, 16, rectanglePlacement, 0)
        juce-setColour (colour 0)
        juce-drawText (text, 20, 0, width - 20, height, justification, 1)
      }
      { icon 1 juce-Image, icon 2 juce-Image
      | :ok
        g
        juce-drawImageWithin (icon 1, 2, 2, 16, 16, rectanglePlacement, 0)
        juce-drawImageWithin (icon 2, 20, 2, 16, 16, rectanglePlacement, 0)
        juce-setColour (colour 0)
        juce-drawText (text, 38, 0, width - 38, height, justification, 1)
      }
    }
  }
  { juce-selectedRowsChanged: row count
  | :who ' selected (. row + 1) .:try
  }
  { juce-keyPressed: keypress
  | :who :try keypress juce-getKeyCode call
    { 13
    | who activated (. who juce-getLastRowSelected .:need + 1) .:need
      and: :ok 1
    }
    { 27 | who escape .:need and: :ok 1 }
  }
  { juce-listBoxItemDoubleClicked: n count, ?
  | :who ' activated (. n + 1) .:need and: :ok 1
  }
  { focusing: focusing call [.0 .1]
  | :who ' juce-setWantsKeyboardFocus (focusing) .:ok
  }
}
><:[module:. platform qt parent menu .timestamp 2011-07-21T00:25:22.988+02 .language qt]><;
{ parent:. ' juce-DocumentWindow juce-MenuBarModel; menu:. & ' .action
| ;standard @@ [pils standard menu] menu (.window parent) or ();
  parent juce-setMenuBar (parent) and:
  ;menu ' &
  ( standard call {:where? .ruleset :ruleset try|:try ' every [call: match]}
    or:
  )
  ;
  :ok
  parent mind juce-action := [ok] +++ [call: action] -> standard +++ action;
  parent mind juce-menu-action :=
    menu -> [ok] +++ [call: action] -> standard +++ action
  ;
  ;tree @ tree (.menu);
  parent mind juce-menu-names :=
    tree every {submenu: .name; ?|:ok say (name)}
    first (juce-StringArray ()) fold {list := item|:ok list juce-add (item)}
  ;
  parent mind juce-menus :=
    tree every {submenu: .name; ok|:ok}
    every
    { items
    | :who :ok
      juce-PopupMenu () & items fold
      { menu := submenu: .name; items
      | :ok menu juce-addSubMenu: saying (name), items call (who)
      }
      { menu := item:. .name .at
      | :ok
        menu juce-addItem:
        at,
        saying (name)
        (item call {*;shortcut +$ '|:ok "">>"(" (shortcut) ")"} or ""),
        1,
        item call {*;check 1|:ok 1} or 0
      }
      { menu := item:. .name [-] .at | :ok menu juce-addSeparator }
    }
  ;
  parent mind juce-shortcuts :=
    menu firsts
    { *;shortcut $ '
    | ;shortcut ' lower split "+";
      shortcut <+# 1 singlewise call
      { $ ok | :ok ?:? // ' }
      { ok call [."del" delete ."ins" insert ."esc" escape] | :ok }
      { $ ok | :if ok utf-8 count = 1; :ok }
      { ok $ 1 | :ok ' upper }
      .([key down]: .ctrl-key 0 .alt-key 0 .shift-key 0 .key)
      & (shortcut <-# 1) fold
      { ok := modifier call [."ctrl" ctrl-key ."alt" alt-key ."shift" shift-key]
      | :if modifier call (ok) = 0; :ok ' merge (modifier, 1)
      }
      .:try
    }
  ;
  parent juce-menuItemsChanged and:
  parent
}
><:[module:. platform qt parent menu tree .timestamp 2011-07-20T23:32:39.242+02 .language system]><;
{ tree: .menu
| :ok
  menu legs
  { at := item = *;menu path
  | :ok
    (item:. .at) & (path listwise reverse) fold
    { chain := name | :ok name:. .at; chain }
  }
  call
  { level
  | :who :ok
    level groups
    { name:. .at; value | :ok :name (submenu: .name); value }
    { name:. .at; value = item: .? .at | :ok :name (item: .name); value }
    legs {group := values = (*;at) 1 |:ok group:. .at; values}
    order [call: at]
    every
    { group: . (item: .name) .at; (item:. .at) 1 | :ok item:. .name .at }
    { group: . (submenu: .name) .at?; level
    | :ok submenu: .name; level call (who)
    }
  }
}
