><:[module:. platform qt dialog .timestamp 2026-07-06T13:14:31.947+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55 .WindowModal 1;
{ .dialog: .window .boss
| :where :what :ok
  new Q:Dialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title)
  q:setWindowModality (WindowModal)
  q:resize (boss size or [300 200])
  q:show
  when
  { .channel | :who :ok channel: who }
  { listen: handler
  | :who :ok
    ;listener who channel listen (handler);
    who q:show mind listener := listener;
    who
  } 
  { .bug | shit }
  { .close
  | :who :ok
    window mind dialog-listen := ();
    who q:close
  }
  { column: boss
  |:who  :ok
    @ lane: .layout  new Q:VBoxLayout .widget who .boss
  }
  { row: boss
  |:who  :ok
    @ lane: .layout  new Q:HBoxLayout .widget who .boss
  }
  { tree: boss [tree]
  | :who :ok
    :use
    { when: .boss
    | :self :ok
      { .bug | shit }
      { node: boss
      | :who
        ;text boss text .:need; :ok
        who q:addChild (text) when (self when: .boss)
      }
      { .boss | :where :what shit and: :ok boss }
    }
    ;
    ;layout new Q:VBoxLayout(who);
    ;tree new Q:PilsTreeWidget(who) when
    { qs:itemActivated: ?
    | :who :try boss [tree] picked: who q:currentNode
    }
    { node: boss
    | :who
      ;text boss text .:need; :ok
      who q:addRootNode (text)
      when (when (.boss))
    }
    ;
    layout q:addWidget(tree) and:
    who q:setLayout(layout) and:
    tree
  }
  try
  { who
  | new Q:Shortcut ("Ctrl+Shift+F1", who)
    when
    { qs:activated: ?
    | :try @ [pils editor] pinpoint: .where .what
    }
  }
}
