><:[module:. platform qt pils language .timestamp 2008-06-25T15:43:29.112+02 .language system]><;
><:[module:. platform qt pils language qt .timestamp 2009-02-06T10:02:35.939+01 .language system]><;
language: {}? merge:
;"q" ["pils.org/ns/qtmethod":]
."qs" ["pils.org/ns/qtsignal":]
."qe" ["pils.org/ns/qtevent":]
."Q" ["pils.org/ns/qtclass":]
><:[module:. platform qt strap .timestamp 2009-01-16T22:44:21.050+01 .language qt]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ strap: window
| :where :what :ok
  straps
  every (window)
  and:
  window mind pinpointer := (pinpoint: .what .module where this module);
  window
}

