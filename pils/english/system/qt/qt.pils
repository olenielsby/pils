{ parent: .; [row]
| :ok
  ;layout juce-StretchableLayoutManager ();
  parent juce-new (juce-Component ())
  when (@ common)
  when (@ offspring)
  when
  { juce-resized:
  | :who :ok
    ;children
      0 up (who juce-getNumChildComponents - 1)
