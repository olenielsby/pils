><:[module:. platform, .timestamp 2008-06-25T15:43:00.909+02 .language system]><;
><:[module:. platform qt .timestamp 2008-06-25T15:43:08.612+02 .language system]><;
><:[module:. platform qt dialog .timestamp 2026-07-06T13:14:31.947+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55 .WindowModal 1;
{ .dialog: .window .boss
| :where :what :ok
  new Q:Dialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title)
  q:setWindowModality (WindowModal)
  q:resize (boss size or [300 200])
  q:show
  when
  { .channel | :who :ok channel: who }
  { listen: handler
  | :who :ok
    ;listener who channel listen (handler);
    who q:show mind listener := listener;
    who
  } 
  { .bug | shit }
  { .close
  | :who :ok
    window mind dialog-listen := ();
    who q:close
  }
  { column: boss
  |:who  :ok
    @ lane: .layout  new Q:VBoxLayout .widget who .boss
  }
  { row: boss
  |:who  :ok
    @ lane: .layout  new Q:HBoxLayout .widget who .boss
  }
  { tree: boss [tree]
  | :who :ok
    :use
    { when: .boss
    | :self :ok
      { .bug | shit }
      { node: boss
      | :who
        ;text boss text .:need; :ok
        who q:addChild (text) when (self when: .boss)
      }
      { .boss | :ok boss }
    }
    ;
    ;layout new Q:VBoxLayout(who);
    ;tree new Q:PilsTreeWidget(who) when
    { qs:itemActivated: ?
    | :who :try boss [tree] picked: who q:currentNode
    }
    { node: boss
    | :who
      ;text boss text .:need; :ok
      who q:addRootNode (text)
      when (when (.boss))
    }
    ;
    layout q:addWidget(tree) and:
    who q:setLayout(layout) and:
    tree
  }
  try
  { who
  | new Q:Shortcut ("Ctrl+Shift+F1", who)
    when
    { qs:activated: ?
    | :try @ [pils editor] pinpoint: .where .what
    }
  }
}
><:[module:. platform qt edits .timestamp 2026-07-03T22:45:23.295+02 .language qt]><;
;new plumcake;
{ edits: .window .boss
| :possibly
  new Q:TabWidget
  when
  { qs:currentChanged: n | :who :try boss select: .tabs who }
  { .tabs
  | :who :ok
     who q:count up every
    { n | :ok who q:widget: n - 1 }
  }
  { edit: boss
  | :who :ok
    ;tabber who .id boss id;
    ! Search for existing tab with same id
    tabber tabs find
    { tab
    | :if id = tab id; :ok
      (found-tab: .id) bug {} and:
      tab edit
    }
    or:
    ;edit
      new Q:PilsPlainTextEdit (boss text)
      when
      { qs:textChanged:
      | :who boss text:. who q:toPlainText
      }
      { .boss | :ok boss }
      { .text | :who :ok who q:toPlainText }
      { selection: a, b
      | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
      }
      { .selection | :who :ok who q:selection }
      { .focus | :who :ok who q:setFocus }
      { .pickup
      | :who :ok
        ;widget tabber tabs find { tab | :if tab id = id; :ok tab };
        tabber q:setCurrentWidget (widget) or ((bad: tapper:.) bug {})
        and:
        who
      }
    ;
    ;layout new Q:VBoxLayout;
    ;tab new Q:Widget when
      { .edit | :ok edit }
      { .id | :ok boss id }
    ;
    tab q:setLayout (layout) and:
    who q:addTab (tab, boss name) and:
    layout q:addWidget(edit, 1, 0) and:
    edit
  }
  { .current
  | :who :ok who q:currentWidget edit
  }
  try {tabs|who q:addWidget (tabs)}
}
><:[module:. platform qt entry .timestamp 2008-07-23T09:38:47.465+02 .language system]><;
@
><:[module:. platform qt entry icon .timestamp 2010-02-28T14:55:28.627+01 .language qt]><;
{ icon: .size .png | :ok Q:Image: png }
