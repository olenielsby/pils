| :ok
  ;tree new Q:PilsTreeWidget (parent) when
  { qs:itemActivated: ? | :who :try boss picked: who q:currentNode }
  { node: boss
  | :who
    ;text boss text .:need; :ok
    who q:addRootNode (text)
    when (when (.boss))
  }
  { .focus | :who :ok who q:setFocus }
  ;
  layout q:addWidget (tree) and:
