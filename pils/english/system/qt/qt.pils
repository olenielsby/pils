><:[module:. platform qt dialog .timestamp 2026-07-03T22:26:41.578+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55 .WindowModal 1;
{ .dialog: .window .handle
| :ok
  new Q:Dialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (handle title)
  q:setWindowModality (WindowModal)
  q:show
  when
  { .bug | shit }
  { .close | :who :ok who q:close }
  { tree: handle [tree]
  | :who :ok
    :use
    { when: .handle
    | :self :ok
      { .bug | shit }
      { node: handle
      | :who
        ;text handle text .:need; :ok
        who q:addChild (text) when (self when: .handle)
      }
      { .handle | :ok handle }
    }
    ;
    ;layout new Q:VBoxLayout(who);
    ;tree new Q:PilsTreeWidget(who) when
    { qs:itemActivated: ?
    | :who :try handle [tree] picked: who q:currentNode
    }
    { node: handle
    | :who
      ;text handle text .:need; :ok
      who q:addRootNode (text)
      when (when (.handle))
    }
    ;
    layout q:addWidget(tree) and:
    who q:setLayout(layout) and:
    tree
  }
}
><:[module:. platform qt edits .timestamp 2026-07-03T22:45:23.295+02 .language qt]><;
;new plumcake;
{ edits: .window .handle
| :possibly
  new Q:TabWidget
  when
  { qs:currentChanged: n | :who :try handle select: .tabs who }
  { .tabs
  | :who :ok
     who q:count up every
    { n | :ok who q:widget: n - 1 }
  }
  { edit: handle
  | :who :ok
    ;tabber who .id handle id;
    ! Search for existing tab with same id
    tabber tabs find
    { tab
    | :if id = tab id; :ok
      (found-tab: .id) bug {} and:
      tab edit
    }
    or:
    ;edit
      new Q:PilsPlainTextEdit (handle text)
      when
      { qs:textChanged:
      | :who handle text:. who q:toPlainText
      }
      { .handle | :ok handle }
      { .text | :who :ok who q:toPlainText }
      { selection: a, b
      | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
      }
      { .selection | :who :ok who q:selection }
      { .focus | :who :ok who q:setFocus }
      { .pickup
      | :who :ok
        ;widget tabber tabs find { tab | :if tab id = id; :ok tab };
        tabber q:setCurrentWidget (widget) or ((bad: tapper:.) bug {})
        and:
        who
      }
    ;
    ;layout new Q:VBoxLayout;
    ;tab new Q:Widget when
      { .edit | :ok edit }
      { .id | :ok handle id }
    ;
    tab q:setLayout (layout) and:
    who q:addTab (tab, handle name) and:
    layout q:addWidget(edit, 1, 0) and:
    edit
  }
  { .current
  | :who :ok who q:currentWidget edit
  }
  try {tabs|who q:addWidget (tabs)}
}
