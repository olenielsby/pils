><:[module:. platform qt strap .timestamp 2009-01-15T02:44:21.050+01 .language qt]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ strap: window
| :where :what :ok
  straps
  every (window)
  and:
  window mind pinpointer := (pinpoint: .what .module where this module);
  window
}
><:[module:. platform qt window .timestamp 2011-07-21T01:01:26.842+02 .language qt]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ window: .
| :where :what :ok
  straps each (window) and:
  ( @ parent:. window +++
    { juce-new: ok juce-Component
    | :ok window juce-setContentComponent (ok) and: ok
    }
  )
  +++
  { icon: ' | :who window juce-setIcon (icon) .:need and: :ok who }
  { .status
  | :who :ok
    { text: $ text
    | :ok
      ;status-bar
        window mind juce-status-bar or
        ( ;status-bar juce-Label ("snot", "splat");
          window mind juce-status-bar := status-bar;
          window juce-setBottomComponentHeight
          juce-setBottomComponent (status-bar) and:
          status-bar
        )
      ;
      status-bar juce-setText (text, 0) and:
      who
    }
  }
  { .status-bar | :who :ok who status }
  { .inner
  | :who :ok
    { size: '
    | window juce-setContentComponentSize (size) .:need and: :ok who
    }
    { .size
    | :try [juce-getWidth juce-getHeight] every:
      window juce-getContentComponent .:need
    }
  }
  { wenn: ' | :who :ok @ wenn: .; who }
  { .pinpoint
  | :ok @@ [pils run pinpoint] pinpoint: .what .module where this module
  }
  { .up | :who :ok window juce-toFront 1 anyway: who }
  { size: ' | :who window juce-setSize (size) .:need and: :ok who }
  { position: '
  | :who window juce-setTopLeftPosition (position) .:need and: :ok who
  }
  { .close | :who :ok window juce-removeFromDesktop and: who }
}
