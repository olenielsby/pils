><:[module:. platform qt entry window .timestamp 2026-07-08T19:39:44.241+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ window: boss
| :where :what :possibly
  new Q:MainWindow
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title .:need)
  q:setWindowIcon (boss icon .:need)
  q:show
  q:resize (boss size .:need)
  when
  { .channel | :who :ok channel: who }
  { listen: handler
  | :who :ok
    who mind listen := who channel listen (handler);
    who
  }
  { column: boss
  | :who  :ok
    ;inner new Q:Widget;
    who q:setCentralWidget (inner) and:
    @ lane: .layout new Q:VBoxLayout .widget inner .boss
  }
  { row: boss
  | :who  :ok
    ;inner new Q:Widget;
    who q:setCentralWidget (inner) and:
    @ lane: .layout new Q:HBoxLayout .widget inner .boss
  }
  { .splitter
  | :who :ok
    { column: boss
    | :ok
      ;splitter new Q:Splitter 2;
      who q:setCentralWidget (splitter) and:
      @ lane: .layout splitter .widget splitter .boss
    }
    { row: boss
    | :ok
      ;splitter new Q:Splitter 1;
      who q:setCentralWidget (splitter) and:
      @ lane: .layout splitter .widget splitter .boss
    }
  }
  { filedialog: boss | :who :try @ filedialog: .window who .boss }
  { dialog: boss | :who :try @ dialog: .window who .boss }
  { ask: .; options = :where? .ruleset :' rules
  | :who :ok
    ;buttons rules every [call: match];
    ;dialog new Q:Dialog (who) when
    {|}
    ;
    ;hbox new Q:HBoxLayout;
    dialog q:setWindowTitle (say (ask) "?")
    q:setWindowModality 1 ! WindowModal
    q:setLayout (hbox)
    and:
    rules every
    { ;match .action?
    | :ok hbox q:addWidget:
      new Q:PushButton (say (match))
      when
      { qs:clicked: ?
      | :ok
        dialog q:close and: match try (options)
      }
    }
    and:
    dialog q:show
  }
  { icon: ' | :who :try who q:setWindowIcon (icon) }
  { title: $ title | :who ' q:setWindowTitle (title) .:try }
  { .pinpoint | :who :ok who mind pinpointer call: @@ [pils run pinpoint] }
  { .size
  | :who :possibly who juce-getWidth .:need, who juce-getHeight .:need
  }
  { menubar: boss | :who :ok @ menubar: .window who .boss }
  { .statusbar
  | :who :ok
    ;statusbar who q:statusBar;
    { say: $ say | :ok statusbar q:showMessage (say, 0) }
    { .says | :ok statusbar q:currentMessage }
  }
  try
  { who
  | new Q:Shortcut ("Ctrl+Shift+F1", who)
    when
    { qs:activated: ?
    | :try @ [pils editor] pinpoint: .where .what
    }
  }
  .(@ strap) .:need
}
><:[module:. platform qt entry window strap .timestamp 2009-01-16T22:44:21.050+01 .language qt]><;
;straps
  (strap: program: this program filename),
  (strap: mind: program: this program filename)
;
{ strap: window
| :where :what :ok
  straps
  every (window)
  and:
  window mind pinpointer := (pinpoint: .what .module where this module);
  window
}

><:[module:. platform qt filedialog .timestamp 2026-07-04T16:20:33.564+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ .filedialog: .window .boss
| :possibly
  new Q:FileDialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title .:need) .:need
  q:setWindowModality 1 ! WindowModal
  q:setDirectory (boss path .:need)
  q:show
  when
  { .bug | shit }
  { .boss | :where :what shit and: :ok boss }
  { .close | :who :ok who q:close }
  { qs:fileSelected: x | :try boss pick: x }
}
><:[module:. platform qt lane .timestamp 2026-07-09T14:22:11.461+02 .language qt]><;
;new plumcake;
{ lane: .layout .window .boss
| :self
  ;widget new Q:Widget;
  window q:setCentralWidget (widget) and:
  :try self lane: .layout .widget .boss
}
{ lane: .layout .widget .boss
| :self :ok
  layout q:setContentsMargin [0 0 0 0] anyway:
  layout q:setSpacing (boss spacing or 4) anyway:
  widget q:setLayout (layout) anyway:
  { .bug | shit }
  { column: boss
  | :ok
    ;w lane-widget (.boss);
    layout q:addWidget (w) and:
    self lane:
    .layout new Q:VBoxLayout
    .widget w .boss
  }
  { row: boss
  | :ok
    ;w lane-widget (.boss);
    layout q:addWidget(w) and:
    self lane:
    .layout new Q:HBoxLayout
    .widget w .boss
  }
  { label: boss | :try @ label: .boss .parent widget .layout }
  { button: boss | :ok @ button: .boss .parent widget .layout }
  { line-edit: boss | :ok @ line-edit: .boss .parent widget .layout }
  { edit: boss | :ok @ edit: .boss .parent widget .layout }
  { tree: boss | :ok @ tree: .boss .parent widget .layout }
  { tabs: boss | :ok @ tabs: .boss .parent widget .layout }
  { canvas: boss | :ok @ canvas: .boss .parent widget .layout }
}
===
{ lane-widget: .boss | :ok new Q:Widget }
{ lane-widget: .boss
| ;title boss title .:need call {$ ok|:ok} .:need;
  :ok new Q:PilsGroupBox (title) q:setFlat 1
}

><:[module:. platform qt lane button .timestamp 2026-07-09T11:55:32.695+02 .language qt]><;
;new plumcake;
{ button: .boss .parent .layout
| ;title boss title .:need call {$ ok|:ok} .:need;
  :ok
  new Q:PushButton
  try {widget|layout q:addWidget (widget)}
  call (@ ownership: .boss) when
  { qs:clicked: args | :try boss pressed }
  { title: $ title | :who :ok who q:setText (title) }
  { .title | :who :ok who q:text }
  { enabled: enabled | :who :ok who q:setEnabled (enabled) }
  { .enabled | :who :ok who q:isEnabled }
  { .focus | :who :ok who q:setFocus }
  title (title)
}
><:[module:. platform qt lane canvas .timestamp 2026-07-10T17:13:43.393+02 .language qt]><;
><:[module:. platform qt lane edit .timestamp 2026-07-10T16:23:04.421+02 .language qt]><;
;new plumcake;
{ edit: .boss .parent .layout
| :ok
  Q:PilsPlainTextEdit
  try {widget|layout q:addWidget: widget}
  call (@ ownership: .boss) when:
  { qs:textChanged:
  | :who :try boss text:. who q:toPlainText
  }
  { .channel | :who :ok channel: who }
  { .text | :who :ok who q:toPlainText }
  { text: ' | :who :ok who q:setPlainText: text }
  { selection: a, b
  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
  }
  { .selection | :who :ok who q:selection }
  { .focus | :who :ok who q:setFocus }
  { .pickup | :who :ok who }
  +++ boss
}
><:[module:. platform qt lane label .timestamp 2026-07-10T16:42:55.309+02 .language qt]><;
;new plumcake;
{ label: .boss .parent .layout
| :ok
  ;widget
    new Q:Label when
    ( { text: $ text | :who :ok who q:setText (text) }
      { .text | :who :ok who q:text }
      +++ boss
    )
  ;
  layout q:addWidget (widget) and:
  widget
}
><:[module:. platform qt lane line-edit .timestamp 2026-07-10T16:45:29.030+02 .language qt]><;
;new plumcake;
{ line-edit: .boss .parent .layout
| :ok
  ;widget new Q:LineEdit when
  ( { qs:textChanged: text | :who :try who text:. text }
    { text: text | :who :ok who q:setText (text) }
    { .text | :who :ok who q:text }
    { .focus | :who :ok who q:setFocus }
    +++ boss
  )
  ;
  layout q:addWidget (widget) and:
  widget
}
><:[module:. platform qt lane tabs .timestamp 2026-07-10T17:33:07.478+02 .language qt]><;
;new plumcake;
{ tabs: .boss .parent .layout
| :ok
  ;widget new Q:TabWidget;
  layout q:addWidget (widget) and:
  widget when
  ( { .bug | :ok shit }
    { .boss | :where :what shit and: :ok boss }
    { qs:currentChanged: n | :who :try boss select: .tabs who }
    { own: (= id) | :who :try (channel: who) own (id) }
    { .current | :who :ok who q:currentWidget }
    { .tabs
    | :who :ok
      who q:count up every
      { n | :ok who q:widget: n - 1 }
    }	
    { tab: boss
    | :who :ok
      ;layout new Q:VBoxLayout;
      ;tab new Q:Widget when
      ( { .bug | :ok shit }
        +++ boss )
      ;
      tab q:setLayout (layout) and:
      who q:addTab (tab, boss name) and:
      tab
    }
    { tab: boss
    | :who :ok
      ;tab new Q:Widget when
      ( { .bug | :ok shit }
        { .boss | :where :what shit and: :ok boss }
        { column: boss
        | :who :ok
          @ lane: .layout new Q:VBoxLayout .widget who .boss
        }
        { row: boss
        | :who :ok
          @ lane: .layout new Q:HBoxLayout .widget who .boss
        }
        { .select | ;tabs who; :who :ok tabs q:setCurrentWidget (who) and: who }
        +++ boss
      )
      ;
      who q:addTab (tab, boss name) and:
      tab
    }
    +++ boss
  )
}
