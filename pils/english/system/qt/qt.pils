><:[module:. platform qt entry window .timestamp 2026-07-03T22:28:40.347+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ window: handle
| :possibly
  new Q:MainWindow
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (handle title .:need)
  q:setWindowIcon (handle icon .:need)
  q:show
  q:setGeometry (handle geometry .:need)
  when
  { filedialog: handle | :who :try @ filedialog: .window who .handle }
  { dialog: handle | :who :try @ dialog: .window who .handle }
  { ask: .; options = :where? .ruleset :' rules
  | :who :ok
    ;buttons rules every [call: match];
    ;dialog plumcake Q:Dialog (who) when
    {|}
    ;
    ;hbox plumcake Q:HBoxLayout;
    dialog q:setWindowTitle (say (ask) "?")
    q:setWindowModality 1 ! WindowModal
    q:setLayout (hbox)
    and:
    rules every
    { ;match .action?
    | :ok hbox q:addWidget:
      plumcake Q:PushButton (say (match))
      when
      { qs:clicked: ?
      | :ok
        dialog q:close and: match try (options)
      }
    }
    and:
    dialog q:show
  }
  { icon: ' | :who :try who q:setWindowIcon (icon) }
  { qe:mouseButtonPress: ' | (': ') bug {}}
  { qe:mouseButtonRelease: ' | (': ') bug {}}
  { title: $ title | :who ' q:setWindowTitle (title) .:try }
  { .pinpoint | :who :ok who mind pinpointer call: @@ [pils run pinpoint] }
  { .size | :who :possibly who juce-getWidth .:need, who juce-getHeight .:need }
  { menubar: handle
  | :who :ok who q:menuBar
    when
    { action: ..name
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args
      | handle action (.) or:
      }
      and: who
    }
    { action: ..name .shortcut
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args
      | handle action (.) or:
      }
      q:setShortcut (shortcut)
      anyway: who
    }
    { menu: .name
    | :who :self :ok
      who q:addMenu (name) when (self)
    }
    or: who q:menuBar q:clear
  }
  { .statusbar
  | :who :ok
    ;statusbar who q:statusBar;
    { say: $ say | :ok statusbar q:showMessage (say, 0) }
    { .says | :ok statusbar q:currentMessage }
  }
  { .inner
  | :who :ok
    who mind inner or:
    ;inner plumcake Q:Widget when
    { .vertical
    | :who :ok
      ;layout
        plumcake Q:VBoxLayout when
        { .splitter
        | :who :ok
          ;splitter
            plumcake Q:Splitter 2 when
            { label: text
            | :who :ok
              ;label plumcake Q:Label (text) when {|};
              who q:addWidget (label) and:
              label
            }
            { edit: text
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit (text) when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup | :who :ok who }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { .edit
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit "" when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup | :who :ok who }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { tabs: handle
            | :who :ok
              plumcake Q:TabWidget
              when
              { qs:currentChanged: n | :who :try handle select: .tabs who }
              { .tabs
              | :who :ok
                who q:count up every
                { n | :ok who q:widget: n - 1 }
              }
              { edit: handle
              | :who :ok
                ;tabber who .id handle id;
                ! Search for existing tab with same id
                tabber tabs find
                { tab
                | :if id = tab id; :ok
                  (found-tab: .id) bug {} and:
                  tab edit
                }
                or:
                ;edit
                  plumcake Q:PilsPlainTextEdit (handle text)
                  when
                  { qs:textChanged:
                  | :who handle text:. who q:toPlainText
                  }
                  { .handle | :ok handle }
                  { .text | :who :ok who q:toPlainText }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup
                  | :who :ok
                    ;widget tabber tabs find { tab | :if tab id = id; :ok tab };
                    tabber q:setCurrentWidget (widget) or ((bad: tapper:.) bug {})
                    and:
                    who
                  }
                ;
                ;layout plumcake Q:VBoxLayout;
                ;tab plumcake Q:Widget when
                { .edit | :ok edit }
                { .id | :ok handle id }
                ;
                tab q:setLayout (layout) and:
                who q:addTab (tab, handle name) and:
                layout q:addWidget(edit, 1, 0) and:
                edit
              }
              { .current
              | :who :ok who q:currentWidget edit
              }
              try {tabs|who q:addWidget (tabs)}
            }
          ;
          who q:addWidget (splitter, 1, 0) and:
          splitter
        }
      ;
      who q:setLayout (layout) and:
      layout
    }
    ;
    who q:setCentralWidget (inner) and:
    inner
  }
  .(@ strap) .:need
}

><:[module:. platform qt filedialog .timestamp 2026-07-03T22:28:53.666+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ .filedialog: .window .handle
| :possibly
  new Q:FileDialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (handle title .:need) .:need
  q:setWindowModality 1 ! WindowModal
  q:setDirectory (handle path .:need)
  q:show
  when
  { .bug | shit }
  { .handle | :ok handle }
  { .close | :who :ok who q:close }
  { qs:fileSelected: x | :try handle pick: x }
}
