  { try | :who :try ' call: who: .; who mind juce-when or () }
  { when: more
  | :who :ok who mind juce-when := who mind juce-when or () +++ more; who
  }
  { tip: tip | :who :ok who mind tip := tip; who }
  { focusing: focusing call [.0 .1]
  | :who ' juce-setWantsKeyboardFocus (focusing) .:ok
  }
  { .hot
  | :who
    :if who juce-currentFileIsValid = 1; :ok
    who juce-getCurrentFile juce-getFullPathName *=* ("\", "/") "/" .(folder)
