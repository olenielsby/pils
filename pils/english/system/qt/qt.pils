><:[module:. platform qt wrapper .timestamp 2008-08-20T18:12:46.466+02 .language system]><;
@@><:[module:. platform qt wrapper image .timestamp 2011-07-21T00:03:52.965+02 .language qt]><;
{ paint: painter
| :who
  @ graphics (. juce-Graphics (who) .:need) try (painter) and: :ok who
}
{ .height | :who ' juce-getHeight .:ok }
{ .width | :who ' juce-getWidth .:ok }
{ .png
| :who
  ;stream juce-MemoryOutputStream ();
  juce-PNGImageFormat () juce-writeImageToStream (who, stream) .:need and:
  :ok stream juce-getData
}
