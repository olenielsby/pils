><:[module:. platform qt menubar .timestamp 2026-07-04T17:05:50.309+02 .language qt]><;
{ menubar: .window .boss
| :ok window q:menuBar
  when
  { action: ..name
  | :who :ok
    who q:addAction (name)
    when
    { qs:triggered: args | :try boss action (.) }
    and: who
  }
  { action: ..name .shortcut
  | :who :ok
    who q:addAction (name)
    when
    { qs:triggered: args | :try boss action (.) }
    q:setShortcut (shortcut)
    anyway: who
  }
  { menu: .name
  | :who :self :ok
    who q:addMenu (name) when (self)
  }
  or: window q:menuBar q:clear
}
><:[module:. platform qt ownership .timestamp 2026-07-10T16:07:28.172+02 .language qt]><;
! If the component boss has an id and an owner,
! a listener must be installed in the owner's channel,
! to allow the component to be found by its id.

! This is done in a slightly obscure way, by wrapping
! the newly created and parented component in an
! object that intercepts the following when-clause,
! keeping the listener in a dummy variable.

! This is for use only in the lane component modules,
! assuming the form:
!   widget call (@ ownership: .boss) when {...|...}...

! Dummy ownership does nothing

{ ownership: .boss | :ok [ok] }
{ ownership: .boss
| :who
  ;channel boss owner .:need call { = owner | :ok channel: owner } .:need
  .id boss id .:need call { = ok | :ok } .:need
  ;
  :ok
  { widget
  | :ok
     ;trap () merge ((own: id), widget);
     ;listener channel listen (trap);
     { when: rules | :ok widget when: rules +++ listener }
  }
}
