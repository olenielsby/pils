    ;
    layout juce-clearAllItems() and:
    children every
    { ? | :ok 8, -1, -1 }
    { child | ;width child mind width .:need; :ok width, width, width }
    legs { n := hint | layout juce-setItemLayout: (n - 1) & hint }
    and:
    layout juce-layOutComponents:
    children, 0, 0, who juce-getWidth, who juce-getHeight, 0, 1
  }
  { juce-new: ok juce-Component
  | :who :ok who juce-addAndMakeVisible (ok) juce-resized and: ok
  }
}
