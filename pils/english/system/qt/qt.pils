><:[module:. platform qt entry window .timestamp 2026-07-06T15:26:42.354+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ window: boss
| :where :what :possibly
  new Q:MainWindow
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title .:need)
  q:setWindowIcon (boss icon .:need)
  q:show
  q:resize (boss size .:need)
  when
  { .channel | :who :ok channel: who }
  { listen: handler
  | :who :ok
    who mind listen := who channel listen (handler);
    who
  }
  { column: boss
  | :who  :ok
    (cw1: who q:centralWidget or "nixen") bug {} and:
    ;inner new Q:Widget;
    who q:setCentralWidget (inner) and:
    (cw2: who q:centralWidget or "nixen") bug {} and:
    @ lane: .layout  new Q:VBoxLayout .widget inner .boss
  }
  { row: boss
  | :who  :ok
    ;inner new Q:Widget;
    who q:setCentralWidget (inner) and:
    @ lane: .layout  new Q:HBoxLayout .widget inner .boss
  }
  { filedialog: boss | :who :try @ filedialog: .window who .boss }
  { dialog: boss | :who :try @ dialog: .window who .boss }
  { ask: .; options = :where? .ruleset :' rules
  | :who :ok
    ;buttons rules every [call: match];
    ;dialog plumcake Q:Dialog (who) when
    {|}
    ;
    ;hbox plumcake Q:HBoxLayout;
    dialog q:setWindowTitle (say (ask) "?")
    q:setWindowModality 1 ! WindowModal
    q:setLayout (hbox)
    and:
    rules every
    { ;match .action?
    | :ok hbox q:addWidget:
      plumcake Q:PushButton (say (match))
      when
      { qs:clicked: ?
      | :ok
        dialog q:close and: match try (options)
      }
    }
    and:
    dialog q:show
  }
  { icon: ' | :who :try who q:setWindowIcon (icon) }
  { qe:mouseButtonPress: ' | (': ') bug {}}
  { qe:mouseButtonRelease: ' | (': ') bug {}}
  { title: $ title | :who ' q:setWindowTitle (title) .:try }
  { .pinpoint | :who :ok who mind pinpointer call: @@ [pils run pinpoint] }
  { .size
  | :who :possibly who juce-getWidth .:need, who juce-getHeight .:need
  }
  { menubar: boss | :who :ok @ menubar: .window who .boss }
  { old-menubar: boss
  | :who :ok who q:menuBar
    when
    { action: ..name
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args | :try boss action (.) }
      and: who
    }
    { action: ..name .shortcut
    | :who :ok
      who q:addAction (name)
      when
      { qs:triggered: args | :try boss action (.) }
      q:setShortcut (shortcut)
      anyway: who
    }
    { menu: .name
    | :who :self :ok
      who q:addMenu (name) when (self)
    }
    or: who q:menuBar q:clear
  }
  { .statusbar
  | :who :ok
    ;statusbar who q:statusBar;
    { say: $ say | :ok statusbar q:showMessage (say, 0) }
    { .says | :ok statusbar q:currentMessage }
  }
  { .inner
  | :who :ok
    who mind inner or:
    ;inner plumcake Q:Widget when
    { .vertical
    | :who :ok
      ;layout
        plumcake Q:VBoxLayout when
        { .splitter
        | :who :ok
          ;splitter
            plumcake Q:Splitter 2 when
            { label: text
            | :who :ok
              ;label plumcake Q:Label (text) when {|};
              who q:addWidget (label) and:
              label
            }
            { edit: text
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit (text) when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup | :who :ok who }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { .edit
            | :who :ok
              ;edit plumcake Q:PilsPlainTextEdit "" when
              { .text | :who :ok who q:toPlainText }
              { text: ' | :who :ok who q:setPlainText: text }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup | :who :ok who }
              ;
              who q:addWidget (edit) and:
              edit
            }
            { tabs: boss
            | :who :ok
              plumcake Q:TabWidget
              when
              { qs:currentChanged: n | :who :try boss select: .tabs who }
              { .tabs
              | :who :ok
                who q:count up every
                { n | :ok who q:widget: n - 1 }
              }
              { edit: boss
              | :who :ok
                ;tabber who .id boss id;
                ! Search for existing tab with same id
                tabber tabs find
                { tab
                | :if id = tab id; :ok
                  (found-tab: .id) bug {} and:
                  tab edit
                }
                or:
                ;edit
                  plumcake Q:PilsPlainTextEdit (boss text)
                  when
                  { qs:textChanged:
                  | :who boss text:. who q:toPlainText
                  }
                  { .boss | :ok boss }
                  { .text | :who :ok who q:toPlainText }
                  { selection: a, b
                  | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
                  }
                  { .selection | :who :ok who q:selection }
                  { .focus | :who :ok who q:setFocus }
                  { .pickup
                  | :who :ok
                    ;widget tabber tabs find { tab | :if tab id = id; :ok tab };
                    tabber q:setCurrentWidget (widget) or ((bad: tapper:.) bug {})
                    and:
                    who
                  }
                ;
                ;layout plumcake Q:VBoxLayout;
                ;tab plumcake Q:Widget when
                { .edit | :ok edit }
                { .id | :ok boss id }
                ;
                tab q:setLayout (layout) and:
                who q:addTab (tab, boss name) and:
                layout q:addWidget(edit, 1, 0) and:
                edit
              }
              { .current
              | :who :ok who q:currentWidget edit
              }
              try {tabs|who q:addWidget (tabs)}
            }
          ;
          who q:addWidget (splitter, 1, 0) and:
          splitter
        }
      ;
      who q:setLayout (layout) and:
      layout
    }
    ;
    who q:setCentralWidget (inner) and:
    inner
  }
  try
  { who
  | new Q:Shortcut ("Ctrl+Shift+F1", who)
    when
    { qs:activated: ?
    | :try @ [pils editor] pinpoint: .where .what
    }
  }
  .(@ strap) .:need
}
><:[module:. platform qt filedialog .timestamp 2026-07-04T16:20:33.564+02 .language qt]><;
;new plumcake .WA_DeleteOnClose 55;
{ .filedialog: .window .boss
| :possibly
  new Q:FileDialog (window)
  q:setAttribute (WA_DeleteOnClose, 1)
  q:setWindowTitle (boss title .:need) .:need
  q:setWindowModality 1 ! WindowModal
  q:setDirectory (boss path .:need)
  q:show
  when
  { .bug | shit }
  { .boss | :ok boss }
  { .close | :who :ok who q:close }
  { qs:fileSelected: x | :try boss pick: x }
}
><:[module:. platform qt lane .timestamp 2026-07-06T21:39:02.150+02 .language qt]><;
;new plumcake;
{ lane: .layout .window .boss
| :self
  ;widget new Q:Widget;
  window q:setCentralWidget (widget) and:
  :try self lane: .layout .widget .boss
}
{ lane: .layout .widget .boss
| :self :ok
  widget q:setLayout (layout) and:
  { .bug | shit }
  { column: boss
  | :ok
    ;w new Q:Widget;
    layout q:addWidget (w) and:
    self lane: .layout new Q:VBoxLayout .widget w .boss
  }
  { row: boss
  | :ok
    ;w new Q:Widget;
    layout q:addWidget(w) and:
    self lane: .layout new Q:HBoxLayout .widget w .boss
  }
  { label: boss | :try @ label: .boss .parent widget .layout }
  { button: boss | :ok @ button: .boss .parent widget .layout }
  { line-edit: boss | :ok @ line-edit: .boss .parent widget .layout }
  { edit: boss | :ok @ edit: .boss .parent widget .layout }
  { tree: boss | :ok @ tree: .boss .parent widget .layout }
  { tabs: boss | :ok @ tabs: .boss .parent widget .layout }
  { canvas: boss | :ok @ canvas: .boss .parent widget .layout }
}
><:[module:. platform qt lane button .timestamp 2026-07-05T22:30:59.700+02 .language qt]><;
;new plumcake;
{ button: .boss .parent .layout
| ;title boss title .:need call {$ ok|:ok} .:need;
  :ok
  ;widget
    new Q:PushButton
    when
    { qs:clicked: args | :try boss pressed }
    { title: $ title | :who :ok who q:setText (title) }
    { .title | :who :ok who q:text }
    { enabled: enabled | :who :ok who q:setEnabled (enabled) }
    { .enabled | :who :ok who q:isEnabled }
    { .focus | :who :ok who q:setFocus }
  ;
  widget title (title) and:
  layout q:addWidget (widget) and:
  widget
}
><:[module:. platform qt lane canvas .timestamp 2026-07-05T13:51:26.780+02 .language qt]><;
><:[module:. platform qt lane edit .timestamp 2026-07-06T14:36:44.390+02 .language qt]><;
;new plumcake;
{ edit: .boss .parent .layout
| :ok
  ;widget Q:PilsPlainTextEdit (boss text or "") when
    { qs:textChanged:
    | :who :try boss text:. who q:toPlainText
    }
    { .text | :who :ok who q:toPlainText }
    { text: ' | :who :ok who q:setPlainText: text }
    { selection: a, b
    | :who :ok who q:setSelection(a, b) q:ensureCursorVisible
    }
    { .selection | :who :ok who q:selection }
    { .focus | :who :ok who q:setFocus }
    { .pickup | :who :ok who }
  ;
  layout q:addWidget (widget) and:
  widget
}
><:[module:. platform qt lane label .timestamp 2026-07-05T22:34:23.304+02 .language qt]><;
;new plumcake;
{ label: .boss .parent .layout
| ;text boss text .:need call {$ ok|:ok} .:need;
  :ok
  ;widget
    new Q:Label
    when
    { text: $ text | :who :ok who q:setText (text) }
    { .text | :who :ok who q:text }
  ;
  widget text (text) and:
  layout q:addWidget (widget) and:
  widget
}
><:[module:. platform qt lane line-edit .timestamp 2026-07-05T17:18:34.619+02 .language qt]><;
;new plumcake;
{ line-edit: .boss .parent .layout
| :ok
  ;widget new Q:LineEdit when
    { qs:textChanged: text | :try boss text: text }
    { text: text | :who :ok who q:setText (text) }
    { .text | :who :ok who q:text }
    { .focus | :who :ok who q:setFocus }
  ;
  layout q:addWidget (widget) and:
  widget
}
