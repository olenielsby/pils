><:[module: . parse, .timestamp 2007-11-26T01:31:18.419+01 .language system]><;
><:[module: . parse language .language system]><;
><:[module: . parse language vhdl .timestamp 2009-01-29T15:56:53.370+01 .language system]><;
{ parse: .text .tag
| :try
  @ tokenize (.text .tag)
  first [design-file: .?]
  fold (@@ rules)
}
><:[module: . parse language vhdl positions .timestamp 2008-08-13T11:58:53.576+02 .language system]><;
{ positions: .text
| :ok @@ . [tokenize split]
  split (.text) first 0 fold {p := ?, ? $ c|:ok list := p + c} .(:list . := 0;)
}
><:[module: . parse language vhdl positions test .timestamp 2008-08-12T17:04:57.666+02 .language system]><;
{ .test
| :ok
  ;filename
    this module filename <-#=* "/lib/".
    "/testdata/vhdl/dsp6415/dsp6415.vhd"
  ;
  ;text file (filename) text;
!  (now,
 positions (.text) !and: now)
}
