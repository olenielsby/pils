{ tokenize: .text .tag
| :ok @ split (.text)
  & [symbol "",]
  legs
  { at := token = (?, original) | :ok token: ..tag tag: ..at .original }
  { at := [symbol] // ?, original
  | :ok token: . original .tag tag: ..at .original
  }
  { at := [symbol], original
  | :ok token: . original .tag tag: ..at .original
  }
  { at := [all], original | :ok token: . "all" .tag tag: ..at .original }
  { at := [keyword], original
  | :ok token: . original lower .tag tag: ..at .original
  }
  { at := [basic-identifier], original
  | :ok token: . [identifier], original lower .tag tag: ..at .original
  }
  { ? := [blank] // ?, ? | ? }
  { ? := [blank], ? | ? }
}
><:[module: . parse language vhdl tokenize keywords .timestamp 2008-08-12T15:22:04.182+02 .language system]><;
! This module is not used - keywords are recognized in the splitter

{ [test test]
| :ok
[
! VHDL-87
  "abs", "access", "after", "alias", "all", "and", "architecture", "array", "assert",
  "attribute", "begin", "block", "body", "buffer", "bus",
  "case", "component", "configuration", "constant", "disconnect", "downto",
  "else", "elsif", "end", "entity", "exit", "file", "for", "function",
  "generate", "generic", "guarded", "if", "in", "inout", "is",
  "label", "library", "linkage", "loop", "map", "mod",
  "nand", "new", "next", "nor", "not", "null",
  "of", "on", "open", "or", "others", "out",
  "package", "port", "procedure", "process",
  "range", "record", "register", "rem", "report", "return",
  "select", "severity", "signal", "subtype", "then", "to", "transport", "type",
  "units", "until", "use", "variable", "wait", "when", "while", "with", "xor",
! VHDL-93
  "group", "impure", "inertial", "literal", "postponed", "pure",
  "reject", "rol", "ror", "shared", "sla", "sll", "sra", "srl", "unaffected", "xnor",
! VHDL-2001
  "protected"
]
each
  {keyword|:ok (keyword) " " (keyword upper) ""/} splice ""}
><:[module: . parse language vhdl tokenize split .timestamp 2008-08-12T15:26:19.994+02 .language system]><;
{ split: .text . $.
| :ok
  text split
  [ [blank|tickable] [blank|ticked] blank symbol keyword all
    bit-string-literal
    basic-identifier identifier
    [symbol|tick] character-literal [symbol|tickable] string-literal
    decimal-literal based-literal
    .[blank|tickable] tickable blank,
    .[blank|ticked] [/: [symbol|tick]] blank,
    .nonticked [-: /: [symbol|tick] [blank|ticked]]
    .blank [+: " ", "">, ""=, ""<, "--" [*: [-: ""<, ""=] 1,]]
    ! extended-identifier-s are read directly as identifier,
    ! basic-identifier must be lowered for case insensitivity
    .basic-identifier letter [*: letter, "0-9", "_" [-: "_"]],
    .identifier "\" [*: [-: "\"] 1,] "\",
    .letter "A-Z", "a-z"
    .symbol
      "(", "[", ":=", ";", "<=", ">=", "=>", "=", "<>", "<", ">",
      ":", ",", ".", "**", "*", "+", "-", "/=", "/", "&", "|"
    .[symbol|tickable] ")", "]"
    .[symbol|tick] tickable "'",
    .tickable
      [ /:
        [symbol|tickable]
        [blank|tickable]
        all
        identifier
        basic-identifier
        string-literal
        character-literal
      ]
    .string-literal """" [*: [-: """"] 1, """"""] """",
    .bit-string-literal base-specifier """" based-integer """",
    .based-integer extended-digit [*: ["_", []] extended-digit,],
    .base-specifier "B", "O", "X", "b", "o", "x"
    .extended-digit "0-9", "A-Z", "a-z"
!!
PILS works with utf-8 encoded VHDL, i.e. some char literals are multibyte-encoded
!!
    .character-literal "'" [""20"-"7e, utf-8-encoded-prinatble-high-ansi-character] "'",
    .utf-8-encoded-prinatble-high-ansi-character ""c2. ""a0"-"bf, ""c3. ""80"-"bf,
    .decimal-literal integer ["." integer, [-: "#"]] [exponent, []],
    .integer "0-9" [*: ["_", []] "0-9",],
    .exponent ["E", "e"] ["+", "-", []] integer,
    .based-literal integer "#" based-integer ["." based-integer, []] "#" [exponent, []],
    ! Keywords must be recognized by the splitter, to deal correctly with ticks.
    ! For case insensitivity, letters are defined by symbolic names.
    ! For speed, keywords are grouped by initial letter, and sectioned.
    .a "a", "A"
    .b "b", "B"
    .c "c", "C"
    .d "d", "D"
    .e "e", "E"
    .f "f", "F"
    .g "g", "G"
    .h "h", "H"
    .i "i", "I"
    .j "j", "J"
    .k "k", "K"
    .l "l", "L"
    .m "m", "M"
    .n "n", "N"
    .o "o", "O"
    .p "p", "P"
    .q "q", "Q"
    .r "r", "R"
    .s "s", "S"
    .t "t", "T"
    .u "u", "U"
    .v "v", "V"
    .w "w", "W"
    .x "x", "X"
    .y "y", "Y"
    .z "z", "Z"
    ! The only keyword that can be followed by a tick is  all
    .all "a" l l [-: letter, "0-9", "_"], "A" l l [-: letter, "0-9", "_"],
    .keyword
    [-: -: "a-m"]
    nonticked
    [ "a"
      [ b s, c c e s s, f t e r, l i a s, n d, r c h i t e c t u r e, r r a y,
        s s e r t, t t r i b u t e
      ],
      "b" [e g i n, l o c k, o d y, u f f e r, u s],
      "c" [a s e, o m p o n e n t, o n f i g u r a t i o n, o n s t a n t],
      "d" [i s c o n n e c t, o w n t o],
      "e" [l s e, l s i f, n d, n t i t y, x i t],
      "f" [i l e, o r, u n c t i o n],
      "g" [e n e r a t e, e n e r i c, u a r d e d, r o u p],
      !  Note order: n o u t, n e r t i a l  must be before  n
      "i" [f, m p u r e, n e r t i a l, n o u t, n, s],
      "l" [a b e l, i b r a r y, i n k a g e, o o p, i t e r a l],
      "m" [a p, o d],
    ]
    [-: letter, "0-9", "_"]
    ,
    [-: -: "n-z"]
    nonticked
    [ "n" [a n d, e w, e x t, o r, o t, u l l],
      "o" [f, n, p e n, r, t h e r s, u t],
      "p"
      [ a c k a g e, o r t, r o c e d u r e, r o c e s s, o s t p o n e d, u r e,
        r o t e c t e d
      ],
      "r"
      [ a n g e, e c o r d, e g i s t e r, e m, e p o r t, e t u r n, e j e c t,
        o l, o r
      ],
      "s" [e l e c t, e v e r i t y, i g n a l, u b t y p e, h a r e d, l a, l l, r a, r l],
      "t" [h e n, o, r a n s p o r t, y p e],
      "u" [n i t s, n t i l, s e, n a f f e c t e d],
      "v" a r i a b l e,
      "w" [a i t, h e n, h i l e, i t h],
      "x" [o r, n o r],
    ]
    [-: letter, "0-9", "_"]
    ,
    [-: -: "A-M"]
    nonticked
    [ "A"
      [ b s, c c e s s, f t e r, l i a s, n d, r c h i t e c t u r e, r r a y,
        s s e r t, t t r i b u t e
      ],
      "B" [e g i n, l o c k, o d y, u f f e r, u s],
      "C" [a s e, o m p o n e n t, o n f i g u r a t i o n, o n s t a n t],
      "D" [i s c o n n e c t, o w n t o],
      "E" [l s e, l s i f, n d, n t i t y, x i t],
      "F" [i l e, o r, u n c t i o n],
      "G" [e n e r a t e, e n e r i c, u a r d e d, r o u p],
      !  Note order:  (i) n o u t, (i) n e r t i a l  must be before  (i) n
      "I" [f, m p u r e, n e r t i a l, n o u t, n, s],
      "L" [a b e l, i b r a r y, i n k a g e, o o p, i t e r a l],
      "M" [a p, o d],
    ]
    [-: letter, "0-9", "_"]
    ,
    [-: -: "N-Z"]
    nonticked
    [ "N" [a n d, e w, e x t, o r, o t, u l l],
      "O" [f, n, p e n, r, t h e r s, u t],
      "P"
      [ a c k a g e, o r t, r o c e d u r e, r o c e s s, o s t p o n e d, u r e,
        r o t e c t e d
      ],
      "R"
      [ a n g e, e c o r d, e g i s t e r, e m, e p o r t, e t u r n, e j e c t,
        o l, o r
      ],
      "S" [e l e c t, e v e r i t y, i g n a l, u b t y p e, h a r e d, l a, l l, r a, r l],
      "T" [h e n, o, r a n s p o r t, y p e],
      "U" [n i t s, n t i l, s e, n a f f e c t e d],
      "V" a r i a b l e,
      "W" [a i t, h e n, h i l e, i t h],
      "X" [o r, n o r],
    ]
    [-: letter, "0-9", "_"]
    ,
  ]
}
><:[module: . parse language vhdl tokenize test .timestamp 2008-08-12T16:23:35.010+02 .language system]><;
{ .test
| :ok
  ;filename
    this module filename <-#=* "/lib/".
    "/testdata/vhdl/dsp6415/dsp6415.vhd"
  ;
  ;text file (filename) text;
  (now, tokenize (.text .tag ()) and: now)
!  tokenize (.text .tag ())= tokenize (.text .x ())
}
><:[module: . parse language vhdl tokenize' .timestamp 2008-03-31T02:11:50.467+02 .language system]><;
{ tokenize: .text .tag
| :ok @ split (.text)
  & [symbol "",]
  first 0 fold
  { p := token = (type, original $ c)
  | :ok
    list :=
    ( token: .. try
      { [symbol] // ?, ok | :ok }
      { [symbol], ok | :ok }
      { [all], ok | :ok "all" }
      { [keyword], ok | :ok . lower }
      { [basic-identifier], ok | :ok [identifier], ok lower }
      .tag tag: ..at p, p + c .original
    )
    ;
    p + c
  }
  { p := [blank] // ?, ? $ c | :ok p + c }
  { p := [blank], ? $ c | :ok p + c }
  .:list
}
