  }
}
><:[module:. parse language csharp tokenize positions .timestamp 2011-09-07T13:56:30.632+02 .language system]><;
{ positions: .text
| :ok @ split (.text) first 0 fold
  {p := ?, ? $ c|:ok list := p, p + c; p + c}
