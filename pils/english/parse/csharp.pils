><:[module:. parse language csharp test data .timestamp 2011-09-26T13:22:30.903+02 .language system]><;
{ .data
| :ok
  this module path <-#~* "//"
  !"/Murbrok/"
  "/Brokkeriet/"
  .(folder) files
  each {ok file: ? <$* ".cs"|:ok}
