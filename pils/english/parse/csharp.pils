><:[module:. parse language csharp tokenize split .timestamp 2011-09-13T16:03:10.161+02 .language system]><;
{ split: .text
| :ok
  text split
  [ space
    string-literal
    character-literal
    floating-literal
    integer-literal
    identifier
    separator
    operator
    .linefeed ""=, ""/, ""<
    .space [+: linefeed, " ", "">, "/*" [=*: "*/"], "//" [=*: linefeed]]
    .identifier ["A-Z", "a-z", "_", "$"] [*: "A-Z", "a-z", "_", "$", "0-9"],
    .string-literal ["L" []] """" [*: [-: """"] string-character,] """",
    .character-literal ["L" []] "'" [-: "'"] string-character "'",
    .string-character
      [-: "\"] 1,
      "\"
      [ "'", """", "?", "\", "a", "b", "f", "n", "r", "t", "v",
        octal-digit [octal-digit [octal-digit [],], []],
        "x" [+: hexadecimal-digit],
        "u" hex-quad,
        "U" hex-quad hex-quad
      ],
    .integer-literal
      [ "1-9" [*: "0-9"],
        "0" [["X", "x"] [+: hexadecimal-digit], [*: octal-digit]]
      ]
      [ ["U", "u"] ["ll", "l", "LL", "L", []],
        ["ll", "l", "LL", "L", []] ["U", "u", []]
      ]
      ,
    .floating-literal
      [ [ +: "0-9" ] [ "." [*: "0-9"] [exponent-part, []], exponent-part ],
        "." [+: "0-9"] [exponent-part, []]
      ]
      [ "f", "l", "F", "L", [] ]
      ,
    .exponent-part ["e", "E"] ["+", "-", []] [+: "0-9"],
    .hexadecimal-digit "0-9", "a-f", "A-F"
    .hex-quad
      hexadecimal-digit hexadecimal-digit hexadecimal-digit hexadecimal-digit,
    .octal-digit "0-7"
    .ellipsis "..."
    .operator
      ["!", "%", "*", "/", "=", "^"] ["=", []],
      "&" ["&", "=", []],
      "|" ["|", "=", []],
      "+" ["+", "=", []],
      "-" ["-", "=", ">*", ">", []],
      "." ["*", []],
      ":" [":", []],
      "<" ["<", []] ["=", []],
      ">" [">", []] ["=", []],
      "?" [-: "?" ["'", "!", "/", "<", ">", "(", ")"],],
      "~"
    .separator ";", ",", "[", "]", "(", ")", "{", "}"
  ]
}
