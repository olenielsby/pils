| :who :ok
  (statement: . term; state) call (who) :=
}
{ (statement: .term; state) := . = token: . "=" .tag?
| :ok term: .level [=] .embrace (); assign: . term ."=" =.; state
}
{ (term: .level .embrace; state)
  := name =
  token: . ? call [.identifier .text .double .integer .imaginary], ? .tag?
| :ok term: . name .level .embrace; state
}
{ (term: ..level .embrace?; state) :=
| :who :ok state call (who) (:= term: .) call (who) :=
