| :ok statements: .."end" =.; state
}
{ (statements: .."end"; state) := stop = token: .? call [.""= .";"] .tag?
| :who :ok state call (who) := statements: ..end (end: ."end" .stop)
}
{ (statements: .."end"; state) := . = token: . "" .tag?
| :who :ok
  state call (who) (:= statements: ..end end: ."end" .stop ()) call (who) :=
}
{ (state = statements: .?; ?) := term: . | :ok statement: .term; state }
