| :ok try: ."try" .stop .statements ."catch" =.; state
}
{ (try: ."try" .stop .statements ."catch"; state)
  := . = token: . [identifier], ? .tag?
| :ok
  try: ."try" .stop .statements ."catch" .catch =.; state
}
{ (try: ."try" .stop .statements ."catch"; state)
  := . = token: .? call [.""= .";" .","] .tag?
| :ok
  statements: . ();
  try: ."try" .stop .statements ."catch" .catch () .[stop: "catch"] =.; state
}
{ (try: ."try" .stop .statements ."catch" .catch; state)
  := . = token: .? call [.""= .";" .","] .tag?
| :ok
  statements: . ();
  try: ."try" .stop .statements ."catch" .catch .[stop: "catch"] =.; state
}
{ ( try: ."try" .stop .statements ."catch" .catch .[stop: "catch"]; state )
  := statements: . statements [catch] .end
| :who :ok
  state call (who) :=
  statement: .
  try: ."try" .stop .statements .end .catch
  catch: ..stop stop "catch" .statements statements [catch]
}
{ (state = statements: .?; ?) := . = token: . "break" .tag?
| :ok statement: . (break: ."break" =.); state
}
{ (statement: .term command = (token: . [identifier], ? .tag?); state)
  := mash = token: . [identifier], ? .tag?
| :ok command: ..arguments () .mash .,; state
}
{ (command: ..arguments .mash; state) :=
| :ok command: ..arguments .mash . & =.; state
}
{ (command: ..arguments .mash; state) := token: . " " .tag?
| :ok command: ..arguments . & (mash,) .mash (); state
}
{ (command: ..arguments .mash; state)
  := stop = token: .? call [."," .";" .""=] .tag?
| :who :ok
  state call (who) := statement: . command: ..arguments . & (mash,) .stop
}
{ (statements: .; state) := token: . "" .tag?
| :who :ok state call (who) := statements: ..end ()
}
{ [matlab] := [function] * done
| :ok done: .
}
><:[module: . parse language matlab samples .timestamp 2009-01-29T01:38:57.423+01 .language system]><;
{ .samples
| :ok
  folder (platform path documents . "matlab-samples/") files
  each
  { ok file: filename <$* ".zip"
  | :ok . zip each
    {name <$* ".m", data, ?|:ok filename . "::" . name, data}
    === ;filename . <+#-* "/"
  }
  splice
}
><:[module: . parse language matlab test .timestamp 2009-02-01T16:47:48.075+01 .language system]><;
;at 323;
{ .test
| :ok
  @ testbench (.text @ samples . (at) 2 .language [matlab])
}
><:[module: . parse language matlab tokenize .timestamp 2009-01-29T17:51:56.589+01 .language system]><;
{ tokenize: .text .tag
| :ok @ split (.text)
  & [symbol "",]
  legs
  { at := token = (?, original) | :ok token: ..tag tag: ..at .original }
  { at := ? call [.symbol .symbol'], token
  | :ok token: ..tag tag: ..at .original token
  }
  { at := token call [.space " " .newline ""=], original
  | :ok token: ..tag tag: ..at .original
  }
  { at := [identifier], token call
    [ ."break" ."case" ."catch" ."continue" ."else" ."elseif" ."end"
      ."for" ."function" ."global" ."if" ."otherwise" ."persistent"
      ."return" ."switch" ."try" ."while" 
    ]
  | :ok token: ..tag tag: ..at .original token
  }
}
><:[module: . parse language matlab tokenize positions .timestamp 2009-01-29T17:34:12.605+01 .language system]><;
{ positions: .text
| :ok
  @ split (.text)
  first 0 fold {at := ?, ? $ (count)|:ok ;at' at + count; list := (at, at'); at'}
  .:list
}
><:[module: . parse language matlab tokenize split .timestamp 2009-01-31T23:49:47.523+01 .language system]><;
{ split: .text . $.
| :ok
  text split
  [ newline space identifier double integer imaginary
    shell-escape symbol' symbol text
    .hspace " ", "">, ""1a
    .space [+: hspace, "..." [*: [-: linefeed] 1,] linefeed]
    .linefeed ""<, ""=, ""0c
    .newline
      [ space,, ]
      [ +:
        [ "%" [-: "{"] [*: [-: linefeed] 1,],,]
        linefeed
        [ *: hspace ]
        [ *:
          "%{"
          [ *: hspace ]
          linefeed
          [ *: [*: [-: "%}", linefeed] 1,] linefeed, ]
          [ *: hspace ]
          "%}"
          [ *: hspace ]
          [ linefeed, -: 1 ]
          [ *: hspace ]
          ,
        ]
        [ space,, ]
        ,
        "%" [-: "{"] [*: [-: linefeed] 1,] [-: 1]
      ]
      ,
    .shell-escape "!" [*: [-: newline] 1,] newline,
    .identifier ["a-z", "A-Z"] [*: "a-z", "A-Z", "0-9", "_"],
    .digit "0-9"
    .integer [sign,,] [+: digit] [-: "i", "j"],
    .exponent ["D", "d", "E", "e"] ["+", "-",,] [+: digit],
    .decimal-point "." [-: "'", "*", "/", "\", "^"],
    .double
      [sign,,]
      [ [+: digit] [decimal-point [*: digit] [exponent,,], exponent],
        "." [+: digit] [exponent,,]
      ]
      [-: "i", "j"]
      ,
    .imaginary
      [sign,,] [[+: digit] ["." [*: digit]], "." [+: digit]] [exponent,,] ["i", "j"],
    .' [/: identifier integer double imaginary text symbol'] "'",
    .text "'" [*: [-: "'", linefeed] 1, "''"] "'",
    .symbol'
      ")",
      ".'",
      "]",
      [/: identifier integer double imaginary text symbol'] "'"
    .symbol
      "(", "[", "{", "}", ",", ";", ":", "+", "-", "*", "/", "\", "^", "@",
      "." ["*", "/", "\", "^", [-: "."]],
      ["~", "<", ">", "="] ["=",,],
      "&" ["&",,],
      "|" ["|",,],
  ]
}
