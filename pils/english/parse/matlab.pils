><:[module: . parse language matlab .timestamp 2009-01-29T01:30:01.205+01 .language system]><;
{ parse: .text .tag
| :try
  @ tokenize (.text .tag)
  first [matlab-file: .?]
  fold (@@ rules)
}
><:[module: . parse language matlab rules .timestamp 2009-02-01T17:26:41.435+01 .language system]><;
{ state := . = token: . "[" .tag?
| :ok term: .level [=] .embrace "]"; matrix: ."[" =. .rows () .items (); state
}
{ state := . = token: . "{" .tag?
| :ok term: .level [=] .embrace "}";
  cell-array: ."{" =. .rows () .items (); state
}
{ state := token: . " " .tag? | :ok space: state }
{ (space: state) := | :who :ok state call (who) := }
{ [-test-] := | :who :ok [matlab] call (who) := }
{ [matlab] := | :who :ok [statements: .?; matlab] call (who) := }
{ [matlab] := . = token: . "function" .tag
| :ok function: ."function" =.; [matlab]
}
{ (state = statements: .?; ?) := . = token: . "function" .tag
| :ok function: ."function" =.; state
}
{ (function: ."function"; state) := name = token: . [identifier], ? .tag?
| :ok function: ."function" .name; state
}
{ (function: ."function"; state) := . = token: . "[" .tag?
| :ok function: ."function" ."[" =. .output (); state
}
{ (function: ."function" ."[" .output; state)
  := item = token: . [identifier], ? .tag?
| :ok function: ."function" ."[" .output .item; state
}
{ (function: ."function" ."[" .output .item; state)
  := . = token: . [identifier], ? .tag?
| :ok function: ."function" ."[" .output . & (item: .) .item =.; state
}
{ (function: ."function" ."[" .output .item; state) := . = token: . "]" .tag?
| :ok function: ."function" ."[" .output . & (item: .) ."]" =.; state
}
{ (function: ."function" ."[" .output .item; state) := . = token: . "," .tag?
| :ok function: ."function" ."[" .output . & (item: .."," =.); state
}
{ (function: ."function" ."[" .output ."]"; state) := . = token: . "=" .tag?
| :ok function: ."function" .output (output: .."[" ."]" ."=" =.); state
}
{ (function: ."function" .name; state) := . = token: . "=" .tag?
| :ok function: ."function" .output (output: . (item: . name), ."=" =.); state
}
{ (function: ."function" .name; state) := . = token: . "(" .tag?
| :ok input: . () ."(" =.; function: ."function" .output () .name; state
}
{ (function: ."function" .output; state)
  := name = token: . [identifier], ? .tag?
| :ok function: ."function" .output .name; state
}
{ (state = function: ."function"? .output? .name?; ?)
  := . = token: . "(" .tag?
| :ok input: . () ."(" =.; state
}
{ (input: . () ."("; state) := . = token: . ")" .tag?
| :who :ok state call (who) := input: . () ."(" .")" =.
}
{ (input: .."("; state) := name = token: . [identifier], ? .tag?
| :ok input: .."(" .name; state
}
{ (input: .."(" .name; state) := . = token: . ")" .tag?
| :who :ok state call (who) := input: .. & (item: . name) ."(" .")" =.
}
{ (input: .."(" .name; state) := . = token: . "," .tag?
| :ok input: .. & (item: . name ."," =.) ."("; state
}
{ (function: ."function" .output .name; state) := input = input: .? ."(" .")"
| :ok function: ."function" .output .name .input; state
}
{ (function: ."function" .output .name .input; state)
  := stop = token: .? call [.""= .";"] .tag?
| :ok
  statements: . (); function: ."function" .output .name .input .stop; state
}
{ (function: ."function" .name; state)
  := stop = token: .? call [.""= .";"] .tag?
| :ok
  statements: . ();
  function: ."function" .output () .name .input () .stop;
  state
}
{ (function: ."function" .output .name; state)
  := stop = token: .? call [.""= .";"] .tag?
| :ok
  statements: . ();
  function: ."function" .output .name .input () .stop;
  state
}
{ (function: ."function" .output .name .input .stop; state)
  := statements: ..end
| :who :ok
  state call (who) :=
  function: ."function" .output .name .input .stop .statements .end
}
{ (statements: .; state = [function] *?)
  := statement =
  function: ."function"? .output? .name? .input? .stop? .statements? .end?
| :ok statements: .. & (statement: .); state
}
{ (state = statements: .?; ?) := . = token: . "global" .tag?
| :ok global: . () ."global" =.; state
}
{ (global: .."global"; state) := item = token: . [identifier], ? .tag?
| :ok global: .. & (item: .) ."global"; state
}
{ (global: .."global"; statements: .; state)
  := stop = token: .? call [.""= .";"] .tag?
| :ok statements: .. & (statement: . (global: .."global") .stop); state
}
{ (state = statements: .?; ?) := name = token: . [identifier], ? .tag?
| :ok term: . name .level [=] .embrace (); state
}
